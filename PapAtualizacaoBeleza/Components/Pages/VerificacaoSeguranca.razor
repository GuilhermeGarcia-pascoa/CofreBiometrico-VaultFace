@page "/verificacao-seguranca"
@layout EmptyLayout
@rendermode InteractiveServer

@using PapAtualizacaoBeleza
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject EmailService EmailSvc
@inject BaseSql BancoService
@inject TemaService Tema

<PageTitle>VaultFace — Verificação de Segurança</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ── PAINEL ESQUERDO ── *@
    <aside class="vs-aside @(IsReset ? "vs-aside--red" : "vs-aside--amber")">

        <div class="vs-aside-brand">
            <div class="vs-aside-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            <span>VaultFace</span>
        </div>

        <div class="vs-aside-content">
            <div class="vs-aside-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
            </div>
            <h2 class="vs-aside-title">Verificação de Segurança</h2>
            <p class="vs-aside-desc">
                Esta ação requer confirmação em múltiplos passos para proteger o sistema.
            </p>

            <div class="vs-aside-action-box">
                <p class="vs-aside-action-label">Ação solicitada</p>
                <p class="vs-aside-action-name">
                    @(IsReset ? "Reset Total do Sistema" : "Transferência de Master")
                </p>
                @if (!IsReset)
                {
                    <p class="vs-aside-action-target">→ @Estado.NomeAlvoVerificacao</p>
                }
            </div>

            <div class="vs-aside-steps">
                @{
                    int totalPassos = IsReset ? 2 : (novoEmailDigitado.Length > 0 ? 3 : 2);
                }

                @* Step 1 *@
                <div class="vs-aside-step @(passo == 1 ? "vs-aside-step--active" : passo > 1 ? "vs-aside-step--done" : "")">
                    <div class="vs-aside-step-dot">
                        @if (passo > 1)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="10" height="10">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                        }
                        else
                        {

                            <text>1</text>
                        }
                    </div>
                    <span>Código por email</span>
                </div>

                <div class="vs-aside-step-connector @(passo > 1 ? "vs-aside-step-connector--done" : "")"></div>

                @* Step 2 *@
                <div class="vs-aside-step @(passo == 2 ? "vs-aside-step--active" : passo > 2 ? "vs-aside-step--done" : "")">
                    <div class="vs-aside-step-dot">
                        @if (passo > 2)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="10" height="10">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                        }
                        else
                        {

                            <text>2</text>
                        }
                    </div>
                    <span>@(IsReset ? "Confirmar nome" : "Nome + email")</span>
                </div>

                @* Step 3 — só aparece para transferência com novo email *@
                @if (!IsReset)
                {
                    <div class="vs-aside-step-connector @(passo > 2 ? "vs-aside-step-connector--done" : "")"></div>
                    <div class="vs-aside-step @(passo == 3 ? "vs-aside-step--active" : "")">
                        <div class="vs-aside-step-dot">3</div>
                        <span>Verificar novo email</span>
                    </div>
                }
            </div>
        </div>

        <p class="vs-aside-footer">Ação irreversível · Proceda com cautela</p>
    </aside>

    @* ── PAINEL DIREITO ── *@
    <main class="vs-main">
        <div class="vs-form-wrap">

            @* ══════════════ PASSO 1 — Código ══════════════ *@
            @if (passo == 1)
            {
                <div class="vs-pane">
                    <div class="vs-pane-header">
                        <span class="vs-pane-step-tag">Passo 1 de @(IsReset ? "2" : "2–3")</span>
                        <h1 class="vs-pane-title">Verifique o seu email</h1>
                        <p class="vs-pane-sub">
                            Enviámos um código de 6 dígitos para o email registado da conta master.
                            Introduza-o abaixo para continuar.
                        </p>
                    </div>

                    @if (envioEmCurso)
                    {
                        <div class="vs-status-box">
                            <div class="vs-spinner"></div>
                            <span>A enviar email de verificação...</span>
                        </div>
                    }
                    else if (erroEnvio)
                    {
                        <div class="vs-status-box vs-status-box--error">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="flex-shrink:0;">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                            <span>Falha ao enviar email. Verifique as configurações SMTP ou se o email master está confirmado.</span>
                        </div>
                    }
                    else
                    {
                        <div class="vs-code-area">
                            <label class="vs-label">Código de verificação</label>
                            <div class="vs-code-wrap" @onclick="FocarInputCodigo">
                                <input id="vs-cod-input"
                                       class="vs-cod-hidden"
                                       type="text"
                                       inputmode="numeric"
                                       maxlength="6"
                                       autocomplete="one-time-code"
                                       @oninput="OnCodigoInput"
                                       @onkeydown="OnCodigoKeyDown"
                                       @onfocus="@(() => codFocado = true)"
                                       @onblur="@(() => codFocado = false)" />
                                @for (int i = 0; i < 6; i++)
                                {
                                    int idx = i;
                                    bool ativo = codFocado && codigoDigitado.Length == idx;
                                    bool cheio = codigoDigitado.Length > idx;
                                    <div class="vs-cod-box @(ativo ? "vs-cod-box--active" : "") @(cheio ? "vs-cod-box--filled" : "") @(erroCodigo ? "vs-cod-box--error" : "")">
                                        @(cheio? codigoDigitado[idx].ToString() : "")
                                    </div>
                                    @if (idx == 2)
                                    {
                                        <span class="vs-cod-sep">–</span>
                                    }
                                }
                            </div>
                            @if (erroCodigo)
                            {
                                <p class="vs-field-error">
                                    @if (Estado.CodigoExpirado)
                                    {
                                        <text>Código expirado. </text>
                                        <button class="vs-link" @onclick="ReenviarCodigo">Reenviar novo código</button>
                                    }
                                    else
                                    {
                                        <text>Código incorreto. Verifique e tente novamente.</text>
                                    }
                                </p>
                            }
                        </div>

                        <div class="vs-actions">
                            <button class="vs-btn-ghost" @onclick="Cancelar">Cancelar</button>
                            <button class="vs-btn-confirm @(IsReset ? "vs-btn--red" : "vs-btn--amber")"
                                    @onclick="VerificarCodigo"
                                    disabled="@(codigoDigitado.Length < 6)">
                                Continuar →
                            </button>
                        </div>

                        <p class="vs-hint">
                            Não recebeu?
                            <button class="vs-link" @onclick="ReenviarCodigo" disabled="@reenvioEmCurso">
                                @(reenvioEmCurso ? "A reenviar..." : "Reenviar código")
                            </button>
                        </p>
                    }
                </div>
            }

            @* ══════════════ PASSO 2 — Nome + Email ══════════════ *@
            @if (passo == 2)
            {
                <div class="vs-pane">
                    <div class="vs-pane-header">
                        <span class="vs-pane-step-tag">Passo 2 de @(IsReset ? "2" : "2–3")</span>
                        <h1 class="vs-pane-title">@(IsReset ? "Confirme o nome" : "Confirme a transferência")</h1>
                        <p class="vs-pane-sub">
                            @if (IsReset)
                            {
                                <text>Escreva o <strong>seu próprio nome</strong> exatamente como aparece no sistema para confirmar o reset.</text>
                            }
                            else
                            {
                                <text>Confirme o nome do novo master. Pode também definir um novo email para a conta.</text>
                            }
                        </p>
                    </div>

                    @* Nome a confirmar *@
                    <div class="vs-name-ref @(IsReset ? "vs-name-ref--red" : "vs-name-ref--amber")">
                        <span class="vs-name-ref-label">@(IsReset ? "O seu nome" : "Nome do novo master")</span>
                        <span class="vs-name-ref-value">@Estado.NomeAlvoVerificacao</span>
                    </div>

                    <div class="vs-field-group" style="margin-bottom: 24px;">
                        <label class="vs-label">Escreva o nome aqui</label>
                        <input class="vs-text-input @(erroNome ? "vs-text-input--error" : "")"
                               type="text"
                               placeholder="@Estado.NomeAlvoVerificacao"
                               @bind="nomeDigitado"
                               @bind:event="oninput"
                               @onkeydown="OnNomeKeyDown" />
                        @if (erroNome)
                        {
                            <p class="vs-field-error">Nome incorreto. Atenção a maiúsculas e espaços.</p>
                        }
                    </div>

                    @* Campo de email — só aparece em transferência *@
                    @if (!IsReset)
                    {
                        <div class="vs-email-section">
                            <div class="vs-email-section-header">
                                <div>
                                    <p class="vs-email-section-title">Novo email para o master</p>
                                    <p class="vs-email-section-sub">Opcional. Se vazio, o email atual é mantido.</p>
                                </div>
                                <span class="vs-badge-optional">Opcional</span>
                            </div>

                            <div class="vs-field-group">
                                <input class="vs-text-input @(erroEmail ? "vs-text-input--error" : "")"
                                       type="email"
                                       placeholder="novo@email.com"
                                       @bind="novoEmailDigitado"
                                       @bind:event="oninput" />
                                @if (erroEmail)
                                {
                                    <p class="vs-field-error">Email inválido. Verifique o formato.</p>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(novoEmailDigitado))
                            {
                                <div class="vs-email-notice">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink:0; margin-top:1px;">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="8" x2="12" y2="12" />
                                        <line x1="12" y1="16" x2="12.01" y2="16" />
                                    </svg>
                                    <span>Será enviado um código de confirmação para <strong>@novoEmailDigitado</strong> antes de guardar.</span>
                                </div>
                            }
                        </div>
                    }

                    <div class="vs-actions">
                        <button class="vs-btn-ghost" @onclick="VoltarStep1">← Voltar</button>
                        <button class="vs-btn-confirm @(IsReset ? "vs-btn--red" : "vs-btn--amber")"
                                @onclick="AvancarDoStep2"
                                disabled="@(string.IsNullOrWhiteSpace(nomeDigitado) || executando)">
                            @if (!IsReset && !string.IsNullOrWhiteSpace(novoEmailDigitado))
                            {
                                <text>Verificar email →</text>
                            }
                            else if (IsReset)
                            {
                                @if (executando)
                                {
                                    <span class="vs-spinner-sm"></span>
                                    <span>A resetar...</span>
                                }
                                else
                                {
                                    <text>Resetar sistema agora</text>
                                }
                            }
                            else
                            {
                                @if (executando)
                                {
                                    <span class="vs-spinner-sm"></span>
                                    <span>A transferir...</span>
                                }
                                else
                                {
                                    <text>Transferir master agora</text>
                                }
                            }
                        </button>
                    </div>
                </div>
            }

            @* ══════════════ PASSO 3 — Verificar Novo Email ══════════════ *@
            @if (passo == 3)
            {
                <div class="vs-pane">
                    <div class="vs-pane-header">
                        <span class="vs-pane-step-tag">Passo 3 de 3</span>
                        <h1 class="vs-pane-title">Confirme o novo email</h1>
                        <p class="vs-pane-sub">
                            Enviámos um código de verificação para <strong>@novoEmailDigitado</strong>.
                            Introduza-o abaixo para confirmar que o email é válido.
                        </p>
                    </div>

                    @* destaque do email novo *@
                    <div class="vs-name-ref vs-name-ref--amber" style="margin-bottom: 24px;">
                        <span class="vs-name-ref-label">Novo email da conta master</span>
                        <span class="vs-name-ref-value" style="font-size:15px; word-break:break-all;">@novoEmailDigitado</span>
                    </div>

                    @if (envioEmailNovoEmCurso)
                    {
                        <div class="vs-status-box">
                            <div class="vs-spinner"></div>
                            <span>A enviar código para o novo email...</span>
                        </div>
                    }
                    else if (erroEnvioEmailNovo)
                    {
                        <div class="vs-status-box vs-status-box--error">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="flex-shrink:0;">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                            <span>Não foi possível enviar o email. Verifique o endereço e tente novamente.</span>
                        </div>
                        <div class="vs-actions">
                            <button class="vs-btn-ghost" @onclick="VoltarStep2">← Corrigir email</button>
                            <button class="vs-btn-confirm vs-btn--amber" @onclick="EnviarCodigoNovoEmail">Reenviar</button>
                        </div>
                    }
                    else
                    {
                        <div class="vs-code-area">
                            <label class="vs-label">Código de verificação</label>
                            <div class="vs-code-wrap" @onclick="FocarInputCodigoNovo">
                                <input id="vs-cod-novo-input"
                                       class="vs-cod-hidden"
                                       type="text"
                                       inputmode="numeric"
                                       maxlength="6"
                                       autocomplete="one-time-code"
                                       @oninput="OnCodigoNovoEmailInput"
                                       @onkeydown="OnCodigoNovoEmailKeyDown"
                                       @onfocus="@(() => codNovoFocado = true)"
                                       @onblur="@(() => codNovoFocado = false)" />
                                @for (int i = 0; i < 6; i++)
                                {
                                    int idx = i;
                                    bool ativo = codNovoFocado && codigoNovoEmailDigitado.Length == idx;
                                    bool cheio = codigoNovoEmailDigitado.Length > idx;
                                    <div class="vs-cod-box @(ativo ? "vs-cod-box--active" : "") @(cheio ? "vs-cod-box--filled" : "") @(erroCodigoNovo ? "vs-cod-box--error" : "")">
                                        @(cheio? codigoNovoEmailDigitado[idx].ToString() : "")
                                    </div>
                                    @if (idx == 2)
                                    {
                                        <span class="vs-cod-sep">–</span>
                                    }
                                }
                            </div>
                            @if (erroCodigoNovo)
                            {
                                <p class="vs-field-error">Código incorreto. Verifique e tente novamente.</p>
                            }
                        </div>

                        <div class="vs-actions">
                            <button class="vs-btn-ghost" @onclick="VoltarStep2">← Voltar</button>
                            <button class="vs-btn-confirm vs-btn--amber"
                                    @onclick="ConfirmarEmailNovoEExecutar"
                                    disabled="@(codigoNovoEmailDigitado.Length < 6 || executando)">
                                @if (executando)
                                {
                                    <span class="vs-spinner-sm"></span>
                                    <span>A transferir...</span>
                                }
                                else
                                {
                                    <text>Confirmar e transferir →</text>
                                }
                            </button>
                        </div>

                        <p class="vs-hint">
                            Não recebeu?
                            <button class="vs-link" @onclick="EnviarCodigoNovoEmail" disabled="@reenvioNovoEmailCurso">
                                @(reenvioNovoEmailCurso ? "A reenviar..." : "Reenviar código")
                            </button>
                            &nbsp;·&nbsp;
                            <button class="vs-link" @onclick="VoltarStep2">Corrigir email</button>
                        </p>
                    }
                </div>
            }

        </div>
    </main>
</div>

@code {
    // ── estado geral ──
    private int passo = 1;
    private bool _codigoJaEnviado = false;
    private bool IsReset => Estado.AcaoPendente == AcaoCritica.ResetarSistema;

    // ── step 1 — código existente ──
    private bool envioEmCurso = true;
    private bool erroEnvio = false;
    private bool reenvioEmCurso = false;
    private string codigoDigitado = "";
    private bool codFocado = false;
    private bool erroCodigo = false;

    // ── step 2 — nome + email opcional ──
    private string nomeDigitado = "";
    private bool erroNome = false;
    private string novoEmailDigitado = "";
    private bool erroEmail = false;
    private bool executando = false;

    // ── step 3 — verificar novo email ──
    private string codigoNovoEmail = "";           // guardado para comparar
    private string codigoNovoEmailDigitado = "";   // o que o user digitou
    private bool codNovoFocado = false;
    private bool erroCodigoNovo = false;
    private bool envioEmailNovoEmCurso = false;
    private bool erroEnvioEmailNovo = false;
    private bool reenvioNovoEmailCurso = false;

    // ── lifecycle ──

    protected override void OnInitialized()
    {
        if (!Estado.EstadoLogado ||
            Estado.UsuarioAtual?.Permissao != NivelPermissao.AdminSupremo ||
            Estado.AcaoPendente == null)
        {
            Navigation.NavigateTo("/admin", replace: true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _codigoJaEnviado) return;
        if (Estado.AcaoPendente == null) return;
        _codigoJaEnviado = true;
        await EnviarCodigoInicial();
    }

    // ── step 1 — envio e verificação do código atual ──

    private async Task EnviarCodigoInicial()
    {
        envioEmCurso = true;
        erroEnvio = false;
        StateHasChanged();
        try
        {
            var (email, confirmado) = BancoService.ObterEmailUserMaster();
            if (string.IsNullOrEmpty(email) || !confirmado) { erroEnvio = true; return; }

            string codigo = await EmailSvc.EnviarVerificacaoAcaoCriticaAsync(
                email, Estado.UsuarioAtual!.Nome,
                Estado.AcaoPendente!.Value, Estado.NomeAlvoVerificacao);

            Estado.CodigoVerificacaoPendente = codigo;
            Estado.CodigoGeradoEm = DateTime.Now;
        }
        catch { erroEnvio = true; }
        finally { envioEmCurso = false; StateHasChanged(); }
    }

    private async Task ReenviarCodigo()
    {
        reenvioEmCurso = true;
        codigoDigitado = "";
        erroCodigo = false;
        StateHasChanged();
        await EnviarCodigoInicial();
        reenvioEmCurso = false;
        StateHasChanged();
    }

    private void OnCodigoInput(ChangeEventArgs e)
    {
        string raw = e.Value?.ToString() ?? "";
        codigoDigitado = new string(raw.Where(char.IsDigit).ToArray());
        if (codigoDigitado.Length > 6) codigoDigitado = codigoDigitado[..6];
        erroCodigo = false;
        if (codigoDigitado.Length == 6) VerificarCodigo();
    }

    private void OnCodigoKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && codigoDigitado.Length > 0)
            codigoDigitado = codigoDigitado[..^1];
    }

    private void FocarInputCodigo() { }

    private void VerificarCodigo()
    {
        if (Estado.CodigoExpirado) { erroCodigo = true; return; }
        if (codigoDigitado != Estado.CodigoVerificacaoPendente)
        {
            erroCodigo = true;
            codigoDigitado = "";
            return;
        }
        erroCodigo = false;
        passo = 2;
    }

    // ── step 2 — confirmar nome + email opcional ──

    private void OnNomeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(nomeDigitado))
            AvancarDoStep2();
    }

    private async void AvancarDoStep2()
    {
        // validar nome
        if (nomeDigitado.Trim() != Estado.NomeAlvoVerificacao.Trim())
        {
            erroNome = true;
            return;
        }
        erroNome = false;

        // validar email se foi introduzido
        if (!string.IsNullOrWhiteSpace(novoEmailDigitado))
        {
            if (!novoEmailDigitado.Contains('@') || !novoEmailDigitado.Contains('.'))
            {
                erroEmail = true;
                return;
            }
            erroEmail = false;

            // avança para step 3 — verificar o novo email
            passo = 3;
            await EnviarCodigoNovoEmail();
            return;
        }

        // sem novo email — executa diretamente
        await ExecutarAcao(novoEmail: null);
    }

    private void VoltarStep1()
    {
        passo = 1;
        codigoDigitado = "";
        nomeDigitado = "";
        erroNome = false;
        erroEmail = false;
        erroCodigo = false;
    }

    // ── step 3 — verificar novo email ──

    private async Task EnviarCodigoNovoEmail()
    {
        reenvioNovoEmailCurso = true;
        envioEmailNovoEmCurso = true;
        erroEnvioEmailNovo = false;
        codigoNovoEmailDigitado = "";
        erroCodigoNovo = false;
        StateHasChanged();

        try
        {
            // envia código para o NOVO email — usa o método simples de verificação
            string codigo = await EmailSvc.EnviarCodigoVerificacaoAsync(
                novoEmailDigitado, Estado.NomeAlvoVerificacao);
            codigoNovoEmail = codigo;
        }
        catch { erroEnvioEmailNovo = true; }
        finally
        {
            envioEmailNovoEmCurso = false;
            reenvioNovoEmailCurso = false;
            StateHasChanged();
        }
    }

    private void OnCodigoNovoEmailInput(ChangeEventArgs e)
    {
        string raw = e.Value?.ToString() ?? "";
        codigoNovoEmailDigitado = new string(raw.Where(char.IsDigit).ToArray());
        if (codigoNovoEmailDigitado.Length > 6) codigoNovoEmailDigitado = codigoNovoEmailDigitado[..6];
        erroCodigoNovo = false;
        if (codigoNovoEmailDigitado.Length == 6) ConfirmarEmailNovoEExecutar();
    }

    private void OnCodigoNovoEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && codigoNovoEmailDigitado.Length > 0)
            codigoNovoEmailDigitado = codigoNovoEmailDigitado[..^1];
    }

    private void FocarInputCodigoNovo() { }

    private async void ConfirmarEmailNovoEExecutar()
    {
        if (codigoNovoEmailDigitado != codigoNovoEmail)
        {
            erroCodigoNovo = true;
            codigoNovoEmailDigitado = "";
            return;
        }
        erroCodigoNovo = false;
        await ExecutarAcao(novoEmail: novoEmailDigitado.Trim());
    }

    private void VoltarStep2()
    {
        passo = 2;
        codigoNovoEmailDigitado = "";
        erroCodigoNovo = false;
        erroEnvioEmailNovo = false;
    }

    // ── execução final ──

    private async Task ExecutarAcao(string? novoEmail)
    {
        executando = true;
        StateHasChanged();

        bool foiReset = IsReset;
        int idNovoMaster = Estado.IdNovoMasterPendente;
        string nomeMaster = Estado.UsuarioAtual?.Nome ?? "Master";
        int idAtual = Estado.UsuarioAtual!.Id;

        await Task.Run(() =>
        {
            if (foiReset)
            {
                BancoService.ResetarSistema(nomeMaster);
            }
            else
            {
                // atualiza email ANTES de transferir se foi fornecido
                if (!string.IsNullOrEmpty(novoEmail))
                    BancoService.AtualizarEmail(idNovoMaster, novoEmail, confirmado: true);

                BancoService.TransferirAdminMaster(idAtual, idNovoMaster);
            }
        });

        Estado.LimparVerificacao();

        if (foiReset)
        {
            Estado.Logout();
            Estado.EstadoCofreAtual = EstadoCofre.Fechado;
            Navigation.NavigateTo("/", replace: true);
        }
        else
        {
            if (Estado.UsuarioAtual != null)
                Estado.UsuarioAtual.Permissao = NivelPermissao.AdminComum;
            Navigation.NavigateTo("/UserLogado", replace: true);
        }
    }

    private void Cancelar()
    {
        Estado.LimparVerificacao();
        Navigation.NavigateTo("/admin", replace: true);
    }
}

