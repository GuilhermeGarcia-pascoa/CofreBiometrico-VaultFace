    /* ══════════════════════════════════════════
                           ESTILOS COMUNS (usam variáveis, funcionam em ambos os modos)
                        ══════════════════════════════════════════ */

    /* Toggle button */
    .btn-tema {
        background: none;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 7px 9px;
        cursor: pointer;
        color: var(--muted);
