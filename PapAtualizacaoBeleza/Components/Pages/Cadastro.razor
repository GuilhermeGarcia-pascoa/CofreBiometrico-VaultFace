        padding: 36px 24px;
    }

    .wizard {
        width: 100%;
        max-width: 980px;
        display: flex;
        flex-direction: column;
        gap: 28px;
    }

    /* ── STEPS BAR ── */
    .steps-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        padding: 0 24px;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        opacity: 0.35;
        transition: opacity 0.3s;
    }

    .step--active, .step--done {
