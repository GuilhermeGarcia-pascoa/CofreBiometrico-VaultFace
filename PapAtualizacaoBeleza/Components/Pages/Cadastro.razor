@page "/cadastro"
@using PapAtualizacaoBeleza.Components.Layout
@using Emgu.CV
@using Emgu.CV.CvEnum
@using Emgu.CV.Structure
@using Emgu.CV.Util
@using System.Drawing
@using System.IO
@using System.Threading
@layout EmptyLayout
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation
@inject BaseSql BaseSqlService
@inject EmailService EmailService
@inject EstadoApp estadoApp
@inject TemaService Tema
@inject IJSRuntime JS

<PageTitle>Cadastro Biométrico — VaultFace</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* TOPBAR *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            <button class="btn-tema" @onclick="Tema.Alternar" title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            @if (!primeiroUtilizador)
            {
                <button class="btn-outline" @onclick="VoltarParaAdmin">← Painel Admin</button>
            }
            else
            {
                <span class="topbar-hint">Registe o primeiro utilizador para continuar</span>
            }
        </div>
    </header>

    <main class="center">
        <div class="wizard">

            @* STEPS INDICATOR *@
            <div class="steps-bar">
                <div class="step @(etapa >= Etapa.Nome ? "step--active" : "") @(etapa > Etapa.Nome ? "step--done" : "")">
                    <div class="step-circle">
                        @if (etapa > Etapa.Nome)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
                        }
                        else
                        {
                            <span>1</span>
                        }
                    </div>
                    <span class="step-label">Nome</span>
                </div>
                <div class="step-connector @(etapa > Etapa.Nome ? "connector--done" : "")"></div>
                @if (primeiroUtilizador)
                {
                    <div class="step @(etapa >= Etapa.VerificacaoEmail ? "step--active" : "") @(etapa > Etapa.VerificacaoEmail ? "step--done" : "")">
                        <div class="step-circle">
                            @if (etapa > Etapa.VerificacaoEmail)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
                            }
                            else
                            {
                                <span>2</span>
                            }
                        </div>
                        <span class="step-label">Email</span>
                    </div>
                    <div class="step-connector @(etapa > Etapa.VerificacaoEmail ? "connector--done" : "")"></div>
                }
                <div class="step @(etapa >= Etapa.Camera ? "step--active" : "") @(etapa > Etapa.Camera ? "step--done" : "")">
                    <div class="step-circle">
                        @if (etapa > Etapa.Camera)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
                        }
                        else
                        {
                            <span>@(primeiroUtilizador ? "3" : "2")</span>
                        }
                    </div>
                    <span class="step-label">Captura</span>
                </div>
                <div class="step-connector @(etapa > Etapa.Camera ? "connector--done" : "")"></div>
                <div class="step @(etapa >= Etapa.Concluido ? "step--active" : "")">
                    <div class="step-circle"><span>@(primeiroUtilizador ? "4" : "3")</span></div>
                    <span class="step-label">Concluído</span>
                </div>
            </div>

            @* ETAPA 1: NOME *@
            @if (etapa == Etapa.Nome)
            {
                <div class="card card--centered animate-in">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <h1 class="card-title">Identificação do Utilizador</h1>
                    <p class="card-sub">Introduza o nome completo antes de iniciar a captura facial</p>

                    <div class="name-form">
                        <div class="field-wrapper">
                            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <input id="nome-input"
                                   type="text"
                                   @bind="nomeUsuario"
                                   @bind:event="oninput"
                                   @onkeydown="OnNomeKeyDown"
                                   class="field-input @(nomeErro ? "field-input--error" : "")"
                                   placeholder="Ex: João da Silva"
                                   autofocus
                                   maxlength="80" />
                        </div>
                        @if (nomeErro)
                        {
                            <p class="field-error">Por favor insira um nome válido.</p>
                        }
                        @if (primeiroUtilizador)
                        {
                            <div class="field-wrapper">
                                <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                    <polyline points="22,6 12,13 2,6" />
                                </svg>
                                <input type="email"
                                       @bind="emailUsuario"
                                       @bind:event="oninput"
                                       class="field-input @(emailErro ? "field-input--error" : "")"
                                       placeholder="Ex: joao@email.com"
                                       maxlength="200" />
                            </div>
                            @if (emailErro)
                            {
                                <p class="field-error">Por favor insira um email válido.</p>
                            }
                        }

                        @* ── Bloco de consentimento biométrico ── *@
                        <div class="consent-box">
                            <div class="consent-header">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                                <strong>Informação sobre dados biométricos</strong>
                            </div>
                            <p class="consent-text">
                                <strong>O que é biometria?</strong> Biometria é a identificação de uma pessoa com base nas suas
                                características físicas únicas — neste caso, o rosto. O sistema extrai padrões matemáticos do seu
                                rosto e guarda-os na base de dados para comparação futura.
                            </p>
                            <p class="consent-text">
                                <strong>Como são protegidos os seus dados?</strong> A imagem facial é encriptada com AES-256 em
                                dupla camada antes de ser guardada. Os dados são processados localmente — nunca enviados para
                                servidores externos. A chave de encriptação está vinculada a esta sessão Windows e é irrecuperável
                                sem ela.
                            </p>
                            <p class="consent-text">
                                <strong>Para que são usados?</strong> Exclusivamente para autenticação no cofre VaultFace.
                            </p>
                            <label class="consent-check">
                                <input type="checkbox" @bind="consentimentoDado" />
                                <span>Compreendo que a minha imagem facial será processada e armazenada de forma encriptada para fins de autenticação no VaultFace.</span>
                            </label>
                        </div>

                        <button class="btn-primary btn-full"
                                @onclick="@(primeiroUtilizador? AvancarParaVerificacaoEmail : AvancarParaCamera)"
                                disabled="@(string.IsNullOrWhiteSpace(nomeUsuario) || (primeiroUtilizador && string.IsNullOrWhiteSpace(emailUsuario)) || !consentimentoDado)">
                            @(primeiroUtilizador ? "Continuar para verificação" : "Continuar para captura")
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                        </button>
                    </div>

                    <div class="info-inline">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 16v-4M12 8h.01" /></svg>
                        O nome será associado permanentemente à biometria registada
                    </div>
                </div>
            }

            @* ETAPA 1.5: VERIFICAÇÃO EMAIL (apenas user master) *@
            @if (etapa == Etapa.VerificacaoEmail)
            {
                <div class="card card--centered animate-in">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                    <h1 class="card-title">Verificação de Email</h1>
                    <p class="card-sub">
                        Enviámos um código de 6 dígitos para
                        <strong>@emailUsuario</strong>.<br />
                        Introduza o código abaixo para continuar.
                    </p>

                    <div class="name-form" style="width:100%;">
                        <!-- Inputs individuais dos 6 dígitos -->
                        <div class="codigo-inputs">
                            @for (int i = 0; i < 6; i++)
                            {
                                int idx = i;
                                <input id="cod-@idx"
                                       type="text"
                                       inputmode="numeric"
                                       maxlength="1"
                                       class="cod-input @(codigoErro ? "cod-input--error" : "")"
                                       value="@codigoDigitos[idx]"
                                       @oninput="@(async e => await OnDigitInput(e, idx))"
                                       @onkeydown="@(async e => await OnDigitKeyDown(e, idx))"
                                       autocomplete="off" />
                            }
                        </div>

                        @if (codigoErro)
                        {
                            <p class="field-error" style="text-align:center;">Código incorreto. Tente novamente.</p>
                        }
                        @if (codigoExpirado)
                        {
                            <p class="field-error" style="text-align:center;">O código expirou. Reenvie um novo código.</p>
                        }

                        <button class="btn-primary btn-full"
                                @onclick="VerificarCodigo"
                                disabled="@(codigoDigitos.Any(string.IsNullOrEmpty) || verificandoCodigo)">
                            @if (verificandoCodigo)
                            {
                                <span class="spin-sm" style="border-color:white;border-top-color:transparent;"></span>
                                <span>A verificar...</span>
                            }
                            else
                            {
                                <span>Verificar código</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                            }
                        </button>

                        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;">
                            <button class="btn-ghost-sm" @onclick="VoltarParaNomeDeVerificacao">← Alterar email</button>
                            <button class="btn-ghost-sm" @onclick="ReenviarCodigo" disabled="@reenvioDesativado">
                                @if (reenvioDesativado)
                                {
                                    <span>Reenviar em @segundosReenvio s</span>
                                }
                                else
                                {
                                    <span>Reenviar código</span>
                                }
                            </button>
                        </div>
                    </div>

                    <div class="info-inline">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 16v-4M12 8h.01" /></svg>
                        O código expira em 10 minutos
                    </div>
                </div>
            }

            @* ETAPA 2: CÂMERA *@
            @if (etapa == Etapa.Camera)
            {
                <div class="layout animate-in">

                    @* CAMERA PANEL *@
                    <div class="panel camera-panel">
                        <div class="panel-header">
                            <div>
                                <h2>Captura Facial</h2>
                                <p>A registar biometria para <strong>@nomeUsuario</strong></p>
                            </div>
                            <div class="header-actions">
                                <button class="btn-ghost-sm" @onclick="VoltarParaNome">← Alterar nome</button>
                                @if (cameraAtiva)
                                {
                                    <button class="btn-danger-sm" @onclick="PararCamera">Desligar</button>
                                }
                            </div>
                        </div>

                        <div class="viewport @EstiloViewport()">
                            @if (!cameraAtiva)
                            {
                                <div class="screen-idle">
                                    <div class="idle-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                                            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                            <circle cx="12" cy="13" r="4" />
                                        </svg>
                                    </div>
                                    <p>Câmera inativa</p>
                                    <button class="btn-primary" @onclick="IniciarCamera">Ligar câmera</button>
                                </div>
                            }
                            else if (string.IsNullOrEmpty(imageBase64))
                            {
                                <div class="screen-loading">
                                    <div class="spin"></div>
                                    <p>A iniciar sensor...</p>
                                </div>
                            }
                            else
                            {
                                <img src="@imageBase64" class="feed" alt="câmera" />

                                <div class="face-guide @EstiloGuia()">
                                    <svg class="guide-svg" viewBox="0 0 200 240" fill="none">
                                        <ellipse cx="100" cy="120" rx="72" ry="90"
                                                 stroke="currentColor" stroke-width="2.5"
                                                 stroke-dasharray="@(estadoCaptura == EstadoCaptura.Estavel || estadoCaptura == EstadoCaptura.Capturando ? "0" : "8 6")"
                                                 fill="none" />
                                    </svg>
                                </div>

                                @if (estadoCaptura == EstadoCaptura.Estabilizando)
                                {
                                    <div class="progress-bar-wrap">
                                        <div class="progress-bar" style="width: @((framesEstaveis * 100 / FRAMES_PARA_CAPTURAR))%"></div>
                                    </div>
                                }

                                <div class="instruction-pill @EstiloInstrucao()">
                                    @MensagemInstrucao()
                                </div>
                            }
                        </div>

                        <div class="checklist">
                            <div class="check-item @(cameraAtiva ? "check-ok" : "")">
                                <span class="check-dot"></span> Câmera ativa
                            </div>
                            <div class="check-item @(estadoCaptura >= EstadoCaptura.Estabilizando ? "check-ok" : "")">
                                <span class="check-dot"></span> Rosto centrado
                            </div>
                            <div class="check-item @(estadoCaptura == EstadoCaptura.Estavel || estadoCaptura == EstadoCaptura.Capturando ? "check-ok" : "")">
                                <span class="check-dot"></span> Imóvel
                            </div>
                            <div class="check-item check-ok">
                                <span class="check-dot"></span> Nome preenchido
                            </div>
                        </div>
                    </div>

                    @* FORM SIDE *@
                    <div class="form-side">
                        <div class="panel">
                            <div class="panel-header">
                                <div>
                                    <h2>Estado da Captura</h2>
                                    <p>A captura é feita automaticamente</p>
                                </div>
                            </div>
                            <div class="form-body">
                                <div class="user-badge">
                                    <div class="user-avatar">
                                        @nomeUsuario.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <p class="user-name">@nomeUsuario</p>
                                        <p class="user-role">Utilizador a registar</p>
                                    </div>
                                </div>

                                <div class="status-processo @EstiloStatusProcesso()">
                                    <div class="status-icon">
                                        @if (salvando)
                                        {
                                            <div class="spin-sm"></div>
                                        }
                                        else if (estadoCaptura >= EstadoCaptura.Estavel)
                                        {
                                            <div class="pulse-dot pulse-green"></div>
                                        }
                                        else
                                        {
                                            <div class="pulse-dot pulse-gray"></div>
                                        }
                                    </div>
                                    <span>@MensagemStatusProcesso()</span>
                                </div>

                                @if (estadoCaptura == EstadoCaptura.Estabilizando)
                                {
                                    <div class="progress-detail">
                                        <div class="progress-detail-bar">
                                            <div class="progress-detail-fill" style="width: @((framesEstaveis * 100 / FRAMES_PARA_CAPTURAR))%"></div>
                                        </div>
                                        <span class="progress-detail-label">@framesEstaveis / @FRAMES_PARA_CAPTURAR frames estáveis</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="info-card">
                            <p class="info-title">Como funciona</p>
                            <ol class="info-steps">
                                <li>Posicione o rosto dentro da guia oval</li>
                                <li>Fique imóvel — o sistema aguarda ~1.5 segundos</li>
                                <li>A captura e o registo são automáticos</li>
                            </ol>
                        </div>

                        @if (!string.IsNullOrEmpty(mensagemFeedback))
                        {
                            <div class="feedback-card @(erro ? "feedback--error" : "feedback--success")">
                                <div class="feedback-icon">
                                    @if (erro)
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <circle cx="12" cy="12" r="10" />
                                            <path d="M15 9l-6 6M9 9l6 6" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                            <polyline points="22 4 12 14.01 9 11.01" />
                                        </svg>
                                    }
                                </div>
                                <div class="feedback-text">
                                    <p class="feedback-title">@(erro ? "Erro" : "Sucesso")</p>
                                    <p class="feedback-msg">@mensagemFeedback</p>
                                </div>
                                <button class="feedback-close" @onclick="() => mensagemFeedback = null">✕</button>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ETAPA 3: CONCLUÍDO *@
            @if (etapa == Etapa.Concluido)
            {
                <div class="card card--centered animate-in">
                    <div class="card-icon card-icon--success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                    </div>
                    <h1 class="card-title">Biometria Registada!</h1>
                    <p class="card-sub">O utilizador <strong>@nomeRegistado</strong> foi adicionado com sucesso ao sistema.</p>

                    @if (primeiroUtilizador)
                    {
                        @if (emailEnviado)
                        {
                            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--green);background:var(--green-bg);border:1px solid var(--green-br);border-radius:8px;padding:10px 16px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><polyline points="20 6 9 17 4 12" /></svg>
                                Email de confirmação enviado para <strong style="margin-left:4px;">@emailUsuario</strong>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(emailErroEnvio))
                        {
                            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--amber);background:var(--amber-bg);border:1px solid var(--amber-br);border-radius:8px;padding:10px 16px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10" /><path d="M12 8v4M12 16h.01" /></svg>
                                @emailErroEnvio
                            </div>
                        }
                    }

                    <p class="redirect-hint">A redirecionar em @contagemRegressiva segundos...</p>
                </div>
            }

        </div>
    </main>
</div>

@code {
    private enum Etapa { Nome, VerificacaoEmail, Camera, Concluido }
    private enum EstadoCaptura { Aguardando, RostoDetectado, Estabilizando, Estavel, Capturando }

    private const int FRAMES_PARA_CAPTURAR = 45;
    private const double MARGEM_CENTRO = 0.30;
    private const double TAMANHO_MIN_ROSTO = 0.15;

    // Debounce: o estado visual só muda após este número de frames consecutivos no mesmo estado
    private const int FRAMES_DEBOUNCE_SUBIDA = 6;   // frames para "subir" de estado (ex: Aguardando → RostoDetectado)
    private const int FRAMES_DEBOUNCE_DESCIDA = 10;  // frames para "descer" de estado — mais alto = menos piscar ao perder rosto

    // Limita o render da UI: só faz StateHasChanged a cada N frames, a menos que o estado mude
    private const int FRAMES_POR_RENDER = 2;
    private int _framesSemRender = 0;

    private readonly BaseSql baseSql = new();
    private VideoCapture? camera;
    private CascadeClassifier? faceDetector;
    private Mat frame = new Mat();
    private readonly object frameLock = new object();

    private Etapa etapa = Etapa.Nome;
    private bool cameraAtiva = false;
    private CancellationTokenSource? cts;
    private string imageBase64 = "";
    private string mensagemFeedback = "";
    private bool erro = false;
    private string nomeUsuario = "";
    private string nomeRegistado = "";
    private bool salvando = false;
    private bool primeiroUtilizador = false;
    private bool nomeErro = false;
    private bool consentimentoDado = false; // checkbox de consentimento biométrico
    private string emailUsuario = "";
    private bool emailErro = false;
    private string emailErroEnvio = "";
    private bool emailEnviado = false;

    // ── Verificação de código ──
    private string[] codigoDigitos = new string[6];
    private string _codigoGerado = "";
    private DateTime _codigoExpiracao;
    private bool codigoErro = false;
    private bool codigoExpirado = false;
    private bool verificandoCodigo = false;
    private bool reenvioDesativado = false;
    private int segundosReenvio = 60;
    private CancellationTokenSource? _ctsReenvio;
    private int contagemRegressiva = 3;

    protected override void OnInitialized()
    {
        var existentes = baseSql.ObterUsuariosComRostos();
        primeiroUtilizador = existentes == null || !existentes.Any();

        if (!primeiroUtilizador && !estadoApp.EhAdmin)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        try
        {
            string cascadePath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "haarcascade_frontalface_default.xml");
            if (File.Exists(cascadePath))
                faceDetector = new CascadeClassifier(cascadePath);
            else
            {
                erro = true;
                mensagemFeedback = "Ficheiro de deteção facial não encontrado.";
            }
        }
        catch (Exception ex) { erro = true; mensagemFeedback = ex.Message; }
    }

    private void VoltarParaAdmin() { PararCamera(); Navigation.NavigateTo("/admin"); }

    private async Task OnNomeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AvancarParaCamera();
    }

    private static bool EmailValido(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        try { var addr = new System.Net.Mail.MailAddress(email); return addr.Address == email.Trim(); }
        catch { return false; }
    }

    // Chamado apenas para utilizadores NÃO master (vai direto à câmera)
    private async Task AvancarParaCamera()
    {
        if (string.IsNullOrWhiteSpace(nomeUsuario))
        {
            nomeErro = true;
            return;
        }
        nomeErro = false;
        nomeUsuario = nomeUsuario.Trim();
        etapa = Etapa.Camera;
        StateHasChanged();
        await Task.Delay(50);
        await IniciarCamera();
    }

    // Chamado pelo user master — valida email e avança para verificação
    private async Task AvancarParaVerificacaoEmail()
    {
        if (string.IsNullOrWhiteSpace(nomeUsuario)) { nomeErro = true; return; }
        nomeErro = false;

        if (!EmailValido(emailUsuario.Trim())) { emailErro = true; return; }
        emailErro = false;

        nomeUsuario = nomeUsuario.Trim();

        // Enviar código e avançar para a etapa de verificação
        await EnviarNovoCodigoAsync();
        etapa = Etapa.VerificacaoEmail;
        StateHasChanged();
    }

    private async Task EnviarNovoCodigoAsync()
    {
        try
        {
            codigoDigitos = new string[6];
            codigoErro = false;
            codigoExpirado = false;
            _codigoGerado = await EmailService.EnviarCodigoVerificacaoAsync(emailUsuario.Trim(), nomeUsuario.Trim());
            _codigoExpiracao = DateTime.UtcNow.AddMinutes(10);
        }
        catch (Exception ex)
        {
            erro = true;
            mensagemFeedback = $"Não foi possível enviar o email: {ex.Message}";
        }
    }

    private async Task VerificarCodigo()
    {
        string codigoIntroduzido = string.Concat(codigoDigitos);

        if (DateTime.UtcNow > _codigoExpiracao)
        {
            codigoExpirado = true;
            codigoErro = false;
            return;
        }

        if (codigoIntroduzido != _codigoGerado)
        {
            codigoErro = true;
            codigoDigitos = new string[6];
            StateHasChanged();
            return;
        }

        // Código correto — marcar email como confirmado e avançar para câmera
        codigoErro = false;
        verificandoCodigo = true;
        StateHasChanged();

        await Task.Delay(400); // feedback visual breve
        _ctsReenvio?.Cancel();
        etapa = Etapa.Camera;
        verificandoCodigo = false;
        StateHasChanged();
        await Task.Delay(50);
        await IniciarCamera();
    }

    private async Task OnDigitInput(ChangeEventArgs e, int index)
    {
        string? val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) { codigoDigitos[index] = ""; StateHasChanged(); return; }

        // Aceita paste de 6 dígitos de uma vez
        string digits = new string(val.Where(char.IsDigit).ToArray());
        if (digits.Length == 6)
        {
            for (int i = 0; i < 6; i++) codigoDigitos[i] = digits[i].ToString();
            StateHasChanged();
            // foca o último campo após paste completo
            await JS.InvokeVoidAsync("focusElement", "cod-5");
            return;
        }

        codigoDigitos[index] = digits.Length > 0 ? digits[^1].ToString() : "";
        codigoErro = false;
        StateHasChanged();

        // auto-avança para o campo seguinte ao preencher
        if (codigoDigitos[index].Length == 1 && index < 5)
            await JS.InvokeVoidAsync("focusElement", $"cod-{index + 1}");
    }

    private async Task OnDigitKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Backspace" && string.IsNullOrEmpty(codigoDigitos[index]) && index > 0)
        {
            codigoDigitos[index - 1] = "";
            StateHasChanged();
            // volta ao campo anterior
            await JS.InvokeVoidAsync("focusElement", $"cod-{index - 1}");
        }
    }

    private void VoltarParaNomeDeVerificacao()
    {
        _ctsReenvio?.Cancel();
        etapa = Etapa.Nome;
        codigoDigitos = new string[6];
        codigoErro = false;
        codigoExpirado = false;
        reenvioDesativado = false;
        consentimentoDado = false;
        StateHasChanged();
    }

    private async Task ReenviarCodigo()
    {
        _ctsReenvio?.Cancel();
        await EnviarNovoCodigoAsync();

        // Cooldown de 60 segundos para reenvio
        reenvioDesativado = true;
        segundosReenvio = 60;
        StateHasChanged();

        _ctsReenvio = new CancellationTokenSource();
        var token = _ctsReenvio.Token;
        _ = Task.Run(async () =>
        {
            while (segundosReenvio > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token).ContinueWith(_ => { });
                if (token.IsCancellationRequested) break;
                segundosReenvio--;
                await InvokeAsync(StateHasChanged);
            }
            if (!token.IsCancellationRequested)
            {
                reenvioDesativado = false;
                await InvokeAsync(StateHasChanged);
            }
        }, token);
    }

    private void VoltarParaNome()
    {
        PararCamera();
        etapa = Etapa.Nome;
        mensagemFeedback = "";
        erro = false;
        StateHasChanged();
    }

    private async Task IniciarCamera()
    {
        if (cameraAtiva) return;
        try
        {
            camera ??= new VideoCapture(0, VideoCapture.API.Any);
            if (!camera.IsOpened) throw new Exception("Câmera não disponível.");
            camera.Set(CapProp.FrameWidth, 1280);
            camera.Set(CapProp.FrameHeight, 720);
            cameraAtiva = true;
            cts = new CancellationTokenSource();
            _ = Task.Run(() => LoopDeCaptura(cts.Token));
        }
        catch (Exception ex)
        {
            erro = true;
            mensagemFeedback = $"Erro ao iniciar câmera: {ex.Message}";
            cameraAtiva = false;
            camera?.Dispose();
            camera = null;
        }
    }

    private void PararCamera()
    {
        cameraAtiva = false;
        cts?.Cancel();
        cts?.Dispose();
        cts = null;
        Thread.Sleep(200);

        lock (frameLock)
        {
            camera?.Dispose();
            camera = null;
            frame?.Dispose();
            frame = new Mat();
        }

        imageBase64 = "";
        estadoCaptura = EstadoCaptura.Aguardando;
        framesEstaveis = 0;
        capturaPendente = false;
        salvando = false;
        InvokeAsync(StateHasChanged);
    }

    private EstadoCaptura estadoCaptura = EstadoCaptura.Aguardando;       // estado visível na UI
    private EstadoCaptura _estadoCandidato = EstadoCaptura.Aguardando;    // estado "raw" do detector
    private int _framesCandidato = 0;                                      // quantos frames consecutivos no estado candidato
    private int framesEstaveis = 0;
    private bool capturaPendente = false;

    private async Task LoopDeCaptura(CancellationToken token)
    {
        while (!token.IsCancellationRequested && cameraAtiva)
        {
            try
            {
                Mat? captured = null;

                // Usa Mat local — evita corrupção de memória com Mat partilhado
                using (Mat localFrame = new Mat())
                {
                    bool leituraOk = false;

                    lock (frameLock)
                    {
                        if (camera != null && camera.IsOpened)
                        {
                            camera.Read(localFrame);
                            leituraOk = !localFrame.IsEmpty;

                            // Atualiza o frame de instância para SalvarRostoAutomatico
                            if (leituraOk)
                            {
                                frame?.Dispose();
                                frame = localFrame.Clone();
                            }
                        }
                    }

                    if (!leituraOk)
                    {
                        await Task.Delay(33, token);
                        continue;
                    }

                    captured = localFrame.Clone();
                }

                if (captured != null)
                {
                    using (captured)
                    using (Mat gray = new())
                    using (Mat grayNorm = new())
                    {
                        CvInvoke.CvtColor(captured, gray, ColorConversion.Bgr2Gray);

                        // CLAHE em vez de EqualizeHist — equalização adaptativa por zonas,
                        // consistente com o método usado no reconhecimento (Home.razor)
                        AplicarCLAHE(gray, grayNorm);
                        CvInvoke.GaussianBlur(grayNorm, grayNorm, new Size(3, 3), 0);

                        Rectangle[] faces = faceDetector?.DetectMultiScale(
                            grayNorm, 1.2, 6, new Size(120, 120)) ?? Array.Empty<Rectangle>();

                        var avaliacaoRaw = AvaliarRosto(faces, captured.Width, captured.Height);

                        // ── DEBOUNCE DE ESTADO ──────────────────────────────────────────
                        // O estado "raw" do detector oscila muito. Só promovemos para a UI
                        // quando o mesmo estado se mantém N frames consecutivos.
                        // Para subir (melhorar estado) exige menos frames do que para descer,
                        // o que torna a UI mais rápida a reagir positivamente mas mais lenta
                        // a "desistir" — elimina o efeito de piscar ao perder o rosto por 1-2 frames.

                        if (avaliacaoRaw == _estadoCandidato)
                        {
                            _framesCandidato++;
                        }
                        else
                        {
                            _estadoCandidato = avaliacaoRaw;
                            _framesCandidato = 1;
                        }

                        bool estadoMudou = false;
                        int limiar = avaliacaoRaw > estadoCaptura
                            ? FRAMES_DEBOUNCE_SUBIDA   // a melhorar → reage rápido
                            : FRAMES_DEBOUNCE_DESCIDA; // a piorar  → reage devagar (anti-piscar)

                        EstadoCaptura estadoFinal = estadoCaptura; // mantém o anterior por defeito

                        if (_framesCandidato >= limiar)
                        {
                            estadoFinal = avaliacaoRaw;
                            if (estadoFinal != estadoCaptura) estadoMudou = true;
                        }

                        // ── FRAMES ESTÁVEIS (para captura automática) ──────────────────
                        // Usa o estado raw para o contador interno, mas só quando o estado
                        // visual já está em Estabilizando ou melhor (evita incrementar em ruído)
                        if (estadoFinal >= EstadoCaptura.Estabilizando && avaliacaoRaw >= EstadoCaptura.Estabilizando)
                            framesEstaveis = Math.Min(framesEstaveis + 1, FRAMES_PARA_CAPTURAR);
                        else if (avaliacaoRaw < EstadoCaptura.Estabilizando)
                            framesEstaveis = Math.Max(framesEstaveis - 2, 0); // decresce devagar

                        if (framesEstaveis >= FRAMES_PARA_CAPTURAR)
                            estadoFinal = EstadoCaptura.Estavel;

                        if (estadoFinal != estadoCaptura) estadoMudou = true;

                        // Desenha retângulo apenas quando temos rosto estável (não em ruído)
                        if (faces.Length > 0 && estadoFinal >= EstadoCaptura.RostoDetectado)
                            CvInvoke.Rectangle(captured, faces[0], new MCvScalar(255, 255, 255), 2);

                        string base64 = MatToBase64(captured);

                        bool deveCapturar = estadoFinal == EstadoCaptura.Estavel
                                            && !salvando
                                            && !capturaPendente;

                        // ── THROTTLE DE RENDER ─────────────────────────────────────────
                        // Só chama StateHasChanged se o estado mudou OU passaram N frames.
                        // A imagem da câmera atualiza sempre, mas re-renders pesados são limitados.
                        _framesSemRender++;
                        bool deveRender = estadoMudou || _framesSemRender >= FRAMES_POR_RENDER;

                        await InvokeAsync(() =>
                        {
                            imageBase64 = base64;
                            estadoCaptura = estadoFinal;
                            if (deveRender)
                            {
                                _framesSemRender = 0;
                                StateHasChanged();
                            }
                        });

                        if (deveCapturar)
                        {
                            capturaPendente = true;
                            await InvokeAsync(() => SalvarRostoAutomatico());
                        }
                    }
                }

                await Task.Delay(33, token);
            }
            catch (TaskCanceledException) { break; }
            catch { }
        }
    }

    private EstadoCaptura AvaliarRosto(Rectangle[] faces, int largura, int altura)
    {
        if (faces.Length == 0) return EstadoCaptura.Aguardando;
        var face = faces[0];
        if ((double)face.Width / largura < TAMANHO_MIN_ROSTO)
            return EstadoCaptura.RostoDetectado;
        double cx = (face.X + face.Width / 2.0) / largura;
        double cy = (face.Y + face.Height / 2.0) / altura;
        if (Math.Abs(cx - 0.5) > MARGEM_CENTRO || Math.Abs(cy - 0.5) > MARGEM_CENTRO)
            return EstadoCaptura.RostoDetectado;
        return EstadoCaptura.Estabilizando;
    }

    private async Task SalvarRostoAutomatico()
    {
        if (salvando) return;
        estadoCaptura = EstadoCaptura.Capturando;
        salvando = true;
        mensagemFeedback = "";
        erro = false;
        StateHasChanged();

        Mat snapshot;
        lock (frameLock)
        {
            if (frame == null || frame.IsEmpty)
            {
                MostrarErro("Frame vazio no momento da captura. Tente novamente.");
                return;
            }
            snapshot = frame.Clone();
        }

        try
        {
            using (snapshot)
            using (Mat gray = new())
            using (Mat grayNorm = new())
            {
                CvInvoke.CvtColor(snapshot, gray, ColorConversion.Bgr2Gray);
                AplicarCLAHE(gray, grayNorm);
                CvInvoke.GaussianBlur(grayNorm, grayNorm, new Size(3, 3), 0);

                var faces = faceDetector?.DetectMultiScale(grayNorm, 1.1, 3, new Size(60, 60))
                            ?? Array.Empty<Rectangle>();

                if (faces.Length == 0)
                {
                    MostrarErro("Nenhum rosto encontrado na foto capturada. Reposicione e aguarde.");
                    return;
                }

                var area = faces[0];
                if (area.Width < 40 || area.Height < 40)
                {
                    MostrarErro("Rosto muito pequeno. Aproxime-se da câmera.");
                    return;
                }

                using Mat rostoBase = new(grayNorm, area);
                using Mat rostoResized = new();
                CvInvoke.Resize(rostoBase, rostoResized, new Size(200, 200));

                List<Mat> variacoes = GerarVariacoesDeRosto(rostoResized);
                string nomeParaSalvar = nomeUsuario.Trim();

                await Task.Run(() =>
                {
                    int uid = baseSql.ObterUsuarioIdPorNome(nomeParaSalvar);
                    if (uid == 0) uid = baseSql.CriarUsuario(nomeParaSalvar);

                    // Se é o user master, guardar email
                    if (primeiroUtilizador && !string.IsNullOrWhiteSpace(emailUsuario))
                        baseSql.AtualizarEmail(uid, emailUsuario.Trim(), true); // email já verificado
                    foreach (var img in variacoes)
                    {
                        using VectorOfByte vb = new();
                        CvInvoke.Imencode(".jpg", img, vb);
                        baseSql.InserirRosto(uid, vb.ToArray());
                        img.Dispose();
                    }
                });

                nomeRegistado = nomeParaSalvar;
                PararCamera();

                // Enviar email de confirmação ao user master
                if (primeiroUtilizador && !string.IsNullOrWhiteSpace(emailUsuario))
                {
                    try
                    {
                        await EmailService.EnviarConfirmacaoUserMasterAsync(emailUsuario.Trim(), nomeParaSalvar);
                        emailEnviado = true;
                    }
                    catch (Exception exEmail)
                    {
                        emailErroEnvio = $"Email de confirmação não enviado: {exEmail.Message}";
                    }
                }

                await InvokeAsync(async () =>
                {
                    etapa = Etapa.Concluido;
                    StateHasChanged();

                    // Contagem regressiva antes de redirecionar
                    for (int i = 3; i >= 1; i--)
                    {
                        contagemRegressiva = i;
                        StateHasChanged();
                        await Task.Delay(1000);
                    }

                    Navigation.NavigateTo(primeiroUtilizador ? "/" : "/admin", replace: true);
                });
            }
        }
        catch (Exception ex) { MostrarErro($"Erro ao processar biometria: {ex.Message}"); }
    }

    private void MostrarErro(string msg)
    {
        erro = true;
        mensagemFeedback = msg;
        salvando = false;
        capturaPendente = false;
        framesEstaveis = 0;
        estadoCaptura = EstadoCaptura.Aguardando;
        InvokeAsync(StateHasChanged);
    }

    private List<Mat> GerarVariacoesDeRosto(Mat img)
    {
        // img já chegou como 200x200 grayscale normalizado
        var lista = new List<Mat>();
        var imgSize = new Size(200, 200);
        var center = new PointF(100f, 100f);

        // Normaliza e adiciona à lista — CLAHE garante consistência com o reconhecimento
        void Adicionar(Mat src)
        {
            using Mat resized = new();
            if (src.Width != 200 || src.Height != 200)
                CvInvoke.Resize(src, resized, imgSize);
            else
                src.CopyTo(resized);

            Mat eq = new Mat(imgSize, src.Depth, 1);
            AplicarCLAHE(resized, eq);
            lista.Add(eq); // transfere ownership — não usar using aqui
        }

        // Cria matriz de transformação 2D (rotação + escala)
        Mat CriarMatriz(double angulo, double escala)
        {
            Mat m = new Mat();
            CvInvoke.GetRotationMatrix2D(center, angulo, escala, m);
            return m;
        }

        // Aplica WarpAffine sempre para imgSize e chama Adicionar
        void AdicionarWarp(Mat src, Mat matrix)
        {
            using Mat warped = new Mat(imgSize, src.Depth, 1);
            CvInvoke.WarpAffine(src, warped, matrix, imgSize,
                Inter.Linear, Warp.Default, BorderType.Replicate);
            Adicionar(warped);
        }

        // ── 1. ORIGINAL ───────────────────────────────────────────────────────
        Adicionar(img);

        // ── 2. ESPELHO HORIZONTAL ─────────────────────────────────────────────
        using Mat flipBase = new Mat(imgSize, img.Depth, 1);
        CvInvoke.Flip(img, flipBase, FlipType.Horizontal);
        Adicionar(flipBase);

        // ── 3–10. ROTAÇÕES IN-PLANE ───────────────────────────────────────────
        foreach (int ang in new[] { -25, -15, -8, -4, 4, 8, 15, 25 })
        {
            using Mat m = CriarMatriz(ang, 1.0);
            AdicionarWarp(img, m);
        }

        // ── 11–16. BRILHO E CONTRASTE ─────────────────────────────────────────
        foreach ((double alpha, int beta) in new (double, int)[]
        {
            (0.60,   0),
            (0.80,   0),
            (1.20,   0),
            (1.45,   0),
            (1.00, -30),
            (1.00,  30),
        })
        {
            using Mat bright = new Mat(imgSize, img.Depth, 1);
            img.ConvertTo(bright, DepthType.Cv8U, alpha, beta);
            Adicionar(bright);
        }

        // ── 17–20. ESCALA (distância à câmera) ────────────────────────────────
        // WarpAffine com escala != 1 não muda o tamanho do dst — imgSize mantém-se 200x200
        foreach (double scale in new[] { 0.80, 0.90, 1.10, 1.20 })
        {
            using Mat m = CriarMatriz(0, scale);
            AdicionarWarp(img, m);
        }

        // ── 21–22. BLUR ───────────────────────────────────────────────────────
        foreach (int k in new[] { 3, 5 })
        {
            using Mat blurred = new Mat(imgSize, img.Depth, 1);
            CvInvoke.GaussianBlur(img, blurred, new Size(k, k), 0);
            Adicionar(blurred);
        }

        // ── 23. NITIDEZ (sharpen) ─────────────────────────────────────────────
        using (Mat sharp = new Mat(imgSize, img.Depth, 1))
        {
            float[] kData = { 0, -1, 0, -1, 5, -1, 0, -1, 0 };
            using Mat kernelMat = new Mat(3, 3, DepthType.Cv32F, 1);
            System.Runtime.InteropServices.Marshal.Copy(kData, 0, kernelMat.DataPointer, 9);
            CvInvoke.Filter2D(img, sharp, kernelMat, new Point(-1, -1));
            CvInvoke.Threshold(sharp, sharp, 255, 255, ThresholdType.Trunc);
            CvInvoke.Threshold(sharp, sharp, 0, 0, ThresholdType.ToZero);
            Adicionar(sharp);
        }

        // ── 24. RUÍDO GAUSSIANO ───────────────────────────────────────────────
        using (Mat noisy = img.Clone())
        using (Mat noiseLayer = new Mat(imgSize, img.Depth, 1))
        {
            CvInvoke.Randn(noiseLayer, new MCvScalar(0), new MCvScalar(18));
            CvInvoke.Add(noisy, noiseLayer, noisy);
            Adicionar(noisy);
        }

        // ── 25–28. COMBINAÇÃO: rotação + brilho ───────────────────────────────
        foreach ((int ang, double alpha) in new (int, double)[]
        {
            (-12, 0.75), ( 12, 0.75),
            (-12, 1.30), ( 12, 1.30),
        })
        {
            using Mat m = CriarMatriz(ang, 1.0);
            using Mat rotMat = new Mat(imgSize, img.Depth, 1);
            CvInvoke.WarpAffine(img, rotMat, m, imgSize,
                Inter.Linear, Warp.Default, BorderType.Replicate);
            using Mat bright = new Mat(imgSize, img.Depth, 1);
            rotMat.ConvertTo(bright, DepthType.Cv8U, alpha, 0);
            Adicionar(bright);
        }

        // ── 29–30. COMBINAÇÃO: espelho + rotação ──────────────────────────────
        foreach (int ang in new[] { -10, 10 })
        {
            using Mat m = CriarMatriz(ang, 1.0);
            AdicionarWarp(flipBase, m);
        }

        // ── 31–32. BLUR FORTE + FLIP ──────────────────────────────────────────
        using (Mat softBlur = new Mat(imgSize, img.Depth, 1))
        {
            CvInvoke.GaussianBlur(img, softBlur, new Size(5, 5), 0);
            Adicionar(softBlur);

            using Mat softFlip = new Mat(imgSize, img.Depth, 1);
            CvInvoke.Flip(softBlur, softFlip, FlipType.Horizontal);
            Adicionar(softFlip);
        }

        return lista;
        // Total: ~32 variações por captura
    }

    // Equalização — usa EqualizeHist (CLAHE não disponível nesta versão do Emgu CV)
    private static void AplicarCLAHE(Mat src, Mat dst)
    {
        CvInvoke.EqualizeHist(src, dst);
    }

    private string MatToBase64(Mat mat)
    {
        if (mat.IsEmpty) return "";
        using VectorOfByte vb = new();
        CvInvoke.Imencode(".jpg", mat, vb);
        return "data:image/jpeg;base64," + Convert.ToBase64String(vb.ToArray());
    }

    private string EstiloViewport() => estadoCaptura switch
    {
        EstadoCaptura.Estavel or EstadoCaptura.Capturando => "viewport--ready",
        EstadoCaptura.Estabilizando => "viewport--stabilizing",
        EstadoCaptura.RostoDetectado => "viewport--detected",
        _ => ""
    };
    private string EstiloGuia() => estadoCaptura switch
    {
        EstadoCaptura.Estavel or EstadoCaptura.Capturando => "guide--ready",
        EstadoCaptura.Estabilizando => "guide--stabilizing",
        EstadoCaptura.RostoDetectado => "guide--detected",
        _ => "guide--idle"
    };
    private string EstiloInstrucao() => estadoCaptura switch
    {
        EstadoCaptura.Estavel or EstadoCaptura.Capturando => "instr--green",
        EstadoCaptura.Estabilizando => "instr--blue",
        EstadoCaptura.RostoDetectado => "instr--amber",
        _ => "instr--neutral"
    };
    private string EstiloStatusProcesso() => estadoCaptura switch
    {
        EstadoCaptura.Estavel or EstadoCaptura.Capturando => "status-green",
        EstadoCaptura.Estabilizando => "status-blue",
        _ => "status-neutral"
    };
    private string MensagemInstrucao() => estadoCaptura switch
    {
        EstadoCaptura.Capturando => "A capturar...",
        EstadoCaptura.Estavel => "A capturar em breve...",
        EstadoCaptura.Estabilizando => "Fique imóvel...",
        EstadoCaptura.RostoDetectado => "Centre o rosto na guia",
        _ => "Posicione o rosto na guia oval"
    };
    private string MensagemStatusProcesso()
    {
        if (salvando) return "A processar e guardar biometria...";
        return estadoCaptura switch
        {
            EstadoCaptura.Capturando => "A capturar automaticamente...",
            EstadoCaptura.Estavel => "Pronto para capturar!",
            EstadoCaptura.Estabilizando => $"A estabilizar... ({framesEstaveis}/{FRAMES_PARA_CAPTURAR} frames)",
            EstadoCaptura.RostoDetectado => "Centre o rosto na guia oval",
            _ => "Aguardando rosto na câmera..."
        };
    }

    public void Dispose()
    {
        _ctsReenvio?.Cancel();
        _ctsReenvio?.Dispose();
        PararCamera();
        faceDetector?.Dispose();
    }
}

