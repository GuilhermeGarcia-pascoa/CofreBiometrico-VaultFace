        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: box-shadow 0.3s;
    }

    .viewport--detected {
        box-shadow: inset 0 0 0 2px rgba(217,119,6,0.5);
    }

    .viewport--stabilizing {
        box-shadow: inset 0 0 0 2px rgba(26,86,219,0.5);
    }

    .viewport--ready {
        box-shadow: inset 0 0 0 3px rgba(22,163,74,0.6);
    }

    .feed {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .face-guide {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 38%;
        pointer-events: none;
        transition: color 0.3s, filter 0.3s;
    }

    .guide-svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .guide--idle {
        color: rgba(255,255,255,0.25);
    }

    .guide--detected {
        color: rgba(217,119,6,0.8);
    }

    .guide--stabilizing {
        color: rgba(96,165,250,0.9);
        animation: pulse-oval 1s ease-in-out infinite;
    }

    .guide--ready {
        color: rgba(34,197,94,0.95);
        filter: drop-shadow(0 0 6px rgba(34,197,94,0.5));
    }

    @@keyframes pulse-oval {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }
    }

    .progress-bar-wrap {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: rgba(255,255,255,0.1);
    }

    .progress-bar {
        height: 100%;
        background: var(--accent);
        transition: width 0.1s linear;
    }

    .instruction-pill {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        backdrop-filter: blur(6px);
        white-space: nowrap;
        transition: all 0.25s;
    }

    .instr--neutral {
        background: rgba(0,0,0,0.45);
        color: rgba(255,255,255,0.8);
        border: 1px solid rgba(255,255,255,0.1);
