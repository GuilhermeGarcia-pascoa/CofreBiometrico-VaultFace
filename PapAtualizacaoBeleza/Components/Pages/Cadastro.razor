    .instr--amber {
        background: rgba(217,119,6,0.2);
        color: #fbbf24;
        border: 1px solid rgba(217,119,6,0.4);
    }

    .instr--blue {
        background: rgba(26,86,219,0.2);
        color: #93c5fd;
        border: 1px solid rgba(26,86,219,0.4);
    }

    .instr--green {
        background: rgba(22,163,74,0.2);
        color: #4ade80;
        border: 1px solid rgba(22,163,74,0.4);
