        align-items: center;
        transition: all 0.15s;
    }

        .btn-tema:hover {
            background: var(--surface2);
            color: var(--text);
        }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
    }

    .page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--bg);
    }

    /* ── TOPBAR ── */
    .topbar {
        display: flex;
        align-items: center;
