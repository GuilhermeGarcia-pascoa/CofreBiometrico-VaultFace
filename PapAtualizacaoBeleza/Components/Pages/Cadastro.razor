        --bg2: #0e1016;
        --surface: #131620;
        --surface2: #1b1f2e;
        --border: #252836;
        --border2: #1e2130;
        --text: #e6e8f0;
        --muted: #7b82a0;
        --dim: #454c66;
        --accent: #4f74f9;
        --accent-glow: rgba(79,116,249,0.18);
        --green: #22c55e;
        --green-bg: #071a0f;
        --green-br: #14532d;
        --red: #f87171;
        --red-bg: #1a0808;
        --red-br: #7f1d1d;
        --amber: #fbbf24;
        --amber-bg: #1a1000;
        --amber-br: #78350f;
        --blue-bg: #080f2a;
        --blue-br: #1e3a8a;
