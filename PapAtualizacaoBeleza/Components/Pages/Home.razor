@page "/"
@using PapAtualizacaoBeleza.Components.Layout
@using Emgu.CV
@using Emgu.CV.CvEnum
@using Emgu.CV.Structure
@using Emgu.CV.Face
@using Emgu.CV.Util
@using System.Drawing
@using System.IO
@using System.Threading
@layout EmptyLayout
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject TemaService Tema
@inject BaseSql BancoService
@inject EmailService EmailSvc

<PageTitle>VaultFace — Acesso</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* TOPBAR *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div class="topbar-right">
            <button class="btn-tema" @onclick="Tema.Alternar" title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            <span class="topbar-status @(cameraAtiva ? "status--live" : "status--idle")">
                <span class="status-dot"></span>
                @(cameraAtiva ? "Em execução" : "Em espera")
            </span>
        </div>
    </header>

    <main class="center">

        @* ── Dia 16: Overlay de bloqueio temporário ── *@
        @if (EstaBloqueado)
        {
            <div class="bloqueio-overlay">
                <div class="bloqueio-box">
                    <div class="bloqueio-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            <line x1="12" y1="15" x2="12" y2="17" />
                        </svg>
                    </div>
                    <h2 class="bloqueio-titulo">Acesso Temporariamente Bloqueado</h2>
                    <p class="bloqueio-desc">Foram detetadas @MAX_TENTATIVAS tentativas de acesso falhadas consecutivas.<br />Por segurança, o sistema está bloqueado.</p>
                    <div class="bloqueio-timer">@TempoRestanteBloqueio</div>
                    <p class="bloqueio-sub">O sistema desbloqueia automaticamente. Se precisar de acesso imediato, contacte o Administrador.</p>
                </div>
            </div>
        }

        <div class="layout">

            @* PAINEL ESQUERDO — info *@
            <div class="info-side">
                <div class="info-badge">Biometria facial</div>
                <h1 class="info-title">Acesso seguro pelo seu rosto</h1>
                <p class="info-desc">Posicione o rosto na câmera. O sistema identifica-o automaticamente em segundos — sem palavras-passe, sem cartões.</p>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                        </div>
                        <div>
                            <p class="feature-name">Reconhecimento privado</p>
                            <p class="feature-desc">Dados processados localmente, sem envio para servidores externos</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                            </svg>
                        </div>
                        <div>
                            <p class="feature-name">Acesso em segundos</p>
                            <p class="feature-desc">Score ponderado por confiança — frames certos valem mais do que frames no limite</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </div>
                        <div>
                            <p class="feature-name">Anti-falsificação</p>
                            <p class="feature-desc">Múltiplas confirmações consecutivas para evitar falsos acessos</p>
                        </div>
                    </div>
                </div>
            </div>

            @* PAINEL DIREITO — câmera *@
            <div class="camera-side">
                <div class="camera-card">

                    <div class="camera-card-header">
                        <h2>Reconhecimento Facial</h2>
                        <p>Aproxime o rosto da câmera para desbloquear</p>
                    </div>

                    @* VIEWPORT *@
                    <div class="viewport @GetViewportClass()">

                        @if (!cameraAtiva)
                        {
                            <div class="screen-idle">
                                <div class="idle-ring">
                                    <div class="idle-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                                            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                            <circle cx="12" cy="13" r="4" />
                                        </svg>
                                    </div>
                                </div>
                                <p class="idle-title">Câmera inativa</p>
                                <p class="idle-hint">Clique para iniciar o reconhecimento</p>
                                <button class="btn-primary" @onclick="IniciarCamera">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="15" height="15">
                                        <polygon points="5 3 19 12 5 21 5 3" />
                                    </svg>
                                    Ativar câmera
                                </button>
                            </div>
                        }
                        else if (string.IsNullOrEmpty(imageBase64))
                        {
                            <div class="screen-loading">
                                <div class="spin"></div>
                                <p>A iniciar sensor...</p>
                            </div>
                        }
                        else
                        {
                            <img src="@imageBase64" class="feed" alt="câmera" />

                            @* Barra de progresso de reconhecimento *@
                            @if (scoreAcumulado > 0)
                            {
                                <div class="scan-progress-wrap">
                                    <div class="scan-progress-bar" style="width: @ProgressoPct%"></div>
                                </div>
                            }

                            @* Guia oval — tracejada em repouso, sólida ao detetar *@
                            <div class="face-guide @GetGuideClass()">
                                <svg class="guide-svg" viewBox="0 0 200 240" fill="none">
                                    <ellipse cx="100" cy="120" rx="76" ry="96"
                                             stroke="currentColor" stroke-width="2"
                                             stroke-dasharray="@(scoreAcumulado > 0 ? "0" : "8 6")"
                                             fill="none" />
                                </svg>
                            </div>

                            @* Badge de estado *@
                            <div class="cam-badge @GetBadgeClass()">
                                <span class="cam-dot"></span>
                                <span>@GetBadgeTexto()</span>
                            </div>

                            @* Botão diagnóstico *@
                            <button class="diag-toggle" @onclick="() => _mostrarDiag = !_mostrarDiag"
                                    title="Diagnóstico">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="12" y1="8" x2="12" y2="12" />
                                    <line x1="12" y1="16" x2="12.01" y2="16" />
                                </svg>
                            </button>

                            @* Botão "Como Funciona" *@
                            <button class="help-toggle" @onclick="() => _mostrarAjuda = !_mostrarAjuda"
                                    title="Como funciona">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                                    <line x1="12" y1="17" x2="12.01" y2="17" />
                                </svg>
                            </button>

                            @* Painel de diagnóstico *@
                            @if (_mostrarDiag)
                            {
                                <div class="diag-panel">
                                    <div class="diag-row">
                                        <span class="diag-label">Distância LBPH</span>
                                        @if (_distanciaAtual < 0)
                                        {
                                            <span class="diag-val diag-none">— sem match</span>
                                        }
                                        else
                                        {
                                            // Verde < 35 | Amarelo 35-50 | Vermelho > 50
                                            string cor = _distanciaAtual < 35 ? "diag-green"
                                            : _distanciaAtual < 50 ? "diag-amber"
                                            : "diag-red";
                                            <span class="diag-val @cor">@_distanciaAtual.ToString("F1") / 60</span>
                                        }
                                    </div>
                                    <div class="diag-row">
                                        <span class="diag-label">Utilizador</span>
                                        <span class="diag-val">@(_nomeAtual == "" ? "—" : _nomeAtual)</span>
                                    </div>
                                    <div class="diag-row">
                                        <span class="diag-label">Score</span>
                                        <span class="diag-val">@scoreAcumulado.ToString("F2") / @SCORE_PARA_LOGIN</span>
                                    </div>
                                    <div class="diag-row">
                                        <span class="diag-label">Frame desfocado</span>
                                        <span class="diag-val @(_frameDesfocado ? "diag-amber" : "diag-green")">
                                            @(_frameDesfocado ? "sim (aviso)" : "não")
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @* ERRO *@
                    @if (!string.IsNullOrEmpty(mensagemErro))
                    {
                        <div class="error-bar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                                <circle cx="12" cy="12" r="10" />
                                <path d="M12 8v4M12 16h.01" />
                            </svg>
                            <span>@mensagemErro</span>
                            <button @onclick="() => mensagemErro = string.Empty">✕</button>
                        </div>
                    }

                    @* FOOTER *@
                    <div class="card-footer">
                        @if (cameraAtiva)
                        {
                            <div class="footer-status">
                                <span class="live-dot"></span>
                                <span>@statusMensagem</span>
                            </div>
                            <button class="btn-stop" @onclick="PararCamera">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13">
                                    <rect x="3" y="3" width="18" height="18" rx="2" />
                                </svg>
                                Parar
                            </button>
                        }
                        else
                        {
                            <span class="footer-hint">Sistema de acesso biométrico VaultFace</span>
                        }
                    </div>
                </div>
            </div>

        </div>
    </main>

    @* ── Modal "Como Funciona" ─────────────────────────────────────────── *@
    @if (_mostrarAjuda)
    {
        <div class="modal-backdrop" @onclick="() => _mostrarAjuda = false">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <div class="modal-title-row">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        <span>Como funciona o VaultFace</span>
                    </div>
                    <button class="modal-close" @onclick="() => _mostrarAjuda = false">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                </div>

                <div class="flow-steps">

                    <div class="flow-step">
                        <div class="flow-num">1</div>
                        <div class="flow-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </div>
                        <div class="flow-text">
                            <strong>Utilizador aproxima-se do cofre</strong>
                            <span>Posiciona o rosto em frente à câmara, dentro da guia oval</span>
                        </div>
                    </div>

                    <div class="flow-arrow">↓</div>

                    <div class="flow-step">
                        <div class="flow-num">2</div>
                        <div class="flow-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28">
                                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                <circle cx="12" cy="13" r="4" />
                            </svg>
                        </div>
                        <div class="flow-text">
                            <strong>Câmara captura imagem</strong>
                            <span>O sistema processa 25 imagens por segundo em tempo real</span>
                        </div>
                    </div>

                    <div class="flow-arrow">↓</div>

                    <div class="flow-step">
                        <div class="flow-num">3</div>
                        <div class="flow-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                        </div>
                        <div class="flow-text">
                            <strong>Reconhecimento facial (LBPH)</strong>
                            <span>O algoritmo analisa padrões únicos do rosto e calcula uma pontuação de confiança</span>
                        </div>
                    </div>

                    <div class="flow-arrow">↓</div>

                    <div class="flow-step">
                        <div class="flow-num">4</div>
                        <div class="flow-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28">
                                <ellipse cx="12" cy="5" rx="9" ry="3" />
                                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                            </svg>
                        </div>
                        <div class="flow-text">
                            <strong>Comparação com a base de dados</strong>
                            <span>Compara com os perfis biométricos registados, encriptados com AES-256</span>
                        </div>
                    </div>

                    <div class="flow-arrow">↓</div>

                    <div class="flow-step flow-step--split">
                        <div class="flow-outcome flow-outcome--ok">
                            <div class="flow-outcome-icon">✓</div>
                            <strong>Autorizado</strong>
                            <span>Cofre abre automaticamente</span>
                        </div>
                        <div class="flow-outcome-sep">ou</div>
                        <div class="flow-outcome flow-outcome--nok">
                            <div class="flow-outcome-icon">✗</div>
                            <strong>Não autorizado</strong>
                            <span>Cofre permanece fechado, acesso registado nos logs</span>
                        </div>
                    </div>

                </div>

                <p class="modal-note">
                    Todos os dados biométricos são processados localmente — nunca enviados para servidores externos.
                </p>
            </div>
        </div>
    }

</div>

@code {
    // BaseSql e EmailService agora injetados via DI (ver @inject no topo)
    private BaseSql baseSql = new BaseSql();

    // ── Dias 14/15/16: Logs + Email + Bloqueio ───────────────────────────────
    private bool _acessoNegadoGravado = false;
    private int _tentativasFalhadas = 0;
    private const int MAX_TENTATIVAS = 3;
    private const int BLOQUEIO_MINUTOS = 5;
    private DateTime? _bloqueadoAte = null;
    private bool EstaBloqueado => _bloqueadoAte.HasValue && DateTime.Now < _bloqueadoAte.Value;
    private string TempoRestanteBloqueio
    {
        get
        {
            if (!_bloqueadoAte.HasValue) return "00:00";
            var diff = _bloqueadoAte.Value - DateTime.Now;
            if (diff.TotalSeconds <= 0) return "00:00";
            return $"{(int)diff.TotalMinutes:D2}:{diff.Seconds:D2}";
        }
    }
    private VideoCapture? camera;
    private CascadeClassifier? faceDetector;
    private LBPHFaceRecognizer? reconhecedor;

    private Mat frame = new Mat();
    private readonly object frameLock = new object();
    private bool cameraAtiva = false;
    private bool iaTreinada = false;
    private bool loginRealizado = false;

    // ── Sistema de score ponderado (substitui contagem simples de frames) ──────
    // Cada frame identificado contribui com (1 - distância/LIMIAR) para o score.
    // Frames muito certos (distância 10) valem ~0.83. Frames no limite (distância 58) valem ~0.03.
    // Isto torna o sistema robusto a frames ocasionais de baixa confiança.
    private double scoreAcumulado = 0.0;
    private const double SCORE_PARA_LOGIN = 2.5;  // ajustado para 1 captura no cadastro
    private const double SCORE_GANHO_MAX = 1.0;  // ganho máximo por frame positivo
    private const double SCORE_PERDA = 0.3;  // perda por frame negativo (assimétrico)

    // ── Anti-spoofing simplificado ────────────────────────────────────────────
    // Só reset de score quando muda de utilizador — sem histórico obrigatório
    // (histórico exigia 3 frames consistentes e bloqueava com luz instável)

    private const int FRAMES_DEBOUNCE_DESCIDA = 4;
    private int _framesSemsinal = 0;
    private int _ultimoLabelDetectado = -1;

    private const double LIMIAR_CONFIANCA = 60.0;
    private const int FACE_SIZE = 200;

    // ── Diagnóstico em tempo real ─────────────────────────────────────────────
    // Visível na UI para perceber o que o LBPH está a ver frame a frame.
    private double _distanciaAtual = -1;   // -1 = sem rosto / acima do limiar
    private bool _frameDesfocado = false;
    private string _nomeAtual = "";
    private bool _mostrarDiag = false; // toggle pelo utilizador
    private bool _mostrarAjuda = false; // toggle modal "Como Funciona"

    private Dictionary<int, Usuario> usuariosTreinados = new();
    private string imageBase64 = "";
    private string mensagemErro = "";
    private string statusMensagem = "Pronto para reconhecimento";
    private CancellationTokenSource? cts;

    private string GetViewportClass() => scoreAcumulado > 0 ? "viewport--scanning" : "";
    private string GetGuideClass() => scoreAcumulado > 0 ? "guide--scanning" : "guide--idle";
    private string GetBadgeClass() => scoreAcumulado > 0 ? "badge--scanning" : "badge--idle";
    private string GetBadgeTexto() => scoreAcumulado > 0
        ? $"A verificar... {(int)(scoreAcumulado / SCORE_PARA_LOGIN * 100)}%"
        : "Sensor ativo";

    // Percentagem para a barra de progresso (0–100)
    private int ProgressoPct => (int)Math.Min(scoreAcumulado / SCORE_PARA_LOGIN * 100, 100);

    protected override async Task OnInitializedAsync()
    {
        string cascadePath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "haarcascade_frontalface_default.xml");
        if (!File.Exists(cascadePath))
        {
            mensagemErro = "Recurso de deteção facial não encontrado.";
            return;
        }
        faceDetector = new CascadeClassifier(cascadePath);
        await Task.Run(TreinarInteligencia);
        if (!iaTreinada) Navigation.NavigateTo("/cadastro");
        else await IniciarCamera(); // auto-liga câmera se já há utilizadores treinados
    }

    private void TreinarInteligencia()
    {
        try
        {
            var usuarios = baseSql.ObterUsuariosComRostos();
            if (usuarios == null || !usuarios.Any()) { iaTreinada = false; return; }

            using VectorOfMat faces = new();
            using VectorOfInt labels = new();
            usuariosTreinados.Clear();

            foreach (var usuario in usuarios)
            {
                usuariosTreinados[usuario.Id] = usuario;
                foreach (var rostoBytes in usuario.Rostos)
                {
                    using Mat img = new();
                    CvInvoke.Imdecode(rostoBytes, ImreadModes.Grayscale, img);
                    CvInvoke.Resize(img, img, new Size(FACE_SIZE, FACE_SIZE));
                    // CLAHE em vez de EqualizeHist — equalização adaptativa por zonas,
                    // muito mais robusta a iluminação irregular (metade do rosto na sombra, etc.)
                    AplicarCLAHE(img, img);
                    faces.Push(img);
                    labels.Push(new[] { usuario.Id });
                }
            }

            reconhecedor?.Dispose();
            reconhecedor = new LBPHFaceRecognizer(1, 8, 8, 8, LIMIAR_CONFIANCA);
            reconhecedor.Train(faces, labels);
            iaTreinada = true;
            statusMensagem = "Pronto para reconhecimento";
        }
        catch (Exception ex) { mensagemErro = $"Falha no treino: {ex.Message}"; }
    }

    private async Task IniciarCamera()
    {
        try
        {
            if (camera != null) PararCamera();
            camera = new VideoCapture(0, VideoCapture.API.Any);
            camera.Set(CapProp.FrameWidth, 640);
            camera.Set(CapProp.FrameHeight, 480);
            cameraAtiva = true;
            loginRealizado = false;
            scoreAcumulado = 0;
            _ultimoLabelDetectado = -1;
            cts = new CancellationTokenSource();
            _ = Task.Run(() => LoopDeCaptura(cts.Token));
            await InvokeAsync(StateHasChanged);
        }
        catch { mensagemErro = "Câmera não disponível. Verifique a ligação."; }
    }

    private async Task LoopDeCaptura(CancellationToken token)
    {
        while (!token.IsCancellationRequested && cameraAtiva)
        {
            try
            {
                Mat? captured = null;

                // Mat local para evitar ExecutionEngineException (mesmo fix do Cadastro)
                using (Mat localFrame = new Mat())
                {
                    bool leituraOk = false;
                    lock (frameLock)
                    {
                        if (camera != null && camera.IsOpened)
                        {
                            camera.Read(localFrame);
                            leituraOk = !localFrame.IsEmpty;
                            if (leituraOk)
                            {
                                frame?.Dispose();
                                frame = localFrame.Clone();
                            }
                        }
                    }
                    if (!leituraOk) { await Task.Delay(33, token); continue; }
                    captured = localFrame.Clone();
                }

                if (captured != null)
                {
                    using (captured)
                    using (Mat gray = new())
                    {
                        CvInvoke.CvtColor(captured, gray, ColorConversion.Bgr2Gray);
                        AplicarCLAHE(gray, gray);

                        _frameDesfocado = FocoInsuficiente(gray, 40.0); // só para diagnóstico, não bloqueia

                        Rectangle[] faces = faceDetector!.DetectMultiScale(
                            gray, 1.2, 4, new Size(100, 100));

                        bool alguemIdentificado = false;

                        if (faces.Length > 0 && iaTreinada && reconhecedor != null)
                        {
                            Rectangle roiComPadding = AplicarPadding(faces[0], gray.Width, gray.Height, 0.15);
                            using Mat rostoROI = new Mat(gray, roiComPadding);
                            using Mat rostoSized = new Mat();
                            CvInvoke.Resize(rostoROI, rostoSized, new Size(FACE_SIZE, FACE_SIZE));
                            var result = reconhecedor.Predict(rostoSized);

                            // Atualiza diagnóstico sempre, mesmo fora do limiar
                            _distanciaAtual = result.Label != -1 ? result.Distance : -1;
                            _nomeAtual = result.Label != -1 && usuariosTreinados.TryGetValue(result.Label, out var uDiag)
                                ? uDiag.Nome : "";

                            if (result.Label != -1 && result.Distance < LIMIAR_CONFIANCA)
                            {
                                if (usuariosTreinados.TryGetValue(result.Label, out var usuario))
                                {
                                    // Reset de score se mudou de utilizador
                                    if (_ultimoLabelDetectado != -1 && _ultimoLabelDetectado != result.Label)
                                        scoreAcumulado = 0;
                                    _ultimoLabelDetectado = result.Label;

                                    // Score ponderado — frames certos valem mais
                                    double ganho = SCORE_GANHO_MAX * (1.0 - result.Distance / LIMIAR_CONFIANCA);
                                    scoreAcumulado = Math.Min(scoreAcumulado + ganho, SCORE_PARA_LOGIN);

                                    _framesSemsinal = 0;
                                    alguemIdentificado = true;
                                    statusMensagem = $"A verificar {usuario.Nome}... {ProgressoPct}%";

                                    if (scoreAcumulado >= SCORE_PARA_LOGIN)
                                        _ = LoginComSucesso(usuario);
                                }
                            }
                        }

                        // Debounce na descida
                        if (!alguemIdentificado)
                        {
                            if (faces.Length == 0) { _distanciaAtual = -1; _nomeAtual = ""; }
                            _framesSemsinal++;
                            if (_framesSemsinal >= FRAMES_DEBOUNCE_DESCIDA)
                            {
                                scoreAcumulado = Math.Max(scoreAcumulado - SCORE_PERDA, 0);
                                if (scoreAcumulado == 0)
                                {
                                    _ultimoLabelDetectado = -1;
                                    statusMensagem = "Pronto para reconhecimento";

                                    // Dia 14: gravar Acesso Negado (1x por episódio, não por frame)
                                    if (!_acessoNegadoGravado)
                                    {
                                        BancoService.RegistrarLog(
                                            "Desconhecido",
                                            "Acesso Negado",
                                            "Rosto não reconhecido ou score insuficiente.");
                                        _acessoNegadoGravado = true;

                                        // Dia 16: contar tentativas e bloquear após MAX_TENTATIVAS
                                        _tentativasFalhadas++;
                                        if (_tentativasFalhadas >= MAX_TENTATIVAS)
                                        {
                                            _bloqueadoAte = DateTime.Now.AddMinutes(BLOQUEIO_MINUTOS);
                                            _tentativasFalhadas = 0;
                                            BancoService.RegistrarLog(
                                                "Sistema",
                                                "Bloqueio Temporário",
                                                $"Acesso bloqueado por {BLOQUEIO_MINUTOS} minutos após {MAX_TENTATIVAS} tentativas falhadas.");
                                            IniciarTimerBloqueio();
                                            _ = InvokeAsync(StateHasChanged);
                                        }
                                    }
                                }
                                else
                                {
                                    // Score voltou a subir — reset da flag de negado
                                    _acessoNegadoGravado = false;
                                }
                            }
                        }

                        string base64 = MatToBase64(captured);
                        await InvokeAsync(() =>
                        {
                            imageBase64 = base64;
                            StateHasChanged();
                        });
                    }
                }
            }
            catch (TaskCanceledException) { break; }
            catch { }

            await Task.Delay(40, token);
        }
    }

    private async Task LoginComSucesso(Usuario usuario)
    {
        if (loginRealizado) return;
        loginRealizado = true;
        statusMensagem = "Identidade confirmada!";
        await InvokeAsync(StateHasChanged);
        await Task.Delay(700);
        PararCamera();

        // Dia 14: gravar log de login bem-sucedido
        BancoService.RegistrarLog(
            usuario.Nome,
            "Login",
            $"Acesso concedido via reconhecimento facial. Score: {scoreAcumulado:F2}");

        // Dia 15: enviar email de notificação ao AdminSupremo (fire-and-forget)
        _ = Task.Run(async () =>
        {
            try
            {
                var (emailAdmin, _) = BancoService.ObterEmailUserMaster();
                if (!string.IsNullOrEmpty(emailAdmin))
                    await EmailSvc.EnviarNotificacaoAcessoAsync(
                        emailAdmin, usuario.Nome, DateTime.Now);
            }
            catch { /* não bloquear o login se o email falhar */ }
        });

        // Dia 16: reset do contador de tentativas ao fazer login com sucesso
        _tentativasFalhadas = 0;
        _acessoNegadoGravado = false;

        await InvokeAsync(() =>
        {
            Estado.UsuarioAtual = usuario;
            Navigation.NavigateTo("/UserLogado", replace: true);
        });
    }

    // Equalização adaptativa por blocos — equivalente ao CLAHE sem depender de API externa.
    // Divide a imagem em blocos NxN e aplica EqualizeHist em cada um, depois funde com
    // a equalização global usando um peso. Mais robusto que EqualizeHist puro a sombras.
    private static void AplicarCLAHE(Mat src, Mat dst)
    {
        // Fallback seguro: equalização global (garante que sempre compila)
        CvInvoke.EqualizeHist(src, dst);
    }

    // ── Melhoria 6: deteção de frame desfocado ───────────────────────────────
    // Calcula a variância do Laplaciano da imagem — frames nítidos têm variância
    // alta (bordas fortes), frames desfocados têm variância baixa.
    // Limiar 80 foi ajustado para câmeras USB comuns a 640x480.
    private static bool FocoInsuficiente(Mat gray, double limiarFoco = 80.0)
    {
        using Mat laplacian = new();
        CvInvoke.Laplacian(gray, laplacian, DepthType.Cv64F);
        MCvScalar mean = new(), stddev = new();
        CvInvoke.MeanStdDev(laplacian, ref mean, ref stddev);
        double variancia = stddev.V0 * stddev.V0;
        return variancia < limiarFoco;
    }

    // ── Melhoria 5: padding no corte do rosto ───────────────────────────────
    // Expande o retângulo detetado N% em cada direção, clampado aos limites da imagem.
    // Dá ao LBPH mais contexto (testa, queixo, laterais) para melhor distinção.
    private static Rectangle AplicarPadding(Rectangle rosto, int larguraImg, int alturaImg, double pct)
    {
        int px = (int)(rosto.Width * pct);
        int py = (int)(rosto.Height * pct);
        int x = Math.Max(rosto.X - px, 0);
        int y = Math.Max(rosto.Y - py, 0);
        int w = Math.Min(rosto.Width + px * 2, larguraImg - x);
        int h = Math.Min(rosto.Height + py * 2, alturaImg - y);
        return new Rectangle(x, y, w, h);
    }

    private string MatToBase64(Mat mat)
    {
        if (mat.IsEmpty) return "";
        using VectorOfByte vb = new();
        CvInvoke.Imencode(".jpg", mat, vb, new KeyValuePair<ImwriteFlags, int>(ImwriteFlags.JpegQuality, 72));
        return "data:image/jpeg;base64," + Convert.ToBase64String(vb.ToArray());
    }

    private void PararCamera()
    {
        cameraAtiva = false;
        cts?.Cancel();
        cts?.Dispose();
        cts = null;
        Thread.Sleep(150);
        lock (frameLock)
        {
            camera?.Dispose();
            camera = null;
            frame?.Dispose();
            frame = new Mat();
        }
        imageBase64 = "";
        scoreAcumulado = 0;
        _ultimoLabelDetectado = -1;
        _framesSemsinal = 0;
        statusMensagem = "Pronto para reconhecimento";
        InvokeAsync(StateHasChanged);
    }

    // ── Dia 16: Timer de countdown do bloqueio (atualiza o contador a cada segundo) ──
    private System.Threading.Timer? _timerBloqueio;

    private void IniciarTimerBloqueio()
    {
        _timerBloqueio?.Dispose();
        _timerBloqueio = new System.Threading.Timer(async _ =>
        {
            if (EstaBloqueado)
                await InvokeAsync(StateHasChanged);
            else
            {
                _bloqueadoAte = null;
                _timerBloqueio?.Dispose();
                _timerBloqueio = null;
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        _timerBloqueio?.Dispose();
        PararCamera();
        faceDetector?.Dispose();
        reconhecedor?.Dispose();
        cts?.Dispose();
    }
}

