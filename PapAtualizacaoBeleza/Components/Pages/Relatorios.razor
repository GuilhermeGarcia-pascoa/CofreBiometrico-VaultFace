@page "/relatorios"
@using PapAtualizacaoBeleza.Components.Layout
@using System.Data
@layout EmptyLayout
@rendermode InteractiveServer
@inject BaseSql BaseSqlService
@inject EstadoApp Estado
@inject TemaService Tema
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject EmailService EmailSvc

<PageTitle>Relatórios — VaultFace</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ── TOPBAR ── *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div class="topbar-right">
            <button class="btn-tema" @onclick="Tema.Alternar" title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            <button class="btn-outline" @onclick='() => Navigation.NavigateTo("/admin")'>
                ← Painel Admin
            </button>
        </div>
    </header>

    @* ── Cabeçalho de relatório — só visível no PDF ── *@
    <div class="print-header">
        <h2>VaultFace — Relatório de Acessos</h2>
        <p>Período: @_inicio.ToString("dd/MM/yyyy") a @_fim.ToString("dd/MM/yyyy")</p>
        <p>Gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        <hr />
        <p>
            Acessos: <b>@_stats.TotalAcessos</b> &nbsp;|&nbsp;
            Falhados: <b>@_stats.TentativasFalhadas</b> &nbsp;|&nbsp;
            Cadastros: <b>@_stats.TotalCadastros</b> &nbsp;|&nbsp;
            Utilizador mais ativo: <b>@_stats.UtilizadorMaisAtivo</b> &nbsp;|&nbsp;
            Hora de pico: <b>@_stats.HoraDePico h</b>
        </p>
        <hr />
    </div>

    <main class="rel-main">

        @* ── Título + ações ── *@
        <div class="rel-page-header no-print">
            <div>
                <h1 class="rel-title">Relatórios de Acessos</h1>
                <p class="rel-sub">Todos os eventos registados pelo sistema VaultFace</p>
            </div>
            <div class="rel-actions">
                <button class="btn-exportar no-print" @onclick="ExportarPDF" title="Exportar relatório como PDF">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    Exportar PDF
                </button>
                <button class="btn-email no-print" @onclick="EnviarPorEmail"
                        disabled="@_enviandoEmail" title="Enviar resumo por email">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                    </svg>
                    @(_enviandoEmail ? "A enviar..." : "Enviar por email")
                </button>
                @if (_emailEnviado)
                {
                    <span class="email-ok">✓ Enviado</span>
                }
            </div>
        </div>

        @* ── Barra de filtros ── *@
        <div class="filtros-bar no-print">
            <button class="btn-filtro @(_filtroAtivo == "hoje" ? "ativo" : "")"
                    @onclick='() => AplicarFiltro("hoje")'>
                Hoje
            </button>
            <button class="btn-filtro @(_filtroAtivo == "semana" ? "ativo" : "")"
                    @onclick='() => AplicarFiltro("semana")'>
                Esta semana
            </button>
            <button class="btn-filtro @(_filtroAtivo == "mes" ? "ativo" : "")"
                    @onclick='() => AplicarFiltro("mes")'>
                Este mês
            </button>
            <button class="btn-filtro @(_filtroAtivo == "custom" ? "ativo" : "")"
                    @onclick='() => _filtroAtivo = "custom"'>
                Personalizado
            </button>
            @if (_filtroAtivo == "custom")
            {
                <div class="custom-range">
                    <input type="date" class="date-input" @bind="_inicio" />
                    <span class="date-sep">até</span>
                    <input type="date" class="date-input" @bind="_fim" />
                    <button class="btn-aplicar" @onclick="CarregarDados">Aplicar</button>
                </div>
            }
        </div>

        @if (_carregando)
        {
            @* ── Estado de carregamento ── *@
            <div class="loading-msg">
                <div class="spin"></div>
                <p>A carregar relatório...</p>
            </div>
        }
        else
        {
            @* ── KPI Cards ── *@
            <div class="kpi-cards no-print">
                <div class="kpi-card kpi-card--blue">
                    <div class="kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-val">@_stats.TotalAcessos</span>
                        <span class="kpi-label">Total de Acessos</span>
                    </div>
                </div>
                <div class="kpi-card kpi-card--red">
                    <div class="kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="15" y1="9" x2="9" y2="15" />
                            <line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-val">@_stats.TentativasFalhadas</span>
                        <span class="kpi-label">Tentativas Falhadas</span>
                    </div>
                </div>
                <div class="kpi-card kpi-card--orange">
                    <div class="kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-val kpi-val--sm">@_stats.UtilizadorMaisAtivo</span>
                        <span class="kpi-label">Utilizador Mais Ativo</span>
                    </div>
                </div>
                <div class="kpi-card kpi-card--purple">
                    <div class="kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-val">@_stats.HoraDePico<small>h</small></span>
                        <span class="kpi-label">Hora de Pico</span>
                    </div>
                </div>
                <div class="kpi-card kpi-card--green">
                    <div class="kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <line x1="20" y1="8" x2="20" y2="14" />
                            <line x1="23" y1="11" x2="17" y2="11" />
                        </svg>
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-val">@_stats.TotalCadastros</span>
                        <span class="kpi-label">Novos Cadastros</span>
                    </div>
                </div>
            </div>

            @* ── Gráfico de barras SVG ── *@
            @if (_grafico.Any())
            {
                <div class="grafico-section no-print">
                    <h3 class="section-label">Acessos por dia</h3>
                    <div class="grafico-wrap">
                        @((MarkupString)GerarSvgGrafico())
                    </div>
                </div>
            }

            @* ── Tabela de logs ── *@
            <div class="logs-section">
                <div class="logs-header no-print">
                    <h3 class="section-label">Registo de eventos</h3>
                    <div class="pesquisa-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                        <input class="pesquisa-input" @bind="_pesquisa" @bind:event="oninput"
                               placeholder="Pesquisar por utilizador ou ação..." />
                    </div>
                </div>

                @if (_logs.Rows.Count == 0)
                {
                    <div class="empty-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 8v4M12 16h.01" />
                        </svg>
                        <p>Nenhum evento registado no período selecionado.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Data / Hora</th>
                                    <th>Utilizador</th>
                                    <th>Ação</th>
                                    <th>Detalhes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in LogsFiltrados)
                                {
                                    <tr class="@GetCorLinha(row["Acao"]?.ToString())">
                                        <td class="td-data">@Convert.ToDateTime(row["DataHora"]).ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@row["Usuario"]</td>
                                        <td><span class="acao-badge @GetBadgeClass(row["Acao"]?.ToString())">@row["Acao"]</span></td>
                                        <td class="td-det">@row["Detalhes"]</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Paginação *@
                    @if (TotalPaginas > 1)
                    {
                        <div class="pagination no-print">
                            <button class="btn-pag" disabled="@(_paginaAtual <= 1)"
                                    @onclick="() => { _paginaAtual--; StateHasChanged(); }">
                                ← Anterior
                            </button>
                            <span class="pag-info">@_paginaAtual / @TotalPaginas</span>
                            <button class="btn-pag" disabled="@(_paginaAtual >= TotalPaginas)"
                                    @onclick="() => { _paginaAtual++; StateHasChanged(); }">
                                Próxima →
                            </button>
                        </div>
                    }
                }
            </div>
        }
    </main>
</div>

@code {
    // ── Período ───────────────────────────────────────────────────────────────
    private DateTime _inicio = DateTime.Today.AddDays(-6);
    private DateTime _fim = DateTime.Now;
    private string _filtroAtivo = "semana";

    // ── Dados ─────────────────────────────────────────────────────────────────
    private DataTable _logs = new();
    private EstatisticasRelatorio _stats = new();
    private List<(DateTime Dia, int Total)> _grafico = new();

    // ── Paginação e pesquisa ──────────────────────────────────────────────────
    private int _paginaAtual = 1;
    private const int LINHAS_POR_PAGINA = 25;
    private string _pesquisa = "";

    // ── Estado de UI ─────────────────────────────────────────────────────────
    private bool _carregando = false;
    private bool _enviandoEmail = false;
    private bool _emailEnviado = false;

    // ── Gráfico ───────────────────────────────────────────────────────────────
    private const int GRAFICO_H = 120;
    private int AlturaBarraPx(int valor)
    {
        int max = _grafico.Any() ? _grafico.Max(x => x.Total) : 1;
        return max == 0 ? 0 : (int)(valor / (double)max * GRAFICO_H);
    }

    // Gera o SVG como string para evitar o erro do Razor com <text> com atributos
    private string GerarSvgGrafico()
    {
        int largura = _grafico.Count * 44;
        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg class=\"grafico-svg\" viewBox=\"0 0 {largura} 170\" preserveAspectRatio=\"none\">");
        int gx = 0;
        foreach (var (dia, total) in _grafico)
        {
            int altPx = AlturaBarraPx(total);
            int gy = GRAFICO_H - altPx + 30;
            sb.Append($"<rect x=\"{gx + 6}\" y=\"{gy}\" width=\"32\" height=\"{altPx}\" fill=\"#2E74B5\" rx=\"3\" opacity=\"0.85\"/>");
            if (total > 0)
                sb.Append($"<text x=\"{gx + 22}\" y=\"{gy - 5}\" text-anchor=\"middle\" font-size=\"9\" fill=\"#2E74B5\" font-weight=\"600\">{total}</text>");
            sb.Append($"<text x=\"{gx + 22}\" y=\"163\" text-anchor=\"middle\" font-size=\"8\" fill=\"#888\">{dia:dd/MM}</text>");
            gx += 44;
        }
        sb.Append("</svg>");
        return sb.ToString();
    }

    // ── Filtragem em memória ──────────────────────────────────────────────────
    private IEnumerable<DataRow> LogsFiltrados =>
        _logs.AsEnumerable()
             .Where(r => string.IsNullOrEmpty(_pesquisa) ||
                         (r["Usuario"]?.ToString() ?? "").Contains(_pesquisa, StringComparison.OrdinalIgnoreCase) ||
                         (r["Acao"]?.ToString() ?? "").Contains(_pesquisa, StringComparison.OrdinalIgnoreCase))
             .Skip((_paginaAtual - 1) * LINHAS_POR_PAGINA)
             .Take(LINHAS_POR_PAGINA);

    private int TotalPaginas => (int)Math.Ceiling(
        _logs.AsEnumerable()
             .Count(r => string.IsNullOrEmpty(_pesquisa) ||
                         (r["Usuario"]?.ToString() ?? "").Contains(_pesquisa, StringComparison.OrdinalIgnoreCase) ||
                         (r["Acao"]?.ToString() ?? "").Contains(_pesquisa, StringComparison.OrdinalIgnoreCase))
        / (double)LINHAS_POR_PAGINA);

    // ── Cor das linhas e badges ───────────────────────────────────────────────
    private string GetCorLinha(string acao) => acao switch
    {
        "Login" => "linha-verde",
        "Acesso Negado" => "linha-vermelha",
        "Criação de Usuário" => "linha-azul",
        _ => ""
    };

    private string GetBadgeClass(string acao) => acao switch
    {
        "Login" => "badge-verde",
        "Acesso Negado" => "badge-vermelho",
        "Criação de Usuário" => "badge-azul",
        _ => "badge-cinza"
    };

    // ── Ciclo de vida ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Proteção de rota — só AdminSupremo pode aceder
        if (Estado.UsuarioAtual == null ||
            Estado.UsuarioAtual.Permissao != NivelPermissao.AdminSupremo)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }
        await CarregarDados();
    }

    // ── Carregar dados ────────────────────────────────────────────────────────
    private async Task CarregarDados()
    {
        _carregando = true;
        StateHasChanged();
        await Task.Run(() =>
        {
            _logs = BaseSqlService.ObterLogsFiltrados(_inicio, _fim);
            _stats = BaseSqlService.ObterEstatisticasPeriodo(_inicio, _fim);
            _grafico = BaseSqlService.ObterAcessosPorDia(_inicio, _fim);
        });
        _paginaAtual = 1;
        _carregando = false;
        StateHasChanged();
    }

    // ── Filtros de período ────────────────────────────────────────────────────
    private async Task AplicarFiltro(string filtro)
    {
        _filtroAtivo = filtro;
        _inicio = filtro switch
        {
            "hoje" => DateTime.Today,
            "semana" => DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1),
            "mes" => new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
            _ => _inicio
        };
        _fim = DateTime.Now;
        if (filtro != "custom") await CarregarDados();
    }

    // ── Exportar PDF (CSS print) ──────────────────────────────────────────────
    private async Task ExportarPDF()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    // ── Enviar email ──────────────────────────────────────────────────────────
    private async Task EnviarPorEmail()
    {
        _enviandoEmail = true;
        _emailEnviado = false;
        StateHasChanged();

        var (email, _) = BaseSqlService.ObterEmailUserMaster();
        if (!string.IsNullOrEmpty(email))
        {
            await EmailSvc.EnviarRelatorioAsync(
                email,
                Estado.UsuarioAtual!.Nome,
                _stats,
                _inicio,
                _fim);
            _emailEnviado = true;
        }

        _enviandoEmail = false;
        StateHasChanged();
    }
}

<style>
    /* ── Variáveis (herda do tema global via TemaService) ── */
    .page {
        min-height: 100vh;
        background: var(--bg, #f4f6fb);
        color: var(--text, #1a1a2e);
    }

    .dark {
        --bg: #0d0d1a;
        --surface: #13132a;
        --border: rgba(255,255,255,0.07);
        --text: #f0f0f0;
        --dim: rgba(255,255,255,0.4);
    }

    /* ── Topbar ── */
    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 28px;
        height: 56px;
        background: var(--surface, #fff);
        border-bottom: 1px solid var(--border, #e5e9f2);
        position: sticky;
        top: 0;
        z-index: 50;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 700;
    }

    .brand-lock {
        width: 32px;
        height: 32px;
        background: #1F3864;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-tema {
        background: transparent;
        border: 1px solid var(--border, #e5e9f2);
        border-radius: 6px;
        padding: 6px;
        cursor: pointer;
        color: var(--text, #1a1a2e);
        display: flex;
        align-items: center;
    }

    .btn-outline {
        padding: 7px 14px;
        border: 1px solid var(--border, #e5e9f2);
        background: transparent;
        border-radius: 8px;
        font-size: 13px;
        cursor: pointer;
        color: var(--text, #1a1a2e);
        transition: background 0.2s;
    }

        .btn-outline:hover {
            background: var(--surface, #f4f6fb);
        }

    /* ── Layout principal ── */
    .rel-main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 24px 60px;
    }

    /* ── Cabeçalho da página ── */
    .rel-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .rel-title {
        font-size: 22px;
        font-weight: 800;
        margin: 0 0 4px;
        color: var(--text, #1a1a2e);
    }

    .rel-sub {
        font-size: 13px;
        color: var(--dim, #888);
        margin: 0;
    }

    .rel-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    /* ── Botões de ação ── */
    .btn-exportar, .btn-email {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-exportar {
        background: #1F3864;
        color: #fff;
    }

        .btn-exportar:hover {
            background: #162a4a;
        }

    .btn-email {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

        .btn-email:hover {
            background: #dcfce7;
        }

        .btn-email:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .dark .btn-exportar {
        background: #2E74B5;
    }

    .dark .btn-email {
        background: rgba(22,163,74,0.1);
        border-color: rgba(22,163,74,0.3);
        color: #4ade80;
    }

    .email-ok {
        font-size: 13px;
        color: #16a34a;
        font-weight: 600;
    }

    .dark .email-ok {
        color: #4ade80;
    }

    /* ── Filtros ── */
    .filtros-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .btn-filtro {
        padding: 7px 16px;
        border-radius: 20px;
        border: 1px solid var(--border, #e5e9f2);
        background: var(--surface, #fff);
        color: var(--text, #1a1a2e);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-filtro:hover {
            border-color: #2E74B5;
            color: #2E74B5;
        }

        .btn-filtro.ativo {
            background: #2E74B5;
            color: #fff;
            border-color: #2E74B5;
        }

    .custom-range {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .date-input {
        padding: 6px 10px;
