@page "/UserLogado"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject EstadoApp Estado
@rendermode InteractiveServer

<PageTitle>VaultFace — Painel</PageTitle>

<div class="page">

    @* ── TOPBAR ── *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <button class="btn-logout" @onclick="Logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
            Sair
        </button>
    </header>

    @* ── CONTEÚDO ── *@
    <main class="center">
        <div class="card-stack">

            @* ── PERFIL ── *@
            <div class="panel user-panel">
                <div class="avatar">@ObterIniciais(Estado.UsuarioAtual?.Nome)</div>
                <div class="user-info">
                    <span class="greeting">Bem-vindo(a) de volta</span>
                    <h1 class="user-name">@Estado.UsuarioAtual?.Nome</h1>
                    <span class="role-badge @(Estado.EhAdmin ? "badge-admin" : "badge-user")">
                        @(Estado.EhAdmin ? "Administrador" : "Membro")
                    </span>
                </div>
            </div>

            @* ── COFRE ── *@
            <div class="panel safe-panel @(cofreAberto ? "safe-panel--open" : "")">
                <div class="safe-icon-wrap">
                    @if (cofreAberto)
                    {
                        <svg class="safe-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                        </svg>
                    }
                    else
                    {
                        <svg class="safe-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    }
                </div>

                <div class="safe-info">
                    <p class="safe-label">Estado do Cofre</p>
                    <p class="safe-status @(cofreAberto ? "status-open" : "status-closed")">
                        @(cofreAberto ? "Desbloqueado" : "Bloqueado")
                    </p>
                </div>

                <button class="btn-safe @(cofreAberto ? "btn-safe--lock" : "btn-safe--unlock")" @onclick="OnClickCofre">
                    @if (cofreAberto)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <span>Trancar cofre</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                        </svg>
                        <span>Destrancar cofre</span>
                    }
                </button>
            </div>

            @* ── ADMIN (condicional) ── *@
            @if (Estado.EhAdmin)
            {
                <button class="panel admin-panel" @onclick="IrParaAdmin">
                    <div class="admin-left">
                        <div class="admin-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="admin-title">Painel Administrativo</p>
                            <p class="admin-sub">Gerir utilizadores e registos de acesso</p>
                        </div>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="admin-arrow">
                        <path d="M9 18l6-6-6-6" />
                    </svg>
                </button>
            }

        </div>
    </main>
</div>

@code {
    private bool cofreAberto = false;

    protected override void OnInitialized()
    {
        if (Estado.UsuarioAtual == null)
            Navigation.NavigateTo("/", replace: true);
    }

    private void OnClickCofre()
    {
        cofreAberto = !cofreAberto;
        if (cofreAberto) AbrirCofre();
        else FecharCofre();
    }

    private void AbrirCofre() => Console.WriteLine("Comando enviado: ABRIR");
    private void FecharCofre() => Console.WriteLine("Comando enviado: FECHAR");
    private void IrParaAdmin() => Navigation.NavigateTo("/admin");

    private void Logout()
    {
        Estado.Logout();
        Navigation.NavigateTo("/", replace: true);
    }

    private string ObterIniciais(string? nome)
    {
        if (string.IsNullOrEmpty(nome)) return "U";
        var p = nome.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1
            ? p[0][0].ToString().ToUpper()
            : (p[0][0].ToString() + p[^1][0].ToString()).ToUpper();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #f0f2f5;
        --surface: #ffffff;
        --border: #e2e5ea;
        --text: #111318;
        --muted: #6b7280;
        --dim: #9ca3af;
        --accent: #1a56db;
        --green: #16a34a;
        --green-bg: #f0fdf4;
        --green-br: #bbf7d0;
        --red: #dc2626;
        --red-bg: #fef2f2;
        --red-br: #fecaca;
        --radius: 14px;
        --shadow: 0 4px 24px rgba(0,0,0,0.07);
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
    }

    .page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* ── TOPBAR ── */
    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 32px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: -0.3px;
    }

    .brand-lock {
        width: 32px;
        height: 32px;
        background: var(--text);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        flex-shrink: 0;
    }

        .brand-lock svg {
            width: 16px;
            height: 16px;
        }

    .btn-logout {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: transparent;
        font-size: 13px;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.15s;
    }

        .btn-logout:hover {
            border-color: var(--red);
            color: var(--red);
            background: var(--red-bg);
        }

    /* ── CENTER ── */
    .center {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .card-stack {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        max-width: 420px;
    }

    /* ── PANEL BASE ── */
    .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* ── USER PANEL ── */
    .user-panel {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
    }

    .avatar {
        width: 52px;
        height: 52px;
        background: var(--text);
        color: white;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 600;
        flex-shrink: 0;
        letter-spacing: -0.5px;
    }

    .greeting {
        font-size: 12px;
        color: var(--muted);
        display: block;
        margin-bottom: 3px;
    }

    .user-name {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: -0.4px;
        line-height: 1.2;
        margin-bottom: 7px;
    }

    .role-badge {
        display: inline-block;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 999px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .badge-admin {
        background: #eff6ff;
        color: var(--accent);
        border: 1px solid #dbeafe;
    }

    .badge-user {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    /* ── SAFE PANEL ── */
    .safe-panel {
        padding: 28px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        text-align: center;
        transition: box-shadow 0.3s;
    }

    .safe-panel--open {
        box-shadow: 0 0 0 2px rgba(22,163,74,0.2), var(--shadow);
    }

    .safe-icon-wrap {
        width: 88px;
        height: 88px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        background: var(--bg);
        border: 1px solid var(--border);
    }

    .safe-panel--open .safe-icon-wrap {
        background: var(--green-bg);
        border-color: var(--green-br);
    }

    .safe-icon {
        width: 44px;
        height: 44px;
        color: var(--muted);
        transition: color 0.3s;
    }

    .safe-panel--open .safe-icon {
        color: var(--green);
    }

    .safe-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .safe-label {
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
    }

    .safe-status {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.5px;
    }

    .status-open {
        color: var(--green);
    }

    .status-closed {
        color: var(--text);
    }

    /* ── SAFE BUTTON ── */
    .btn-safe {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        padding: 13px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-safe--unlock {
        background: var(--green);
        color: white;
        box-shadow: 0 2px 12px rgba(22,163,74,0.25);
    }

        .btn-safe--unlock:hover {
            background: #15803d;
            transform: translateY(-1px);
            box-shadow: 0 4px 18px rgba(22,163,74,0.35);
        }

    .btn-safe--lock {
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-safe--lock:hover {
            background: var(--red-bg);
            border-color: var(--red-br);
            color: var(--red);
        }

    /* ── ADMIN PANEL ── */
    .admin-panel {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        cursor: pointer;
        transition: all 0.15s;
        width: 100%;
        text-align: left;
        font-family: 'DM Sans', sans-serif;
    }

        .admin-panel:hover {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(26,86,219,0.08), var(--shadow);
        }

    .admin-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .admin-icon {
        width: 38px;
        height: 38px;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        flex-shrink: 0;
    }

        .admin-icon svg {
            width: 18px;
            height: 18px;
        }

    .admin-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 2px;
    }

    .admin-sub {
        font-size: 12px;
        color: var(--muted);
    }

    .admin-arrow {
        color: var(--dim);
        flex-shrink: 0;
    }

    .admin-panel:hover .admin-arrow {
        color: var(--accent);
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 600px) {
        .topbar {
            padding: 14px 20px;
        }

        .center {
            padding: 24px 16px;
            align-items: flex-start;
        }
    }
</style>
