@page "/UserLogado"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject TemaService Tema
@rendermode InteractiveServer

@using SProjetoPapAtualizacao

<PageTitle>VaultFace — Painel</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ── POPUP: A fechar cofre antes do logout ── *@
    @if (mostrarPopupLogout)
    {
        <div class="popup-overlay">
            <div class="popup-card">
                <div class="popup-icon">
                    <div class="vault-spinner-lg"></div>
                </div>
                <p class="popup-title">A fechar o cofre...</p>
                <p class="popup-sub">Por segurança, o cofre será fechado antes de terminar a sessão.</p>
            </div>
        </div>
    }

    @* ── TOPBAR ── *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            <button class="btn-tema" @onclick="Tema.Alternar"
                    disabled="@BloqueadoPorTransicao()"
                    title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            <button class="btn-logout" @onclick="Logout" disabled="@BloqueadoPorTransicao()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sair
            </button>
        </div>
    </header>

    <main class="center">
        <div class="card-stack">

            @* ── PERFIL ── *@
            <div class="panel user-panel">
                <div class="avatar">@ObterIniciais(Estado.UsuarioAtual?.Nome)</div>
                <div class="user-info">
                    <span class="greeting">Bem-vindo(a) de volta</span>
                    <h1 class="user-name">@Estado.UsuarioAtual?.Nome</h1>
                    <span class="role-badge @(Estado.EhAdmin ? "badge-admin" : "badge-user")">
                        @(Estado.EhAdmin ? "Administrador" : "Membro")
                    </span>
                </div>
            </div>

            @* ── COFRE ── *@
            <div class="panel safe-panel @SafePanelClass()">

                @* Roda do cofre *@
                <div class="vault-door @VaultDoorClass()">

                    @* Anel exterior com marcações *@
                    <div class="vault-ring vault-ring--outer">
                        @for (int i = 0; i < 60; i++)
                        {
                            string tickClass = (i % 5 == 0) ? "ring-tick ring-tick--major" : "ring-tick ring-tick--minor";
                            <div class="@tickClass" style="transform: rotate(@(i * 6)deg) translateY(-70px)"></div>
                        }
                    </div>

                    @* Anel intermédio *@
                    <div class="vault-ring vault-ring--mid"></div>

                    @* Corpo central do cofre *@
                    <div class="vault-center">
                        <div class="bolt bolt--tl"></div>
                        <div class="bolt bolt--tr"></div>
                        <div class="bolt bolt--bl"></div>
                        <div class="bolt bolt--br"></div>

                        <div class="vault-symbol">
                            @if (estadoCofre == EstadoCofre.Aberto)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                                </svg>
                            }
                            else if (estadoCofre == EstadoCofre.Fechado)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            }
                            else
                            {
                                <div class="vault-spinner"></div>
                            }
                        </div>
                    </div>

                    @* Pega da porta *@
                    <div class="vault-handle @VaultHandleClass()">
                        <div class="handle-bar handle-bar--h"></div>
                        <div class="handle-bar handle-bar--v"></div>
                    </div>
                </div>

                @* Texto de estado *@
                <div class="safe-info">
                    <p class="safe-label">Estado do Cofre</p>
                    <p class="safe-status @SafeStatusClass()">@TextoEstado()</p>
                </div>

                @* Mensagem de erro de hardware *@
                @if (!string.IsNullOrEmpty(erroHardware))
                {
                    <div class="hw-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <span>@erroHardware</span>
                        <button @onclick="() => erroHardware = null">×</button>
                    </div>
                }

                @* Botão principal *@
                <button class="btn-safe @BtnSafeClass()"
                        @onclick="OnClickCofre"
                        disabled="@BloqueadoPorTransicao()">
                    @if (estadoCofre == EstadoCofre.AAbrir)
                    {
                        <div class="btn-spinner"></div>
                        <span>A abrir...</span>
                    }
                    else if (estadoCofre == EstadoCofre.AFechar)
                    {
                        <div class="btn-spinner"></div>
                        <span>A fechar...</span>
                    }
                    else if (estadoCofre == EstadoCofre.Aberto)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <span>Trancar cofre</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                        </svg>
                        <span>Destrancar cofre</span>
                    }
                </button>
            </div>

            @* ── ADMIN ── *@
            @if (Estado.EhAdmin)
            {
                <button class="panel admin-panel"
                        @onclick="IrParaAdmin"
                        disabled="@BloqueadoPorTransicao()">
                    <div class="admin-left">
                        <div class="admin-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="admin-title">Painel Administrativo</p>
                            <p class="admin-sub">Gerir utilizadores e registos de acesso</p>
                        </div>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="admin-arrow">
                        <path d="M9 18l6-6-6-6" />
                    </svg>
                </button>
            }

        </div>
    </main>
</div>

@code {
    // Estado local espelha o EstadoApp — sincronizado no OnInitialized
    private EstadoCofre estadoCofre = EstadoCofre.Fechado;
    private string? erroHardware = null;
    private bool mostrarPopupLogout = false;

    private const string PORTA_COM = "COM4";
    private const int DURACAO_MOTOR_MS = 2500;

    protected override void OnInitialized()
    {
        if (Estado.UsuarioAtual == null)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        // ── CORREÇÃO 1: restaurar estado real do cofre ao reentrar na página ──
        // Se o cofre estava a meio de uma transição quando o user saiu (ex: foi ao Admin
        // durante a animação), tratamos como Fechado para ficar num estado seguro e
        // coerente — o hardware já terá terminado de qualquer forma.
        estadoCofre = Estado.EstadoCofreAtual switch
        {
            EstadoCofre.AAbrir or EstadoCofre.AFechar => EstadoCofre.Fechado,
            var s => s
        };
        // Garantir que o EstadoApp também fica coerente
        Estado.EstadoCofreAtual = estadoCofre;
    }

    // ── CORREÇÃO 2: bloqueia TODOS os botões durante qualquer transição ──
    private bool BloqueadoPorTransicao() =>
        estadoCofre == EstadoCofre.AAbrir ||
        estadoCofre == EstadoCofre.AFechar ||
        mostrarPopupLogout;

    private async Task OnClickCofre()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Fechado)
            await Abrir();
        else if (estadoCofre == EstadoCofre.Aberto)
            await Fechar();
    }

    private async Task Abrir()
    {
        SetEstado(EstadoCofre.AAbrir);
        erroHardware = null;

        await Task.Run(() =>
        {
            try
            {
                var hw = new ControladorHardware(PORTA_COM);
                hw.Abrir();
                hw.Desconectar();
            }
            catch (Exception ex) { erroHardware = $"Hardware: {ex.Message}"; }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        SetEstado(EstadoCofre.Aberto);
        await InvokeAsync(StateHasChanged);
    }

    private async Task Fechar()
    {
        SetEstado(EstadoCofre.AFechar);
        erroHardware = null;

        await Task.Run(() =>
        {
            try
            {
                var hw = new ControladorHardware(PORTA_COM);
                hw.Fechar();
                hw.Desconectar();
            }
            catch (Exception ex) { erroHardware = $"Hardware: {ex.Message}"; }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        SetEstado(EstadoCofre.Fechado);
        await InvokeAsync(StateHasChanged);
    }

    // Mantém estado local e partilhado em sincronia sempre
    private void SetEstado(EstadoCofre novo)
    {
        estadoCofre = novo;
        Estado.EstadoCofreAtual = novo;
    }

    // ── CORREÇÃO 3: Logout seguro — fecha o cofre antes de deslogar ──
    private async Task Logout()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Aberto)
        {
            // Mostrar popup + executar animação de fecho
            mostrarPopupLogout = true;
            StateHasChanged();

            await Fechar();

            // Pequena pausa para o utilizador ver o estado "Fechado" antes de sair
            await Task.Delay(600);
        }

        Estado.Logout();
        Estado.EstadoCofreAtual = EstadoCofre.Fechado;
        Navigation.NavigateTo("/", replace: true);
    }

    private void IrParaAdmin()
    {
        if (BloqueadoPorTransicao()) return;
        Navigation.NavigateTo("/admin");
    }

    // ── CSS helpers ──
    private string SafePanelClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "safe-panel--open",
        EstadoCofre.AAbrir => "safe-panel--opening",
        EstadoCofre.AFechar => "safe-panel--closing",
        _ => ""
    };

    private string VaultDoorClass() => estadoCofre switch
    {
        EstadoCofre.AAbrir => "vault-door--spinning-open",
        EstadoCofre.AFechar => "vault-door--spinning-close",
        EstadoCofre.Aberto => "vault-door--open",
        _ => ""
    };

    private string VaultHandleClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "vault-handle--open",
        EstadoCofre.AAbrir => "vault-handle--turning",
        _ => ""
    };

    private string SafeStatusClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "status-open",
        EstadoCofre.AAbrir or EstadoCofre.AFechar => "status-transitioning",
        _ => "status-closed"
    };

    private string BtnSafeClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "btn-safe--lock",
        EstadoCofre.AAbrir or EstadoCofre.AFechar => "btn-safe--busy",
        _ => "btn-safe--unlock"
    };

    private string TextoEstado() => estadoCofre switch
    {
        EstadoCofre.AAbrir => "A abrir...",
        EstadoCofre.AFechar => "A fechar...",
        EstadoCofre.Aberto => "Desbloqueado",
        _ => "Bloqueado"
    };

    private string ObterIniciais(string? nome)
    {
        if (string.IsNullOrEmpty(nome)) return "U";
        var p = nome.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1
            ? p[0][0].ToString().ToUpper()
            : (p[0][0].ToString() + p[^1][0].ToString()).ToUpper();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #f0f2f5;
        --bg2: #f8f9fb;
        --surface: #ffffff;
        --surface2: #f4f5f8;
        --border: #e2e5ea;
        --text: #111318;
        --muted: #6b7280;
        --dim: #9ca3af;
        --accent: #1a56db;
        --accent-glow: rgba(26,86,219,0.12);
        --green: #16a34a;
        --green-bg: #f0fdf4;
        --green-br: #bbf7d0;
        --red: #dc2626;
        --red-bg: #fef2f2;
        --red-br: #fecaca;
        --amber: #d97706;
        --amber-bg: #fffbeb;
        --amber-br: #fde68a;
        --radius: 14px;
        --shadow: 0 4px 24px rgba(0,0,0,0.07);
        --vault-size: 160px;
        --vault-open-ring-bg: #f0fdf4;
        --vault-open-ring-br: #bbf7d0;
        --vault-open-glow: rgba(22,163,74,0.15);
        --vault-busy-ring-bg: #fffbeb;
        --vault-busy-ring-br: #fde68a;
        --vault-busy-glow: rgba(217,119,6,0.15);
    }

    .dark {
        --bg: #08090c;
        --bg2: #0e1016;
        --surface: #131620;
        --surface2: #1b1f2e;
        --border: #252836;
        --text: #e6e8f0;
        --muted: #7b82a0;
        --dim: #454c66;
        --accent: #4f74f9;
        --accent-glow: rgba(79,116,249,0.18);
        --green: #22c55e;
        --green-bg: #071a0f;
        --green-br: #14532d;
        --red: #f87171;
        --red-bg: #1a0808;
        --red-br: #7f1d1d;
        --amber: #fbbf24;
        --amber-bg: #1a1000;
        --amber-br: #78350f;
        --shadow: 0 8px 32px rgba(0,0,0,0.6);
        --vault-open-ring-bg: #071a0f;
        --vault-open-ring-br: #14532d;
        --vault-open-glow: rgba(34,197,94,0.25);
        --vault-busy-ring-bg: #1a1000;
        --vault-busy-ring-br: #78350f;
        --vault-busy-glow: rgba(251,191,36,0.25);
    }

        .dark .brand-lock {
            background: linear-gradient(135deg, var(--accent), #7b5cf6);
            box-shadow: 0 2px 8px rgba(79,116,249,0.4);
        }

        .dark .avatar {
            background: linear-gradient(135deg, var(--accent), #7b5cf6);
            box-shadow: 0 2px 12px rgba(79,116,249,0.35);
        }

        .dark .badge-admin {
            background: #080f2a;
            border-color: #1e3a8a;
            color: var(--accent);
        }

        .dark .badge-user {
            background: var(--surface2);
            border-color: var(--border);
            color: var(--muted);
        }

        .dark .admin-icon {
            background: #080f2a;
            border-color: #1e3a8a;
        }

        .dark .admin-panel:hover {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow), var(--shadow);
            background: var(--surface2);
        }

        .dark .btn-safe--unlock {
            background: var(--green);
            box-shadow: 0 2px 16px rgba(34,197,94,0.3);
        }

            .dark .btn-safe--unlock:hover:not(:disabled) {
                background: #16a34a;
                box-shadow: 0 4px 24px rgba(34,197,94,0.45);
            }

        .dark .btn-safe--lock:hover:not(:disabled) {
            background: var(--red-bg);
            border-color: var(--red-br);
            color: var(--red);
        }

        .dark .vault-center {
            box-shadow: 0 2px 16px rgba(0,0,0,0.4);
        }

        .dark .safe-panel--open .vault-center {
            box-shadow: 0 0 0 3px var(--vault-open-glow), 0 2px 16px rgba(0,0,0,0.4);
        }

        .dark .safe-panel--opening .vault-center, .dark .safe-panel--closing .vault-center {
            box-shadow: 0 0 0 3px var(--vault-busy-glow), 0 2px 16px rgba(0,0,0,0.4);
        }

        .dark .safe-panel--open {
            box-shadow: 0 0 0 2px rgba(34,197,94,0.3), 0 0 40px rgba(34,197,94,0.06), var(--shadow);
        }

        .dark .safe-panel--opening, .dark .safe-panel--closing {
            box-shadow: 0 0 0 2px rgba(251,191,36,0.3), 0 0 40px rgba(251,191,36,0.06), var(--shadow);
        }

        .dark .ring-tick--major {
            background: var(--dim);
            opacity: 0.9;
        }

        .dark .ring-tick--minor {
            background: var(--border);
            opacity: 0.45;
        }

        .dark .safe-panel--open .ring-tick--major {
            background: var(--green);
            box-shadow: 0 0 6px rgba(34,197,94,0.8);
            opacity: 1;
        }

        .dark .safe-panel--open .ring-tick--minor {
            background: var(--green);
            box-shadow: 0 0 3px rgba(34,197,94,0.4);
            opacity: 0.5;
        }

        .dark .safe-panel--opening .ring-tick--major, .dark .safe-panel--closing .ring-tick--major {
            background: var(--amber);
            box-shadow: 0 0 6px rgba(251,191,36,0.8);
            opacity: 1;
        }

        .dark .safe-panel--opening .ring-tick--minor, .dark .safe-panel--closing .ring-tick--minor {
            background: var(--amber);
            box-shadow: 0 0 3px rgba(251,191,36,0.4);
            opacity: 0.5;
        }

        .dark .vault-spinner {
            border-color: rgba(251,191,36,0.2);
            border-top-color: var(--amber);
            box-shadow: 0 0 8px rgba(251,191,36,0.3);
        }

        .dark .vault-handle--open .handle-bar {
            background: var(--green);
            box-shadow: 0 0 6px rgba(34,197,94,0.5);
        }

        .dark .vault-handle--turning .handle-bar {
            background: var(--amber);
            box-shadow: 0 0 6px rgba(251,191,36,0.5);
        }

        .dark .popup-card {
            background: var(--surface);
            border-color: var(--border);
        }

    /* ── POPUP DE LOGOUT ── */
    .popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.2s ease;
    }

    .popup-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 36px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        text-align: center;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
        animation: slideUp 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        min-width: 280px;
    }

    .popup-icon {
        width: 64px;
        height: 64px;
        background: var(--amber-bg);
        border: 1px solid var(--amber-br);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vault-spinner-lg {
        width: 32px;
        height: 32px;
        border: 3px solid var(--amber-br);
        border-top-color: var(--amber);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    .popup-title {
        font-size: 17px;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.3px;
    }

    .popup-sub {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
        max-width: 240px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(16px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* ── BOTÕES DESATIVADOS DURANTE TRANSIÇÃO ── */
    .btn-logout:disabled,
    .btn-tema:disabled,
    .admin-panel:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        pointer-events: none;
    }

    /* ── (todo o resto do CSS original mantido integralmente) ── */

    .btn-tema {
        background: none;
        border: 1px solid var(--border);
        border-radius: 8px;
