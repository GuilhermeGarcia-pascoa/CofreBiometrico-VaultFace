@page "/UserLogado"
@layout EmptyLayout
@implements IDisposable
@using System.Data
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject TemaService Tema
@inject IJSRuntime JS
@inject BaseSql BancoService
@rendermode InteractiveServer

@using SProjetoPapAtualizacao

<PageTitle>VaultFace — Painel</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ── POPUP: A fechar cofre antes do logout ── *@
    @if (mostrarPopupLogout)
    {
        <div class="popup-overlay">
            <div class="popup-card">
                <div class="popup-icon">
                    <div class="vault-spinner-lg"></div>
                </div>
                <p class="popup-title">A fechar o cofre...</p>
                <p class="popup-sub">Por segurança, o cofre será fechado antes de terminar a sessão.</p>
            </div>
        </div>
    }

    @* ── TOPBAR ── *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            <button class="btn-tema" @onclick="Tema.Alternar"
                    disabled="@BloqueadoPorTransicao()"
                    title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            @if (_timeoutAviso)
            {
                <div class="timeout-aviso">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Sessão expira em 1 min
                </div>
            }
            <button class="btn-logout" @onclick="Logout" disabled="@BloqueadoPorTransicao()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sair
            </button>
        </div>
    </header>

    <main class="ul-main">
        <div class="ul-grid">

            @* ══ COLUNA ESQUERDA — Perfil + Cofre ══ *@
            <div class="ul-col-left">

                @* ── Perfil ── *@
                <div class="ul-card ul-profile-card">
                    <div class="ul-avatar-wrap">
                        @if (!string.IsNullOrEmpty(_fotoPerfil))
                        {
                            <div class="ul-avatar ul-avatar--foto">
                                <img src="@_fotoPerfil" alt="Foto de perfil" class="ul-avatar-img" />
                            </div>
                        }
                        else
                        {
                            <div class="ul-avatar">@ObterIniciais(Estado.UsuarioAtual?.Nome)</div>
                        }
                        <div class="ul-avatar-info">
                            <span class="ul-greeting">Bem-vindo(a) de volta</span>
                            <h1 class="ul-name">@Estado.UsuarioAtual?.Nome</h1>
                            <span class="ul-role @(Estado.EhAdmin ? "ul-role--admin" : "ul-role--user")">
                                @(Estado.EhAdmin ? "Administrador" : "Membro")
                            </span>
                        </div>
                    </div>
                </div>

                @* ── Cofre ── *@
                @* ── COFRE ── *@
            <div class="panel safe-panel @SafePanelClass()">

                @* Roda do cofre *@
                <div class="vault-door @VaultDoorClass()">

                    @* Anel exterior com marcações *@
                    <div class="vault-ring vault-ring--outer">
                        @for (int i = 0; i < 60; i++)
                        {
                            string tickClass = (i % 5 == 0) ? "ring-tick ring-tick--major" : "ring-tick ring-tick--minor";
                            <div class="@tickClass" style="transform: rotate(@(i * 6)deg) translateY(2px)"></div>
                        }
                    </div>

                    @* Anel intermédio *@
                    <div class="vault-ring vault-ring--mid"></div>

                    @* Corpo central do cofre *@
                    <div class="vault-center">
                        <div class="bolt bolt--tl"></div>
                        <div class="bolt bolt--tr"></div>
                        <div class="bolt bolt--bl"></div>
                        <div class="bolt bolt--br"></div>

                        <div class="vault-symbol">
                            @if (!arduinoConectado && !aDetectarArduino)
                            {
                                @* Sem hardware — ícone de desconexão com animação *@
                                <svg class="vault-symbol-offline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <path d="M18.36 6.64a9 9 0 1 1-12.73 0" />
                                    <line x1="12" y1="2" x2="12" y2="12" />
                                </svg>
                            }
                            else if (estadoCofre == EstadoCofre.Aberto)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                                </svg>
                            }
                            else if (estadoCofre == EstadoCofre.Fechado)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            }
                            else
                            {
                                <div class="vault-spinner"></div>
                            }
                        </div>
                    </div>

                    @* Pega da porta *@
                    <div class="vault-handle @VaultHandleClass()">
                        <div class="handle-bar handle-bar--h"></div>
                        <div class="handle-bar handle-bar--v"></div>
                    </div>
                </div>

                @* Texto de estado *@
                <div class="safe-info">
                    <p class="safe-label">Estado do Cofre</p>
                    <p class="safe-status @SafeStatusClass()">@TextoEstado()</p>
                </div>

                @* Indicador de estado do Arduino *@
                @if (aDetectarArduino)
                {
                    <div class="hw-status hw-status--searching">
                        <div class="hw-search-anim">
                            <svg class="hw-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                                <rect x="2" y="7" width="20" height="14" rx="2" />
                                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                <line x1="12" y1="12" x2="12" y2="12.01" />
                            </svg>
                            <div class="hw-search-ring hw-search-ring--1"></div>
                            <div class="hw-search-ring hw-search-ring--2"></div>
                        </div>
                        <span class="hw-status-label">A procurar Arduino<span class="hw-dots"><span>.</span><span>.</span><span>.</span></span></span>
                    </div>
                }
                else if (arduinoConectado)
                {
                    <div class="hw-status hw-status--ok">
                        <div class="hw-status-dot hw-status-dot--ok"></div>
                        <span>Arduino ligado · <strong>@portaArduino</strong></span>
                    </div>
                }
                else
                {
                    <div class="hw-status hw-status--offline">
                        <div class="hw-offline-anim">
                            <svg class="hw-offline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                                <rect x="2" y="7" width="20" height="14" rx="2" />
                                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                <line x1="1" y1="1" x2="23" y2="23" stroke-width="2" />
                            </svg>
                        </div>
                        <div class="hw-offline-text">
                            <span class="hw-offline-title">Arduino não encontrado</span>
                            <span class="hw-offline-sub">Verifica o cabo USB e clica em reconectar</span>
                        </div>
                        <button class="btn-retry" @onclick="TentarNovamente" title="Tentar novamente">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="15" height="15">
                                <polyline points="23 4 23 10 17 10" />
                                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                            </svg>
                            Reconectar
                        </button>
                    </div>
                }

                @* Mensagem de erro de hardware *@
                @if (!string.IsNullOrEmpty(erroHardware))
                {
                    <div class="hw-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <span>@erroHardware</span>
                        <button @onclick="() => erroHardware = null">×</button>
                    </div>
                }

                @* Botão principal *@
                <button class="btn-safe @BtnSafeClass()"
                        @onclick="OnClickCofre"
                        disabled="@(BloqueadoPorTransicao() || !arduinoConectado || aDetectarArduino)">
                    @if (estadoCofre == EstadoCofre.AAbrir)
                    {
                        <div class="btn-spinner"></div>
                        <span>A abrir...</span>
                    }
                    else if (estadoCofre == EstadoCofre.AFechar)
                    {
                        <div class="btn-spinner"></div>
                        <span>A fechar...</span>
                    }
                    else if (estadoCofre == EstadoCofre.Aberto)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <span>Trancar cofre</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                        </svg>
                        <span>Destrancar cofre</span>
                    }
                </button>
            </div>

                @* ── Admin ── *@
                @if (Estado.EhAdmin)
                {
                    @* ── ADMIN ── *@
                @if (Estado.EhAdmin)
                {
                    <button class="panel admin-panel"
                                @onclick="IrParaAdmin"
                                disabled="@BloqueadoPorTransicao()">
                        <div class="admin-left">
                                <div class="admin-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="admin-title">Painel Administrativo</p>
                                    <p class="admin-sub">Gerir utilizadores e registos de acesso</p>
                                </div>
                        </div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="admin-arrow">
                                <path d="M9 18l6-6-6-6" />
                        </svg>
                    </button>
                }
                }

            </div>

            @* ══ COLUNA DIREITA — Histórico + Re-treino ══ *@
            <div class="ul-col-right">

                @* ── Re-treino de Biometria ── *@
                <div class="ul-card ul-retreino-card">
                    <div class="ul-section-header">
                        <div class="ul-section-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                                <circle cx="12" cy="13" r="4"/>
                            </svg>
                        </div>
                        <div>
                            <p class="ul-section-title">Biometria Facial</p>
                            <p class="ul-section-sub">Refaça o registo se tiver dificuldades de acesso.</p>
                        </div>
                    </div>
                    @if (_retreinoEstado == "idle")
                    {
                        <button class="ul-btn-retreino" @onclick="IniciarRetreino">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.51"/>
                            </svg>
                            Atualizar biometria
                        </button>
                    }
                    else if (_retreinoEstado == "confirmar")
                    {
                        <div class="ul-retreino-confirm">
                            <p class="ul-retreino-aviso">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                As biometrias atuais serão apagadas.
                            </p>
                            <div class="ul-retreino-btns">
                                <button class="ul-btn-retreino ul-btn-retreino--confirm" @onclick="ConfirmarRetreino">Confirmar</button>
                                <button class="ul-btn-retreino ul-btn-retreino--cancel" @onclick="CancelarRetreino">Cancelar</button>
                            </div>
                        </div>
                    }
                    else if (_retreinoEstado == "aguardar")
                    {
                        <div class="ul-retreino-aguardar">
                            <div class="ul-retreino-spinner"></div>
                            <span>A preparar...</span>
                        </div>
                    }
                </div>

                @* ── Histórico de Acessos ── *@
                <div class="ul-card ul-hist-card">
                    <div class="ul-section-header">
                        <div class="ul-section-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <div>
                            <p class="ul-section-title">Últimos Acessos</p>
                            <p class="ul-section-sub">Histórico de atividade da sua conta.</p>
                        </div>
                    </div>
                    @if (_historico == null || _historico.Rows.Count == 0)
                    {
                        <p class="ul-hist-empty">Sem registos de acesso anteriores.</p>
                    }
                    else
                    {
                        <div class="ul-hist-wrap">
                            <table class="ul-hist-table">
                                <thead>
                                    <tr>
                                        <th>Data / Hora</th>
                                        <th>Ação</th>
                                        <th>Detalhes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (System.Data.DataRow row in _historico.Rows)
                                    {
                                        <tr class="@GetCorHistorico(row["Acao"]?.ToString())">
                                            <td class="ul-hist-data">@Convert.ToDateTime(row["DataHora"]).ToString("dd/MM HH:mm")</td>
                                            <td><span class="ul-hist-badge @GetBadgeHistorico(row["Acao"]?.ToString())">@row["Acao"]</span></td>
                                            <td class="ul-hist-det">@row["Detalhes"]</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    </main>
</div>

@code {
    // ── Timeout de sessão (5 minutos de inatividade) ───────────────────────────
    private const int TIMEOUT_MINUTOS = 5;
    private DateTime _ultimaAtividade = DateTime.Now;
    private System.Threading.Timer? _timeoutTimer;
    private bool _timeoutAviso = false; // aviso 1 min antes

    [JSInvokable]
    public void RegistarAtividade()
    {
        _ultimaAtividade = DateTime.Now;
        if (_timeoutAviso)
        {
            _timeoutAviso = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void IniciarTimerTimeout()
    {
        _timeoutTimer = new System.Threading.Timer(_ =>
        {
            var inativo = (DateTime.Now - _ultimaAtividade).TotalMinutes;
            if (inativo >= TIMEOUT_MINUTOS)
            {
                _ = InvokeAsync(async () =>
                {
                    await Logout();
                });
            }
            else if (inativo >= TIMEOUT_MINUTOS - 1 && !_timeoutAviso)
            {
                _timeoutAviso = true;
                _ = InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    // Re-treino de biometria
    private string _retreinoEstado = "idle";
    private void IniciarRetreino() => _retreinoEstado = "confirmar";
    private void CancelarRetreino() => _retreinoEstado = "idle";

    private async Task ConfirmarRetreino()
    {
        _retreinoEstado = "aguardar";
        StateHasChanged();
        await Task.Delay(300);
        try
        {
            int uid = BancoService.ObterUsuarioIdPorNome(Estado.UsuarioAtual!.Nome);
            if (uid > 0)
            {
                BancoService.LimparRostosUtilizador(uid);
                BancoService.RegistrarLog(Estado.UsuarioAtual.Nome, "Re-treino", "Utilizador apagou biometrias para novo registo.");
            }
            Estado.RetreinarBiometria = true;
            Navigation.NavigateTo("/cadastro", replace: true);
        }
        catch { _retreinoEstado = "idle"; }
    }

    // Dia 20: foto de perfil
    private string? _fotoPerfil;

    // Estado local espelha o EstadoApp — sincronizado no OnInitialized
    private EstadoCofre estadoCofre = EstadoCofre.Fechado;
    private string? erroHardware = null;
    private bool mostrarPopupLogout = false;

    // Dia 17: Histórico de acessos do utilizador
    private System.Data.DataTable? _historico;

    private string GetCorHistorico(string? acao) => acao switch
    {
        "Login" => "hist-verde",
        "Acesso Negado" => "hist-vermelho",
        _ => ""
    };

    private string GetBadgeHistorico(string? acao) => acao switch
    {
        "Login" => "badge-hist-verde",
        "Acesso Negado" => "badge-hist-vermelho",
        _ => "badge-hist-neutro"
    };

    private const int DURACAO_MOTOR_MS = 2500;

    // Porta COM detetada automaticamente no arranque — null se Arduino não encontrado
    private string? portaArduino = null;
    private bool arduinoConectado => portaArduino != null;
    private bool aDetectarArduino = false;

    // Instância persistente do hardware — mantida enquanto o cofre está aberto
    // para que o heartbeat continue a ser enviado ao Arduino
    private ControladorHardware? _hw = null;

    // Timer de monitorização da ligação — verifica a cada 3s se o Arduino ainda responde
    private Timer? _monitorTimer = null;
    private const int MONITOR_INTERVALO_MS = 3000;

    protected override async Task OnInitializedAsync()
    {
        // Dia 20: carregar foto de perfil em background
        if (Estado.UsuarioAtual != null)
        {
            _ = Task.Run(() =>
            {
                _fotoPerfil = BancoService.ObterPrimeiraFotoBase64(Estado.UsuarioAtual.Nome);
            }).ContinueWith(_ => InvokeAsync(StateHasChanged));
        }
        if (Estado.UsuarioAtual == null)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        IniciarTimerTimeout();
        // Ligar deteção de atividade JS


        // ── CORREÇÃO 1: restaurar estado real do cofre ao reentrar na página ──
        estadoCofre = Estado.EstadoCofreAtual switch
        {
            EstadoCofre.AAbrir or EstadoCofre.AFechar => EstadoCofre.Fechado,
            var s => s
        };
        Estado.EstadoCofreAtual = estadoCofre;

        // ── Deteção automática da porta COM do Arduino ──
        aDetectarArduino = true;
        StateHasChanged();

        portaArduino = await Task.Run(() => ControladorHardware.DetectarPortaArduino());

        aDetectarArduino = false;

        if (portaArduino == null)
            erroHardware = "Arduino não encontrado. O cofre físico não poderá ser operado.";

        // Inicia monitorização contínua da ligação
        IniciarMonitorLigacao();

        // Dia 17: carregar histórico de acessos do utilizador atual
        await Task.Run(() =>
            _historico = BancoService.ObterHistoricoUtilizador(Estado.UsuarioAtual!.Nome));

        StateHasChanged();
    }

    private bool _jsIniciado = false;

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && !_jsIniciado)
    {
        _jsIniciado = true;
        var dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("iniciarMonitorAtividade", dotnetRef);
    }
}
    // ── CORREÇÃO 2: bloqueia TODOS os botões durante qualquer transição ──
    private bool BloqueadoPorTransicao() =>
        estadoCofre == EstadoCofre.AAbrir ||
        estadoCofre == EstadoCofre.AFechar ||
        mostrarPopupLogout;

    private async Task OnClickCofre()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Fechado)
            await Abrir();
        else if (estadoCofre == EstadoCofre.Aberto)
            await Fechar();
    }

    private async Task Abrir()
    {
        if (!arduinoConectado) return;

        SetEstado(EstadoCofre.AAbrir);
        erroHardware = null;

        bool sucesso = false;
        await Task.Run(() =>
        {
            try
            {
                _hw = new ControladorHardware(portaArduino!);
                _hw.Abrir();
                sucesso = true;
            }
            catch (Exception ex)
            {
                erroHardware = $"Hardware: {ex.Message}";
                _hw?.Dispose();
                _hw = null;
            }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        // Só avança para Aberto se o hardware respondeu — caso contrário volta a Fechado
        SetEstado(sucesso ? EstadoCofre.Aberto : EstadoCofre.Fechado);
        await InvokeAsync(StateHasChanged);
    }

    private async Task Fechar()
    {
        if (!arduinoConectado) return;

        SetEstado(EstadoCofre.AFechar);
        erroHardware = null;

        await Task.Run(() =>
        {
            try
            {
                if (_hw != null)
                {
                    // Para o heartbeat e envia 'F' — tudo dentro do Fechar()
                    _hw.Fechar();
                    _hw.Dispose();
                    _hw = null;
                }
                else
                {
                    // Fallback: se por algum motivo não há instância ativa, cria uma temporária
                    using var hwTemp = new ControladorHardware(portaArduino!);
                    hwTemp.Fechar();
                }
            }
            catch (Exception ex) { erroHardware = $"Hardware: {ex.Message}"; }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        SetEstado(EstadoCofre.Fechado);
        await InvokeAsync(StateHasChanged);
    }

    // Mantém estado local e partilhado em sincronia sempre
    private void SetEstado(EstadoCofre novo)
    {
        estadoCofre = novo;
        Estado.EstadoCofreAtual = novo;
    }

    // ── CORREÇÃO 3: Logout seguro — fecha o cofre antes de deslogar ──
    private async Task Logout()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Aberto)
        {
            // Mostrar popup + executar animação de fecho
            mostrarPopupLogout = true;
            StateHasChanged();

            await Fechar();

            // Pequena pausa para o utilizador ver o estado "Fechado" antes de sair
            await Task.Delay(600);
        }

        Estado.Logout();
        Estado.EstadoCofreAtual = EstadoCofre.Fechado;
        Navigation.NavigateTo("/", replace: true);
    }

    // ── Monitorização contínua da ligação ────────────────────────────────────
    // Corre a cada 3s e verifica se o Arduino ainda responde ao ping 'P'.
    // Se o cabo for desligado durante o uso, a UI bloqueia imediatamente.
    private void IniciarMonitorLigacao()
    {
        _monitorTimer?.Dispose();
        _monitorTimer = new Timer(async _ =>
        {
            // Se o cofre está em transição ou o heartbeat já trata da ligação, não interferir
            if (BloqueadoPorTransicao() || estadoCofre == EstadoCofre.Aberto) return;

            bool estaLigado = await Task.Run(() =>
            {
                // Se já havia uma porta detetada, testa apenas essa — mais rápido
                if (portaArduino != null)
                    return ControladorHardware.PingPorta(portaArduino);

                // Se não havia porta, tenta detetar de novo (cabo pode ter sido ligado)
                string? novaPorta = ControladorHardware.DetectarPortaArduino();
                if (novaPorta != null)
                {
                    portaArduino = novaPorta;
                    return true;
                }
                return false;
            });

            bool mudou = estaLigado != arduinoConectado;

            if (!estaLigado)
                portaArduino = null;

            if (mudou)
            {
                // Quando desliga: mostra aviso. Quando reconecta: limpa o aviso.
                erroHardware = estaLigado
                    ? null
                    : "Ligação ao Arduino perdida. O cofre físico foi bloqueado.";
                await InvokeAsync(StateHasChanged);
            }
        },
        state: null,
        dueTime: MONITOR_INTERVALO_MS,
        period: MONITOR_INTERVALO_MS);
    }

    // Botão "Tentar novamente" — faz nova deteção completa a pedido do utilizador
    private async Task TentarNovamente()
    {
        aDetectarArduino = true;
        erroHardware = null;
        StateHasChanged();

        portaArduino = await Task.Run(() => ControladorHardware.DetectarPortaArduino());

        aDetectarArduino = false;

        if (portaArduino == null)
            erroHardware = "Arduino continua sem resposta. Verifica o cabo USB e tenta novamente.";

        // Reinicia o monitor — estava parado desde que a ligação foi perdida
        IniciarMonitorLigacao();

        StateHasChanged();
    }

    // ── Limpeza ao destruir a página ─────────────────────────────────────────
    public void Dispose()
    {
        _timeoutTimer?.Dispose();
        _timeoutTimer = null;
        _monitorTimer?.Dispose();
        _monitorTimer = null;
        _hw?.Dispose();
        _hw = null;
    }

    private void IrParaAdmin()
    {
        if (BloqueadoPorTransicao()) return;
        Navigation.NavigateTo("/admin");
    }

    // ── CSS helpers ──
    private string SafePanelClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "safe-panel--offline";
        return estadoCofre switch
        {
            EstadoCofre.Aberto => "safe-panel--open",
            EstadoCofre.AAbrir => "safe-panel--opening",
            EstadoCofre.AFechar => "safe-panel--closing",
            _ => ""
        };
    }

    private string VaultDoorClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "vault-door--offline";
        return estadoCofre switch
        {
            EstadoCofre.AAbrir => "vault-door--spinning-open",
            EstadoCofre.AFechar => "vault-door--spinning-close",
            EstadoCofre.Aberto => "vault-door--open",
            _ => ""
        };
    }

    private string VaultHandleClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "vault-handle--open",
        EstadoCofre.AAbrir => "vault-handle--turning",
        _ => ""
    };

    private string SafeStatusClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "status-offline";
        return estadoCofre switch
        {
            EstadoCofre.Aberto => "status-open",
            EstadoCofre.AAbrir or EstadoCofre.AFechar => "status-transitioning",
            _ => "status-closed"
        };
    }

    private string BtnSafeClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "btn-safe--lock",
        EstadoCofre.AAbrir or EstadoCofre.AFechar => "btn-safe--busy",
        _ => "btn-safe--unlock"
    };

    private string TextoEstado()
    {
        if (aDetectarArduino) return "A verificar...";
        if (!arduinoConectado) return "Sem ligação";
        return estadoCofre switch
        {
            EstadoCofre.AAbrir => "A abrir...",
            EstadoCofre.AFechar => "A fechar...",
            EstadoCofre.Aberto => "Desbloqueado",
            _ => "Bloqueado"
        };
    }

    private string ObterIniciais(string? nome)
    {
        if (string.IsNullOrEmpty(nome)) return "U";
        var p = nome.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1
            ? p[0][0].ToString().ToUpper()
            : (p[0][0].ToString() + p[^1][0].ToString()).ToUpper();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ══ Variáveis ══ */
    :root {
        --bg: #f0f2f5; --bg2: #f8f9fb; --surface: #ffffff; --surface2: #f4f5f8;
        --border: #e2e5ea; --text: #111318; --muted: #6b7280; --dim: #9ca3af;
        --accent: #1a56db; --accent-glow: rgba(26,86,219,0.10);
        --green: #16a34a; --green-bg: #f0fdf4; --green-br: #bbf7d0;
        --red: #dc2626; --red-bg: #fef2f2; --red-br: #fecaca;
        --amber: #d97706; --amber-bg: #fffbeb; --amber-br: #fde68a;
        --blue-bg: #eff6ff; --blue-br: #dbeafe;
        --radius: 14px; --shadow: 0 4px 24px rgba(0,0,0,0.07);
    }
    .dark {
        --bg: #08090c; --bg2: #0e1016; --surface: #131620; --surface2: #1b1f2e;
        --border: #252836; --text: #e6e8f0; --muted: #7b82a0; --dim: #454c66;
        --accent: #4f74f9; --accent-glow: rgba(79,116,249,0.15);
        --green: #22c55e; --green-bg: #071a0f; --green-br: #14532d;
        --red: #f87171; --red-bg: #1a0808; --red-br: #7f1d1d;
        --amber: #fbbf24; --amber-bg: #1a1000; --amber-br: #78350f;
        --blue-bg: #080f2a; --blue-br: #1e3a8a;
        --shadow: 0 8px 32px rgba(0,0,0,0.6);
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); -webkit-font-smoothing: antialiased; }
    .page { min-height: 100vh; background: var(--bg); display: flex; flex-direction: column; }

    /* ══ Timeout aviso ══ */
    .timeout-aviso {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        background: var(--amber-bg);
        border: 1px solid var(--amber-br);
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        color: var(--amber);
        animation: vf-pulse 1.5s ease-in-out infinite;
    }
    @@keyframes vf-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }

    /* ══ Topbar ══ */
    .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 32px; height: 60px; background: var(--surface);
        border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100;
    }
    .brand { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 600; letter-spacing: -0.3px; color: var(--text); }
    .brand-lock { width: 32px; height: 32px; background: var(--text); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; }
    .brand-lock svg { width: 16px; height: 16px; }
    .dark .brand-lock { background: linear-gradient(135deg, var(--accent), #7b5cf6); box-shadow: 0 2px 8px rgba(79,116,249,0.4); }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .btn-tema { background: none; border: 1px solid var(--border); border-radius: 8px; padding: 7px 9px; cursor: pointer; color: var(--muted); display: flex; align-items: center; transition: all 0.15s; }
    .btn-tema:hover { background: var(--surface2); color: var(--text); }
    .btn-logout { display: flex; align-items: center; gap: 7px; padding: 7px 14px; border: 1px solid var(--border); border-radius: 8px; background: transparent; font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif; color: var(--muted); cursor: pointer; transition: all 0.15s; }
    .btn-logout:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }
    .btn-logout:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ══ Layout grid 2 colunas ══ */
    .ul-main { flex: 1; padding: 28px 32px 60px; max-width: 1200px; margin: 0 auto; width: 100%; }
    .ul-grid { display: grid; grid-template-columns: 380px 1fr; gap: 20px; align-items: start; }
    @@media (max-width: 900px) { .ul-grid { grid-template-columns: 1fr; } }

    .ul-col-left { display: flex; flex-direction: column; gap: 16px; }
    .ul-col-right { display: flex; flex-direction: column; gap: 16px; }

    /* ══ Cards base ══ */
    .ul-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow); padding: 20px 24px;
    }

    /* ══ Perfil ══ */
    .ul-profile-card { padding: 22px 24px; }
    .ul-avatar-wrap { display: flex; align-items: center; gap: 16px; }
    .ul-avatar {
        width: 56px; height: 56px; border-radius: 14px;
        background: var(--text); color: white;
        font-size: 22px; font-weight: 700;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .dark .ul-avatar { background: linear-gradient(135deg, var(--accent), #7b5cf6); }
    .ul-avatar--foto { padding: 0; overflow: hidden; }
    .ul-avatar-img { width: 100%; height: 100%; object-fit: cover; }
    .ul-avatar-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .ul-greeting { font-size: 12px; color: var(--muted); }
    .ul-name { font-size: 18px; font-weight: 700; letter-spacing: -0.3px; color: var(--text); }
    .ul-role { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 99px; display: inline-block; }
    .ul-role--admin { background: var(--blue-bg); color: var(--accent); border: 1px solid var(--blue-br); }
    .ul-role--user  { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

    /* ══ Painel do cofre — mantém toda a lógica original com novos wrappers ══ */
    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); padding: 24px; }
    .safe-panel { display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 28px 24px; transition: border-color 0.4s, box-shadow 0.4s; }
    .safe-panel--aberto { border-color: var(--green-br); box-shadow: 0 0 0 3px rgba(22,163,74,0.1), var(--shadow); }
    .safe-panel--fechado { border-color: var(--border); }
    .safe-panel--abrindo, .safe-panel--fechando { border-color: var(--amber-br); box-shadow: 0 0 0 3px rgba(217,119,6,0.08), var(--shadow); }

    /* Admin panel */
    .admin-panel {
        background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 16px 20px;
        display: flex; align-items: center; justify-content: space-between; gap: 16px;
        cursor: pointer; transition: all 0.15s; width: 100%; text-align: left;
    }
    .admin-panel:hover { border-color: var(--accent); background: var(--blue-bg); }
    .admin-panel:disabled { opacity: 0.4; cursor: not-allowed; }
    .admin-left { display: flex; align-items: center; gap: 14px; }
    .admin-icon { width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #1F3864, #2E74B5); color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .admin-icon svg { width: 18px; height: 18px; }
    .admin-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .admin-sub { font-size: 12px; color: var(--muted); }
    .admin-arrow { color: var(--dim); flex-shrink: 0; }

    /* ══ Seção header (re-treino e histórico) ══ */
    .ul-section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .ul-section-icon { width: 36px; height: 36px; border-radius: 9px; background: var(--blue-bg); border: 1px solid var(--blue-br); color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ul-section-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .ul-section-sub { font-size: 12px; color: var(--muted); }

    /* ══ Re-treino ══ */
    .ul-btn-retreino {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 8px 14px; background: var(--bg); border: 1px solid var(--border);
        border-radius: 8px; font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif;
        color: var(--text); cursor: pointer; transition: all 0.15s;
    }
    .ul-btn-retreino:hover { border-color: var(--accent); color: var(--accent); background: var(--blue-bg); }
    .ul-btn-retreino--confirm { background: var(--text); color: white; border-color: var(--text); }
    .ul-btn-retreino--confirm:hover { opacity: 0.85; color: white; background: var(--text); }
    .ul-btn-retreino--cancel:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }
    .ul-retreino-confirm { display: flex; flex-direction: column; gap: 10px; }
    .ul-retreino-aviso { display: flex; align-items: center; gap: 7px; font-size: 12.5px; color: var(--amber); background: var(--amber-bg); border: 1px solid var(--amber-br); border-radius: 8px; padding: 9px 12px; }
    .ul-retreino-btns { display: flex; gap: 8px; }
    .ul-retreino-aguardar { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--muted); }
    .ul-retreino-spinner { width: 16px; height: 16px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.7s linear infinite; }

    /* ══ Histórico ══ */
    .ul-hist-empty { font-size: 13px; color: var(--dim); padding: 8px 0; }
    .ul-hist-wrap { overflow-x: auto; }
    .ul-hist-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
    .ul-hist-table th { padding: 8px 12px; background: var(--bg2); border-bottom: 1px solid var(--border); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--dim); text-align: left; }
    .ul-hist-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .ul-hist-table tbody tr:last-child td { border-bottom: none; }
    .ul-hist-table tbody tr:hover td { background: var(--bg2); }
    .ul-hist-data { color: var(--muted); font-size: 11.5px; white-space: nowrap; font-family: monospace; }
    .ul-hist-det { color: var(--muted); font-size: 11.5px; }
    .ul-hist-badge { padding: 2px 9px; border-radius: 99px; font-size: 11px; font-weight: 600; display: inline-block; white-space: nowrap; }
    .hist-verde   .ul-hist-table td:first-child { border-left: 3px solid var(--green); }
    .hist-vermelho .ul-hist-table td:first-child { border-left: 3px solid var(--red); }
    .badge-hist-verde    { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-br); }
    .badge-hist-vermelho { background: var(--red-bg);   color: var(--red);   border: 1px solid var(--red-br); }
    .badge-hist-neutro   { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

    /* ══ Estado do cofre (porta) ══ */
    .porta-status { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-top: 4px; }
    .porta-status--aberta  { background: var(--red-bg);   color: var(--red);   border: 1px solid var(--red-br); }
    .porta-status--fechada { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-br); }

    /* ══ Vault door — mantida intacta ══ */
    .vault-door { position: relative; width: 160px; height: 160px; }
    .vault-ring { position: absolute; border-radius: 50%; }
    .vault-ring--outer { inset: 0; border: 3px solid var(--border); }
    .vault-ring--mid   { inset: 14px; border: 2px solid var(--border); }
    .ring-tick { position: absolute; left: 50%; top: 0; width: 2px; transform-origin: 0 80px; }
    .ring-tick--major { height: 7px; background: var(--dim); border-radius: 1px; }
    .ring-tick--minor { height: 3px; background: var(--border); border-radius: 1px; }
    .vault-center { position: absolute; inset: 28px; background: var(--surface); border-radius: 50%; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06) inset; }
    .bolt { position: absolute; width: 10px; height: 10px; border-radius: 50%; background: var(--border); }
    .bolt--tl { top: 6px; left: 6px; } .bolt--tr { top: 6px; right: 6px; }
    .bolt--bl { bottom: 6px; left: 6px; } .bolt--br { bottom: 6px; right: 6px; }
    .vault-symbol { color: var(--text); display: flex; align-items: center; justify-content: center; }
    .vault-symbol-offline { opacity: 0.35; animation: pulse 2s ease-in-out infinite; }
    .vault-handle { position: absolute; right: -14px; top: 50%; transform: translateY(-50%); width: 18px; height: 36px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .handle-bar { background: var(--border); border-radius: 2px; }
    .handle-bar--h { width: 18px; height: 4px; }
    .handle-bar--v { width: 4px; height: 18px; }
    .vault-handle--open { transform: translateY(-50%) rotate(90deg); }
    .vault-door--open   { animation: vaultOpen 0.6s ease forwards; }
    .vault-door--closed { animation: vaultClose 0.5s ease forwards; }
    @@keyframes vaultOpen  { 0% { transform: rotate(0); } 100% { transform: rotate(-15deg); } }
    @@keyframes vaultClose { 0% { transform: rotate(-15deg); } 100% { transform: rotate(0); } }

    .vault-spinner { width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .safe-info { text-align: center; }
    .safe-label { font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
    .safe-status { font-size: 15px; font-weight: 700; }
    .safe-status--aberto  { color: var(--green); }
    .safe-status--fechado { color: var(--text); }
    .safe-status--transicao { color: var(--amber); }

    /* Botão do cofre */
    .btn-safe { display: flex; align-items: center; gap: 10px; width: 100%; padding: 12px 20px; border: none; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.2s; justify-content: center; }
    .btn-safe--abrir  { background: var(--text); color: white; }
    .btn-safe--abrir:hover:not(:disabled)  { opacity: 0.85; }
    .btn-safe--fechar { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-br); }
    .btn-safe--fechar:hover:not(:disabled) { background: var(--red); color: white; }
    .btn-safe--transicao { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-br); cursor: wait; }
    .btn-safe:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-spinner { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; flex-shrink: 0; }

    /* Hardware status */
    .hw-status { display: flex; align-items: center; gap: 10px; font-size: 12px; padding: 8px 12px; border-radius: 8px; width: 100%; }
    .hw-status--searching { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-br); }
    .hw-status--ok  { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-br); }
    .hw-status--offline { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-br); flex-wrap: wrap; }
    .hw-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
