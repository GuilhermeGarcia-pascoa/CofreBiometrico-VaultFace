@page "/UserLogado"
@layout EmptyLayout
@implements IDisposable
@using System.Data
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject TemaService Tema
@inject BaseSql BancoService
@rendermode InteractiveServer

@using SProjetoPapAtualizacao

<PageTitle>VaultFace — Painel</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ── POPUP: A fechar cofre antes do logout ── *@
    @if (mostrarPopupLogout)
    {
        <div class="popup-overlay">
            <div class="popup-card">
                <div class="popup-icon">
                    <div class="vault-spinner-lg"></div>
                </div>
                <p class="popup-title">A fechar o cofre...</p>
                <p class="popup-sub">Por segurança, o cofre será fechado antes de terminar a sessão.</p>
            </div>
        </div>
    }

    @* ── TOPBAR ── *@
    <header class="topbar">
        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            <button class="btn-tema" @onclick="Tema.Alternar"
                    disabled="@BloqueadoPorTransicao()"
                    title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            <button class="btn-logout" @onclick="Logout" disabled="@BloqueadoPorTransicao()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sair
            </button>
        </div>
    </header>

    <main class="center">
        <div class="card-stack">

            @* ── PERFIL ── *@
            <div class="panel user-panel">
                @if (!string.IsNullOrEmpty(_fotoPerfil))
                {
                    <div class="avatar avatar--foto">
                        <img src="@_fotoPerfil" alt="Foto de perfil" class="avatar-img" />
                    </div>
                }
                else
                {
                    <div class="avatar">@ObterIniciais(Estado.UsuarioAtual?.Nome)</div>
                }
                <div class="user-info">
                    <span class="greeting">Bem-vindo(a) de volta</span>
                    <h1 class="user-name">@Estado.UsuarioAtual?.Nome</h1>
                    <span class="role-badge @(Estado.EhAdmin ? "badge-admin" : "badge-user")">
                        @(Estado.EhAdmin ? "Administrador" : "Membro")
                    </span>
                </div>
            </div>

            @* ── COFRE ── *@
            <div class="panel safe-panel @SafePanelClass()">

                @* Roda do cofre *@
                <div class="vault-door @VaultDoorClass()">

                    @* Anel exterior com marcações *@
                    <div class="vault-ring vault-ring--outer">
                        @for (int i = 0; i < 60; i++)
                        {
                            string tickClass = (i % 5 == 0) ? "ring-tick ring-tick--major" : "ring-tick ring-tick--minor";
                            <div class="@tickClass" style="transform: rotate(@(i * 6)deg) translateY(-70px)"></div>
                        }
                    </div>

                    @* Anel intermédio *@
                    <div class="vault-ring vault-ring--mid"></div>

                    @* Corpo central do cofre *@
                    <div class="vault-center">
                        <div class="bolt bolt--tl"></div>
                        <div class="bolt bolt--tr"></div>
                        <div class="bolt bolt--bl"></div>
                        <div class="bolt bolt--br"></div>

                        <div class="vault-symbol">
                            @if (!arduinoConectado && !aDetectarArduino)
                            {
                                @* Sem hardware — ícone de desconexão com animação *@
                                <svg class="vault-symbol-offline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <path d="M18.36 6.64a9 9 0 1 1-12.73 0" />
                                    <line x1="12" y1="2" x2="12" y2="12" />
                                </svg>
                            }
                            else if (estadoCofre == EstadoCofre.Aberto)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                                </svg>
                            }
                            else if (estadoCofre == EstadoCofre.Fechado)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="36" height="36">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            }
                            else
                            {
                                <div class="vault-spinner"></div>
                            }
                        </div>
                    </div>

                    @* Pega da porta *@
                    <div class="vault-handle @VaultHandleClass()">
                        <div class="handle-bar handle-bar--h"></div>
                        <div class="handle-bar handle-bar--v"></div>
                    </div>
                </div>

                @* Texto de estado *@
                <div class="safe-info">
                    <p class="safe-label">Estado do Cofre</p>
                    <p class="safe-status @SafeStatusClass()">@TextoEstado()</p>
                </div>

                @* Indicador de estado do Arduino *@
                @if (aDetectarArduino)
                {
                    <div class="hw-status hw-status--searching">
                        <div class="hw-search-anim">
                            <svg class="hw-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                                <rect x="2" y="7" width="20" height="14" rx="2" />
                                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                <line x1="12" y1="12" x2="12" y2="12.01" />
                            </svg>
                            <div class="hw-search-ring hw-search-ring--1"></div>
                            <div class="hw-search-ring hw-search-ring--2"></div>
                        </div>
                        <span class="hw-status-label">A procurar Arduino<span class="hw-dots"><span>.</span><span>.</span><span>.</span></span></span>
                    </div>
                }
                else if (arduinoConectado)
                {
                    <div class="hw-status hw-status--ok">
                        <div class="hw-status-dot hw-status-dot--ok"></div>
                        <span>Arduino ligado · <strong>@portaArduino</strong></span>
                    </div>
                }
                else
                {
                    <div class="hw-status hw-status--offline">
                        <div class="hw-offline-anim">
                            <svg class="hw-offline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                                <rect x="2" y="7" width="20" height="14" rx="2" />
                                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                <line x1="1" y1="1" x2="23" y2="23" stroke-width="2" />
                            </svg>
                        </div>
                        <div class="hw-offline-text">
                            <span class="hw-offline-title">Arduino não encontrado</span>
                            <span class="hw-offline-sub">Verifica o cabo USB e clica em reconectar</span>
                        </div>
                        <button class="btn-retry" @onclick="TentarNovamente" title="Tentar novamente">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="15" height="15">
                                <polyline points="23 4 23 10 17 10" />
                                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                            </svg>
                            Reconectar
                        </button>
                    </div>
                }

                @* Mensagem de erro de hardware *@
                @if (!string.IsNullOrEmpty(erroHardware))
                {
                    <div class="hw-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <span>@erroHardware</span>
                        <button @onclick="() => erroHardware = null">×</button>
                    </div>
                }

                @* Botão principal *@
                <button class="btn-safe @BtnSafeClass()"
                        @onclick="OnClickCofre"
                        disabled="@(BloqueadoPorTransicao() || !arduinoConectado || aDetectarArduino)">
                    @if (estadoCofre == EstadoCofre.AAbrir)
                    {
                        <div class="btn-spinner"></div>
                        <span>A abrir...</span>
                    }
                    else if (estadoCofre == EstadoCofre.AFechar)
                    {
                        <div class="btn-spinner"></div>
                        <span>A fechar...</span>
                    }
                    else if (estadoCofre == EstadoCofre.Aberto)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <span>Trancar cofre</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                        </svg>
                        <span>Destrancar cofre</span>
                    }
                </button>
            </div>

            @* ── ADMIN ── *@
            @if (Estado.EhAdmin)
            {
                <button class="panel admin-panel"
                        @onclick="IrParaAdmin"
                        disabled="@BloqueadoPorTransicao()">
                    <div class="admin-left">
                        <div class="admin-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="admin-title">Painel Administrativo</p>
                            <p class="admin-sub">Gerir utilizadores e registos de acesso</p>
                        </div>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="admin-arrow">
                        <path d="M9 18l6-6-6-6" />
                    </svg>
                </button>
            }

            @* ── Dia 17: HISTÓRICO DE ACESSOS ── *@
            <div class="panel historico-panel">
                <div class="historico-header">
                    <div class="historico-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                    </div>
                    <h3 class="historico-titulo">Os meus últimos acessos</h3>
                </div>
                @if (_historico == null || _historico.Rows.Count == 0)
                {
                    <p class="historico-empty">Sem registos de acesso anteriores.</p>
                }
                else
                {
                    <div class="historico-table-wrap">
                        <table class="historico-table">
                            <thead>
                                <tr>
                                    <th>Data / Hora</th>
                                    <th>Ação</th>
                                    <th>Detalhes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (System.Data.DataRow row in _historico.Rows)
                                {
                                    <tr class="@GetCorHistorico(row["Acao"]?.ToString())">
                                        <td class="hist-data">@Convert.ToDateTime(row["DataHora"]).ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><span class="hist-badge @GetBadgeHistorico(row["Acao"]?.ToString())">@row["Acao"]</span></td>
                                        <td class="hist-det">@row["Detalhes"]</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </main>
</div>

@code {
    // Dia 20: foto de perfil
    private string? _fotoPerfil;

    // Estado local espelha o EstadoApp — sincronizado no OnInitialized
    private EstadoCofre estadoCofre = EstadoCofre.Fechado;
    private string? erroHardware = null;
    private bool mostrarPopupLogout = false;

    // Dia 17: Histórico de acessos do utilizador
    private System.Data.DataTable? _historico;

    private string GetCorHistorico(string? acao) => acao switch
    {
        "Login" => "hist-verde",
        "Acesso Negado" => "hist-vermelho",
        _ => ""
    };

    private string GetBadgeHistorico(string? acao) => acao switch
    {
        "Login" => "badge-verde",
        "Acesso Negado" => "badge-vermelho",
        _ => "badge-cinza"
    };

    private const int DURACAO_MOTOR_MS = 2500;

    // Porta COM detetada automaticamente no arranque — null se Arduino não encontrado
    private string? portaArduino = null;
    private bool arduinoConectado => portaArduino != null;
    private bool aDetectarArduino = false;

    // Instância persistente do hardware — mantida enquanto o cofre está aberto
    // para que o heartbeat continue a ser enviado ao Arduino
    private ControladorHardware? _hw = null;

    // Timer de monitorização da ligação — verifica a cada 3s se o Arduino ainda responde
    private Timer? _monitorTimer = null;
    private const int MONITOR_INTERVALO_MS = 3000;

    protected override async Task OnInitializedAsync()
    {
        // Dia 20: carregar foto de perfil em background
        if (Estado.UsuarioAtual != null)
        {
            _ = Task.Run(() =>
            {
                _fotoPerfil = BancoService.ObterPrimeiraFotoBase64(Estado.UsuarioAtual.Nome);
            }).ContinueWith(_ => InvokeAsync(StateHasChanged));
        }
        if (Estado.UsuarioAtual == null)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        // ── CORREÇÃO 1: restaurar estado real do cofre ao reentrar na página ──
        estadoCofre = Estado.EstadoCofreAtual switch
        {
            EstadoCofre.AAbrir or EstadoCofre.AFechar => EstadoCofre.Fechado,
            var s => s
        };
        Estado.EstadoCofreAtual = estadoCofre;

        // ── Deteção automática da porta COM do Arduino ──
        aDetectarArduino = true;
        StateHasChanged();

        portaArduino = await Task.Run(() => ControladorHardware.DetectarPortaArduino());

        aDetectarArduino = false;

        if (portaArduino == null)
            erroHardware = "Arduino não encontrado. O cofre físico não poderá ser operado.";

        // Inicia monitorização contínua da ligação
        IniciarMonitorLigacao();

        // Dia 17: carregar histórico de acessos do utilizador atual
        await Task.Run(() =>
            _historico = BancoService.ObterHistoricoUtilizador(Estado.UsuarioAtual!.Nome));

        StateHasChanged();
    }

    // ── CORREÇÃO 2: bloqueia TODOS os botões durante qualquer transição ──
    private bool BloqueadoPorTransicao() =>
        estadoCofre == EstadoCofre.AAbrir ||
        estadoCofre == EstadoCofre.AFechar ||
        mostrarPopupLogout;

    private async Task OnClickCofre()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Fechado)
            await Abrir();
        else if (estadoCofre == EstadoCofre.Aberto)
            await Fechar();
    }

    private async Task Abrir()
    {
        if (!arduinoConectado) return;

        SetEstado(EstadoCofre.AAbrir);
        erroHardware = null;

        bool sucesso = false;
        await Task.Run(() =>
        {
            try
            {
                _hw = new ControladorHardware(portaArduino!);
                _hw.Abrir();
                sucesso = true;
            }
            catch (Exception ex)
            {
                erroHardware = $"Hardware: {ex.Message}";
                _hw?.Dispose();
                _hw = null;
            }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        // Só avança para Aberto se o hardware respondeu — caso contrário volta a Fechado
        SetEstado(sucesso ? EstadoCofre.Aberto : EstadoCofre.Fechado);
        await InvokeAsync(StateHasChanged);
    }

    private async Task Fechar()
    {
        if (!arduinoConectado) return;

        SetEstado(EstadoCofre.AFechar);
        erroHardware = null;

        await Task.Run(() =>
        {
            try
            {
                if (_hw != null)
                {
                    // Para o heartbeat e envia 'F' — tudo dentro do Fechar()
                    _hw.Fechar();
                    _hw.Dispose();
                    _hw = null;
                }
                else
                {
                    // Fallback: se por algum motivo não há instância ativa, cria uma temporária
                    using var hwTemp = new ControladorHardware(portaArduino!);
                    hwTemp.Fechar();
                }
            }
            catch (Exception ex) { erroHardware = $"Hardware: {ex.Message}"; }
        });

        await Task.Delay(DURACAO_MOTOR_MS);
        SetEstado(EstadoCofre.Fechado);
        await InvokeAsync(StateHasChanged);
    }

    // Mantém estado local e partilhado em sincronia sempre
    private void SetEstado(EstadoCofre novo)
    {
        estadoCofre = novo;
        Estado.EstadoCofreAtual = novo;
    }

    // ── CORREÇÃO 3: Logout seguro — fecha o cofre antes de deslogar ──
    private async Task Logout()
    {
        if (BloqueadoPorTransicao()) return;

        if (estadoCofre == EstadoCofre.Aberto)
        {
            // Mostrar popup + executar animação de fecho
            mostrarPopupLogout = true;
            StateHasChanged();

            await Fechar();

            // Pequena pausa para o utilizador ver o estado "Fechado" antes de sair
            await Task.Delay(600);
        }

        Estado.Logout();
        Estado.EstadoCofreAtual = EstadoCofre.Fechado;
        Navigation.NavigateTo("/", replace: true);
    }

    // ── Monitorização contínua da ligação ────────────────────────────────────
    // Corre a cada 3s e verifica se o Arduino ainda responde ao ping 'P'.
    // Se o cabo for desligado durante o uso, a UI bloqueia imediatamente.
    private void IniciarMonitorLigacao()
    {
        _monitorTimer?.Dispose();
        _monitorTimer = new Timer(async _ =>
        {
            // Se o cofre está em transição ou o heartbeat já trata da ligação, não interferir
            if (BloqueadoPorTransicao() || estadoCofre == EstadoCofre.Aberto) return;

            bool estaLigado = await Task.Run(() =>
            {
                // Se já havia uma porta detetada, testa apenas essa — mais rápido
                if (portaArduino != null)
                    return ControladorHardware.PingPorta(portaArduino);

                // Se não havia porta, tenta detetar de novo (cabo pode ter sido ligado)
                string? novaPorta = ControladorHardware.DetectarPortaArduino();
                if (novaPorta != null)
                {
                    portaArduino = novaPorta;
                    return true;
                }
                return false;
            });

            bool mudou = estaLigado != arduinoConectado;

            if (!estaLigado)
                portaArduino = null;

            if (mudou)
            {
                // Quando desliga: mostra aviso. Quando reconecta: limpa o aviso.
                erroHardware = estaLigado
                    ? null
                    : "Ligação ao Arduino perdida. O cofre físico foi bloqueado.";
                await InvokeAsync(StateHasChanged);
            }
        },
        state: null,
        dueTime: MONITOR_INTERVALO_MS,
        period: MONITOR_INTERVALO_MS);
    }

    // Botão "Tentar novamente" — faz nova deteção completa a pedido do utilizador
    private async Task TentarNovamente()
    {
        aDetectarArduino = true;
        erroHardware = null;
        StateHasChanged();

        portaArduino = await Task.Run(() => ControladorHardware.DetectarPortaArduino());

        aDetectarArduino = false;

        if (portaArduino == null)
            erroHardware = "Arduino continua sem resposta. Verifica o cabo USB e tenta novamente.";

        // Reinicia o monitor — estava parado desde que a ligação foi perdida
        IniciarMonitorLigacao();

        StateHasChanged();
    }

    // ── Limpeza ao destruir a página ─────────────────────────────────────────
    public void Dispose()
    {
        _monitorTimer?.Dispose();
        _monitorTimer = null;
        _hw?.Dispose();
        _hw = null;
    }

    private void IrParaAdmin()
    {
        if (BloqueadoPorTransicao()) return;
        Navigation.NavigateTo("/admin");
    }

    // ── CSS helpers ──
    private string SafePanelClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "safe-panel--offline";
        return estadoCofre switch
        {
            EstadoCofre.Aberto => "safe-panel--open",
            EstadoCofre.AAbrir => "safe-panel--opening",
            EstadoCofre.AFechar => "safe-panel--closing",
            _ => ""
        };
    }

    private string VaultDoorClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "vault-door--offline";
        return estadoCofre switch
        {
            EstadoCofre.AAbrir => "vault-door--spinning-open",
            EstadoCofre.AFechar => "vault-door--spinning-close",
            EstadoCofre.Aberto => "vault-door--open",
            _ => ""
        };
    }

    private string VaultHandleClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "vault-handle--open",
        EstadoCofre.AAbrir => "vault-handle--turning",
        _ => ""
    };

    private string SafeStatusClass()
    {
        if (!arduinoConectado && !aDetectarArduino) return "status-offline";
        return estadoCofre switch
        {
            EstadoCofre.Aberto => "status-open",
            EstadoCofre.AAbrir or EstadoCofre.AFechar => "status-transitioning",
            _ => "status-closed"
        };
    }

    private string BtnSafeClass() => estadoCofre switch
    {
        EstadoCofre.Aberto => "btn-safe--lock",
        EstadoCofre.AAbrir or EstadoCofre.AFechar => "btn-safe--busy",
        _ => "btn-safe--unlock"
    };

    private string TextoEstado()
    {
        if (aDetectarArduino) return "A verificar...";
        if (!arduinoConectado) return "Sem ligação";
        return estadoCofre switch
        {
            EstadoCofre.AAbrir => "A abrir...",
            EstadoCofre.AFechar => "A fechar...",
            EstadoCofre.Aberto => "Desbloqueado",
            _ => "Bloqueado"
        };
    }

    private string ObterIniciais(string? nome)
    {
        if (string.IsNullOrEmpty(nome)) return "U";
        var p = nome.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1
            ? p[0][0].ToString().ToUpper()
            : (p[0][0].ToString() + p[^1][0].ToString()).ToUpper();
    }
}

