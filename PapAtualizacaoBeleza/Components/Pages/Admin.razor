@page "/admin"
@layout EmptyLayout
@rendermode InteractiveServer

@using System.Data
@using PapAtualizacaoBeleza
@inject NavigationManager Navigation
@inject EstadoApp Estado
@inject BaseSql BancoService
@inject TemaService Tema

<PageTitle>VaultFace — Admin</PageTitle>

<div class="page @(Tema.ModoEscuro ? "dark" : "")">

    @* ══════════════════════════════════════════
       TOPBAR
    ══════════════════════════════════════════ *@
    <header class="topbar">

        <div class="brand">
            <div class="brand-lock">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
            VaultFace
        </div>

        <div class="topbar-right">
            <button class="btn-tema" @onclick="Tema.Alternar" title="@(Tema.ModoEscuro ? "Modo claro" : "Modo escuro")">
                @if (Tema.ModoEscuro)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                }
            </button>
            <div class="admin-info">
                <div class="admin-avatar">@Estado.UsuarioAtual?.Nome?[0]</div>
                <div class="admin-meta">
                    <span class="admin-name">@Estado.UsuarioAtual?.Nome</span>
                    <span class="admin-role">@Estado.UsuarioAtual?.Permissao</span>
                </div>
            </div>
            <button class="btn-logout" @onclick="VoltarParaUserLogado">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sair
            </button>
        </div>

    </header>

    @* ══════════════════════════════════════════
       NAVEGAÇÃO LATERAL FLUTUANTE
    ══════════════════════════════════════════ *@
    <nav class="side-nav">

        <button class="nav-item @(abaAtiva == "dashboard" ? "nav-item--active" : "")"
                @onclick="@(() => MudarAba("dashboard"))">
            <div class="nav-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
            </div>
            <span class="nav-label">Dashboard</span>
        </button>

        <div class="nav-divider"></div>

        <button class="nav-item @(abaAtiva == "usuarios" ? "nav-item--active" : "")"
                @onclick="@(() => MudarAba("usuarios"))">
            <div class="nav-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
            </div>
            <span class="nav-label">Utilizadores</span>
            @if (listaUsuarios != null)
            {
                <span class="nav-badge">@listaUsuarios.Count</span>
            }
        </button>

        <div class="nav-divider"></div>

        <button class="nav-item @(abaAtiva == "logs" ? "nav-item--active" : "")"
                @onclick="@(() => MudarAba("logs"))">
            <div class="nav-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
            </div>
            <span class="nav-label">Auditoria</span>
            @if (tabelaLogs != null && tabelaLogs.Rows.Count > 0)
            {
                <span class="nav-badge nav-badge--alert">@tabelaLogs.Rows.Count</span>
            }
        </button>

        @if (IsMaster())
        {
            <div class="nav-divider"></div>
            <button class="nav-item nav-item--danger @(abaAtiva == "dangerzone" ? "nav-item--danger-active" : "")"
                    @onclick="@(() => MudarAba("dangerzone"))">
                <div class="nav-icon-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                </div>
                <span class="nav-label">Área Master</span>
            </button>
        }

    </nav>

    @* ══════════════════════════════════════════
       CONTEÚDO PRINCIPAL
    ══════════════════════════════════════════ *@
    <main class="main">

        @* ── Toast de Feedback ── *@
        @if (!string.IsNullOrEmpty(mensagemFeedback))
        {
            <div class="toast">
                <div class="toast-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                </div>
                <span>@mensagemFeedback</span>
                <button class="toast-close" @onclick="() => mensagemFeedback = null">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>
        }

        @* ══════════════════════════════════════════
           VIEW — UTILIZADORES
        ══════════════════════════════════════════ *@
        @* ── Dia 21: Dashboard ── *@
        <div class="view @(abaAtiva == "dashboard" ? "view--visible" : "view--hidden")">
            <div class="section-header"><div><h1 class="section-title">Dashboard</h1><p class="section-sub">Resumo dos últimos 7 dias de atividade.</p></div></div>
            @if (_dashStats == null) { <div class="loading-state"><div class="spinner"></div><p>A carregar...</p></div> }
            else
            {
                <div class="dash-kpis">
                    <div class="dash-kpi dash-kpi--blue"><div class="dash-kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><div class="dash-kpi-body"><span class="dash-kpi-val">@_dashStats.TotalAcessos</span><span class="dash-kpi-label">Acessos</span></div></div>
                    <div class="dash-kpi dash-kpi--red"><div class="dash-kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div><div class="dash-kpi-body"><span class="dash-kpi-val">@_dashStats.TentativasFalhadas</span><span class="dash-kpi-label">Tentativas falhadas</span></div></div>
                    <div class="dash-kpi dash-kpi--green"><div class="dash-kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="dash-kpi-body"><span class="dash-kpi-val">@(listaUsuarios?.Count ?? 0)</span><span class="dash-kpi-label">Utilizadores</span></div></div>
                    <div class="dash-kpi dash-kpi--purple"><div class="dash-kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="dash-kpi-body"><span class="dash-kpi-val">@_dashStats.HoraDePico<small>h</small></span><span class="dash-kpi-label">Hora de pico</span></div></div>
                </div>
                <div class="dash-grafico-card">
                    <div class="dash-grafico-header"><span class="dash-grafico-title">Acessos por dia</span><span class="dash-grafico-sub">Últimos 7 dias</span></div>
                    <div class="dash-grafico-wrap">@((MarkupString)GerarSvgDashboard())</div>
                </div>
                <div class="dash-bottom">
                    <div class="dash-card"><p class="dash-card-title">Utilizador mais ativo</p><div class="dash-user-ativo"><div class="dash-user-avatar">@(_dashStats.UtilizadorMaisAtivo.Substring(0,1).ToUpper())</div><span class="dash-user-nome">@_dashStats.UtilizadorMaisAtivo</span></div></div>
                    <div class="dash-card"><p class="dash-card-title">Novos cadastros (7 dias)</p><div class="dash-big-num">@_dashStats.TotalCadastros</div></div>
                    <div class="dash-card"><p class="dash-card-title">Taxa de sucesso</p><div class="dash-big-num dash-big-num--green">@(_dashStats.TotalAcessos + _dashStats.TentativasFalhadas == 0 ? "—" : $"{(int)(100.0 * _dashStats.TotalAcessos / (_dashStats.TotalAcessos + _dashStats.TentativasFalhadas))}%")</div></div>
                </div>
            }
        </div>

        <div class="view @(abaAtiva == "usuarios" ? "view--visible" : "view--hidden")">

            <div class="section-header">
                <div>
                    <h1 class="section-title">Utilizadores</h1>
                    <p class="section-sub">Gerencie os operadores do sistema.</p>
                </div>
                <button class="btn-primary" @onclick="IrParaCadastro">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Novo Operador
                </button>
            </div>

            <div class="card">

                <div class="toolbar">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                        <input type="text"
                               placeholder="Pesquisar utilizador..."
                               @bind="termoPesquisa"
                               @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(termoPesquisa))
                        {
                            <button class="search-clear"
                                    @onclick='() => { termoPesquisa = ""; paginaUsuarios = 1; }'>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                        }
                    </div>
                    <span class="result-count">
                        @UtilizadoresFiltrados().Count resultado@(UtilizadoresFiltrados().Count != 1 ? "s" : "")
                    </span>
                </div>

                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Operador</th>
                                <th>Nível de Acesso</th>
                                <th>Identificador</th>
                                <th class="th-right">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (listaUsuarios == null)
                            {
                                <tr>
                                    <td colspan="4" class="cell-loading">
                                        <div class="spinner"></div>
                                        <span>A carregar dados...</span>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                var paginados = UtilizadoresFiltrados()
                                .Skip((paginaUsuarios - 1) * ITENS_POR_PAGINA)
                                .Take(ITENS_POR_PAGINA)
                                .ToList();

                                if (!paginados.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="cell-empty">Nenhum utilizador encontrado.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var user in paginados)
                                    {
                                        bool isSuperAdmin = IsUserSuperAdmin(user);
                                        bool isMe = user.Id == Estado.UsuarioAtual?.Id;

                                        <tr>
                                            <td>
                                                <div class="user-cell">
                                                    <div class="u-avatar @(isSuperAdmin ? "u-avatar--gold" : "")">
                                                        @user.Nome[0].ToString().ToUpper()
                                                    </div>
                                                    <div>
                                                        <span class="u-name">@user.Nome</span>
                                                        @if (isSuperAdmin)
                                                        {
                                                            <span class="badge-master">MASTER</span>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="perm-badge @ObterClassePermissao(user.Permissao)">
                                                    @user.Permissao
                                                </span>
                                            </td>
                                            <td class="td-mono">ID #@user.Id.ToString("D4")</td>
                                            <td class="th-right">
                                                <div class="action-group">
                                                    @if (!isMe && !isSuperAdmin)
                                                    {
                                                        <button class="btn-icon"
                                                                @onclick="() => AbrirModalEdicao(user)"
                                                                title="Gerir permissões">
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                                                <circle cx="12" cy="12" r="3" />
                                                                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
                                                            </svg>
                                                        </button>
                                                        <button class="btn-icon btn-icon--danger"
                                                                @onclick="() => SolicitarExclusao(user)"
                                                                title="Excluir">
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                                                <polyline points="3 6 5 6 21 6" />
                                                                <path d="M19 6l-1 14H6L5 6" />
                                                                <path d="M9 6V4h6v2" />
                                                            </svg>
                                                        </button>
                                                    }
                                                    else if (isMe)
                                                    {
                                                        <span class="td-label">Você</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="td-label">Protegido</span>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @{
                    int totalU = (int)Math.Ceiling((double)UtilizadoresFiltrados().Count / ITENS_POR_PAGINA);
                }
                @if (totalU > 1)
                {
                    <div class="pagination">
                        <button class="page-btn"
                                disabled="@(paginaUsuarios == 1)"
                                @onclick="() => paginaUsuarios--">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                                <polyline points="15 18 9 12 15 6" />
                            </svg>
                        </button>

                        @for (int i = 1; i <= totalU; i++)
                        {
                            int pg = i;
                            <button class="page-btn @(paginaUsuarios == pg ? "page-btn--active" : "")"
                                    @onclick="() => paginaUsuarios = pg">
                                @pg
                            </button>
                        }

                        <button class="page-btn"
                                disabled="@(paginaUsuarios == totalU)"
                                @onclick="() => paginaUsuarios++">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </button>

                        <span class="page-info">Página @paginaUsuarios de @totalU</span>
                    </div>
                }

            </div>
        </div>

        @* ══════════════════════════════════════════
           VIEW — LOGS / AUDITORIA
        ══════════════════════════════════════════ *@
        <div class="view @(abaAtiva == "logs" ? "view--visible" : "view--hidden")">
            @{
                var todosLogs = LogsFiltrados().ToList();
                int totalL = (int)Math.Ceiling((double)todosLogs.Count / ITENS_POR_PAGINA);
            }

            @* ── Stat Cards ── *@
            <div class="stats-row">

                <button class="stat-card @(filtroTipoAcao == "" ? "stat-card--active" : "")"
                        @onclick='() => { filtroTipoAcao = ""; paginaLogs = 1; }'>
                    <span class="stat-icon stat-icon--all">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                        </svg>
                    </span>
                    <div class="stat-body">
                        <span class="stat-num">@(tabelaLogs?.Rows.Count ?? 0)</span>
                        <span class="stat-label">Todos</span>
                    </div>
                </button>

                <button class="stat-card @(filtroTipoAcao == "Criação" ? "stat-card--active stat-card--green" : "")"
                        @onclick='() => { filtroTipoAcao = "Criação"; paginaLogs = 1; }'>
                    <span class="stat-icon stat-icon--green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <line x1="20" y1="8" x2="20" y2="14" />
                            <line x1="23" y1="11" x2="17" y2="11" />
                        </svg>
                    </span>
                    <div class="stat-body">
                        <span class="stat-num">@ContarTipo("Criação")</span>
                        <span class="stat-label">Criações</span>
                    </div>
                </button>

                <button class="stat-card @(filtroTipoAcao == "Cadastro" ? "stat-card--active stat-card--blue" : "")"
                        @onclick='() => { filtroTipoAcao = "Cadastro"; paginaLogs = 1; }'>
                    <span class="stat-icon stat-icon--blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </span>
                    <div class="stat-body">
                        <span class="stat-num">@ContarTipo("Cadastro")</span>
                        <span class="stat-label">Biometrias</span>
                    </div>
                </button>

                <button class="stat-card @(filtroTipoAcao == "Alteração" ? "stat-card--active stat-card--amber" : "")"
                        @onclick='() => { filtroTipoAcao = "Alteração"; paginaLogs = 1; }'>
                    <span class="stat-icon stat-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                    </span>
                    <div class="stat-body">
                        <span class="stat-num">@ContarTipo("Alteração")</span>
                        <span class="stat-label">Alterações</span>
                    </div>
                </button>

                <button class="stat-card @(filtroTipoAcao == "Exclusão" ? "stat-card--active stat-card--red" : "")"
                        @onclick='() => { filtroTipoAcao = "Exclusão"; paginaLogs = 1; }'>
                    <span class="stat-icon stat-icon--red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14H6L5 6" />
                            <path d="M9 6V4h6v2" />
                        </svg>
                    </span>
                    <div class="stat-body">
                        <span class="stat-num">@ContarTipo("Exclusão")</span>
                        <span class="stat-label">Exclusões</span>
                    </div>
                </button>

            </div>

            <div class="section-header">
                <div>
                    <h1 class="section-title">
                        @if (!string.IsNullOrEmpty(filtroTipoAcao))
                        {
                            <span class="filter-chip">@filtroTipoAcao</span>
                        }
                        else
                        {
                            <text>Auditoria & Logs</text>
                        }
                    </h1>
                    <p class="section-sub">
                        @todosLogs.Count registo@(todosLogs.Count != 1 ? "s" : "")
                        encontrado@(todosLogs.Count != 1 ? "s" : "")
                    </p>
                </div>
                @if (!string.IsNullOrEmpty(filtroTipoAcao) ||
                                !string.IsNullOrEmpty(termoPesquisa) ||
                                filtroDataInicio.HasValue ||
                                filtroDataFim.HasValue)
                {
                    <button class="btn-clear" @onclick="LimparFiltros">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                        Limpar filtros
                    </button>
                }
            </div>

            <div class="card">

                <div class="toolbar toolbar--logs">
                    <div class="search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                        <input type="text"
                               placeholder="Pesquisar utilizador ou detalhe..."
                               @bind="termoPesquisa"
                               @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(termoPesquisa))
                        {
                            <button class="search-clear"
                                    @onclick='() => { termoPesquisa = ""; paginaLogs = 1; }'>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                        }
                    </div>
                    <div class="date-group">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="13" height="13" class="date-icon">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        <input type="date" @bind="filtroDataInicio" />
                        <span class="date-sep">→</span>
                        <input type="date" @bind="filtroDataFim" />
                    </div>
                </div>

                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width:110px">Horário</th>
                                <th style="width:150px">Utilizador</th>
                                <th style="width:150px">Tipo</th>
                                <th>Ocorrência</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var logsPaginados = todosLogs
                                .Skip((paginaLogs - 1) * ITENS_POR_PAGINA)
                                .Take(ITENS_POR_PAGINA)
                                .ToList();
                            }
                            @if (!logsPaginados.Any())
                            {
                                <tr>
                                    <td colspan="4" class="cell-empty">Nenhum registo encontrado.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (DataRow row in logsPaginados)
                                {
                                    string tipo = row["Acao"].ToString() ?? "";

                                    <tr class="@ObterClasseLinha(tipo)">
                                        <td class="td-mono">
                                            @Convert.ToDateTime(row["DataHora"]).ToString("dd/MM HH:mm")
                                        </td>
                                        <td>
                                            <div class="log-user-cell">
                                                <div class="log-dot @(row["Usuario"].ToString() == "Sistema" ? "dot-system" : "dot-user")">
                                                </div>
                                                <span class="u-name">@row["Usuario"]</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="type-badge @ObterClasseBadgeLog(tipo)">@tipo</span>
                                        </td>
                                        <td class="td-detail">@row["Detalhes"]</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @if (totalL > 1)
                {
                    int ini = Math.Max(1, paginaLogs - 2);
                    int fim = Math.Min(totalL, paginaLogs + 2);

                    <div class="pagination">
                        <button class="page-btn"
                                disabled="@(paginaLogs == 1)"
                                @onclick="() => paginaLogs--">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                                <polyline points="15 18 9 12 15 6" />
                            </svg>
                        </button>

                        @if (ini > 1)
                        {
                            <button class="page-btn" @onclick="() => paginaLogs = 1">1</button>
                        }
                        @if (ini > 2)
                        {
                            <span class="page-ellipsis">…</span>
                        }

                        @for (int i = ini; i <= fim; i++)
                        {
                            int pg = i;
                            <button class="page-btn @(paginaLogs == pg ? "page-btn--active" : "")"
                                    @onclick="() => paginaLogs = pg">
                                @pg
                            </button>
                        }

                        @if (fim < totalL - 1)
                        {
                            <span class="page-ellipsis">…</span>
                        }
                        @if (fim < totalL)
                        {
                            <button class="page-btn" @onclick="() => paginaLogs = totalL">@totalL</button>
                        }

                        <button class="page-btn"
                                disabled="@(paginaLogs == totalL)"
                                @onclick="() => paginaLogs++">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </button>

                        <span class="page-info">
                            @((paginaLogs - 1) * ITENS_POR_PAGINA + 1)–@(Math.Min(paginaLogs * ITENS_POR_PAGINA, todosLogs.Count))
                            de @todosLogs.Count
                        </span>
                    </div>
                }

            </div>
        </div>

        @* ══ VIEW — ZONA RESTRITA (apenas master) ══ *@
        <div class="view @(abaAtiva == "dangerzone" ? "view--visible" : "view--hidden")">

            <div class="section-header">
                <div>
                    <h1 class="section-title">Área Master</h1>
                    <p class="section-sub">Configurações e ferramentas exclusivas do Administrador Master.</p>
                </div>
            </div>

            @* Botão de acesso aos relatórios *@
            <div class="relatorios-card">
                <div class="relatorios-card-left">
                    <div class="relatorios-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <line x1="3" y1="9" x2="21" y2="9" />
                            <line x1="9" y1="21" x2="9" y2="9" />
                        </svg>
                    </div>
                    <div>
                        <p class="relatorios-card-title">Relatórios de Acessos</p>
                        <p class="relatorios-card-sub">Consulte estatísticas, filtre eventos por período, veja os logs detalhados e exporte relatórios em PDF.</p>
                    </div>
                </div>
                <button class="btn-relatorios" @onclick='() => Navigation.NavigateTo("/relatorios")'>
                    Ver Relatórios
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </button>
            </div>

            @* Alerta de aviso no topo *@
            @* ── Dia 18: PIN de Emergência ── *@
            <div class="pin-admin-card">
                <div class="pin-admin-left">
                    <div class="pin-admin-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <rect x="3" y="11" width="18" height="11" rx="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            <line x1="12" y1="15" x2="12" y2="17"/>
                        </svg>
                    </div>
                    <div>
                        <p class="pin-admin-title">PIN de Emergência</p>
                        <p class="pin-admin-sub">PIN gerado automaticamente no primeiro cadastro. Para alterar, confirme o PIN atual.</p>
                    </div>
                </div>
                <div class="pin-admin-right">
                    @if (!_mostrarFormPin)
                    {
                        <span class="pin-status pin-status--ativo">● PIN ativo</span>
                        <button class="btn-pin-admin" @onclick="() => { _mostrarFormPin = true; _pinErroAtual = false; }">
                            Alterar PIN
                        </button>
                    }
                    else
                    {
                        <div class="pin-form">
                            <input class="pin-input-admin @(_pinErroAtual ? "pin-input--erro" : "")"
                                   type="password" inputmode="numeric" maxlength="6"
                                   placeholder="PIN atual (6 dígitos)"
                                   @bind="_pinAtualAdmin" @bind:event="oninput" />
                            <input class="pin-input-admin" type="password" inputmode="numeric"
                                   maxlength="6" placeholder="Novo PIN (6 dígitos)"
                                   @bind="_novoPinAdmin" @bind:event="oninput" />
                            <input class="pin-input-admin" type="password" inputmode="numeric"
                                   maxlength="6" placeholder="Confirmar novo PIN"
                                   @bind="_confirmarPinAdmin" @bind:event="oninput" />
                            <div class="pin-form-btns">
                                <button class="btn-pin-guardar"
                                        disabled="@(_pinAtualAdmin.Length < 6 || _novoPinAdmin.Length < 6 || _novoPinAdmin != _confirmarPinAdmin)"
                                        @onclick="GuardarPin">Guardar</button>
                                <button class="btn-pin-cancelar" @onclick="CancelarFormPin">Cancelar</button>
                            </div>
                            @if (_pinErroAtual)
                            { <p class="pin-hint pin-hint--erro">PIN atual incorreto.</p> }
                            @if (_novoPinAdmin.Length > 0 && _novoPinAdmin.Length < 6)
                            { <p class="pin-hint">O novo PIN deve ter exatamente 6 dígitos.</p> }
                            @if (_novoPinAdmin.Length == 6 && _confirmarPinAdmin.Length == 6 && _novoPinAdmin != _confirmarPinAdmin)
                            { <p class="pin-hint pin-hint--erro">Os PINs não coincidem.</p> }
                            @if (_pinGuardadoOk)
                            { <p class="pin-hint pin-hint--ok">✓ PIN alterado com sucesso!</p> }
                        </div>
                    }
                </div>
            </div>

            @* ── Email Notificações ── *@
            <div class="master-card">
                <div class="master-card-left">
                    <div class="master-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <div>
                        <p class="master-card-title">Notificações por Email</p>
                        <p class="master-card-sub">Receber email sempre que alguém acede ao cofre com sucesso.</p>
                    </div>
                </div>
                <div class="master-card-right">
                    <button class="btn-toggle @(_emailNotificacoesAtivo ? "btn-toggle--on" : "btn-toggle--off")"
                            @onclick="ToggleEmailNotificacoes">
                        <span class="toggle-knob"></span>
                    </button>
                    <span class="toggle-label">@(_emailNotificacoesAtivo ? "Ativo" : "Inativo")</span>
                </div>
            </div>

            @* Separador visual para as ações destrutivas *@
            <div class="zona-risco-header">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" style="color:var(--red);flex-shrink:0;">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <span class="zona-risco-label">Ações Irreversíveis</span>
                <div class="zona-risco-line"></div>
            </div>

            @* ── Ação 1: Reset total ── *@
            <div class="danger-card">
                <div class="danger-card-left">
                    <div class="danger-card-icon danger-card-icon--red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14H6L5 6" />
                            <path d="M9 6V4h6v2" />
                        </svg>
                    </div>
                    <div>
                        <p class="danger-card-title">Resetar Sistema</p>
                        <p class="danger-card-sub">
                            Remove todos os utilizadores e biometrias registadas, exceto a sua própria conta master.
                            O sistema voltará ao estado inicial.
                        </p>
                    </div>
                </div>
                @if (confirmarReset)
                {
                    <div class="danger-confirm-group">
                        <span class="danger-confirm-label">Tem a certeza absoluta?</span>
                        <button class="btn-danger-action" @onclick="ExecutarReset" disabled="@executandoAcao">
                            @if (executandoAcao && acaoAtiva == "reset")
                            {
                                <span class="btn-spinner-sm"></span>
                                <span>A resetar...</span>
                            }
                            else
                            {
                                <span>Sim, resetar tudo</span>
                            }
                        </button>
                        <button class="btn-danger-cancel" @onclick="@(() => confirmarReset = false)">Cancelar</button>
                    </div>
                }
                else
                {
                    <button class="btn-danger-outline" @onclick="@(() => confirmarReset = true)" disabled="@executandoAcao">
                        Resetar sistema
                    </button>
                }
            </div>

            @* ── Ação 2: Transferir Master ── *@
            <div class="danger-card">
                <div class="danger-card-left">
                    <div class="danger-card-icon danger-card-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <polyline points="23 11 17 11" />
                            <polyline points="20 8 23 11 20 14" />
                        </svg>
                    </div>
                    <div>
                        <p class="danger-card-title">Transferir Admin Master</p>
                        <p class="danger-card-sub">
                            Transfere o nível Master para outro utilizador. Você ficará como Admin comum
                            e perderá o acesso a esta secção.
                        </p>
                    </div>
                </div>
                <button class="btn-danger-outline btn-danger-outline--amber"
                        @onclick="AbrirModalTransferencia"
                        disabled="@executandoAcao">
                    Escolher utilizador
                </button>
            </div>

        </div>

    </main>
</div>

@* ══════════════════════════════════════════
   MODAL — EDIÇÃO DE PERMISSÃO
══════════════════════════════════════════ *@
@if (modalVisivel && usuarioEmEdicao != null)
{
    <div class="modal-overlay">
        <div class="modal-box">

            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
                        </svg>
                    </div>
                    <div>
                        <h3>Gerir Acesso</h3>
                        <p>@usuarioEmEdicao.Nome</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="FecharModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <div class="modal-body">
                <label class="form-label">Nível de Permissão</label>
                <select class="form-sel" @bind="novaPermissaoSelecionada">
                    @foreach (var item in Enum.GetValues(typeof(NivelPermissao)))
                    {
                        if (item.ToString() == "AdminSupremo") continue;
                        <option value="@item">@item</option>
                    }
                </select>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="FecharModal">Cancelar</button>
                <button class="btn-primary" @onclick="SalvarPermissao">Guardar alterações</button>
            </div>

        </div>
    </div>
}

@* ══════════════════════════════════════════
   MODAL — CONFIRMAÇÃO DE EXCLUSÃO
══════════════════════════════════════════ *@
@if (modalExclusaoVisivel && usuarioParaExcluir != null)
{
    <div class="modal-overlay">
        <div class="modal-box modal-box--danger">

            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon modal-icon--danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14H6L5 6" />
                            <path d="M9 6V4h6v2" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="danger-title">Confirmar Exclusão</h3>
                        <p>@usuarioParaExcluir.Nome</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="FecharModalExclusao">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <div class="modal-body">
                <div class="warning-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    <span>Esta ação é irreversível e revogará o acesso imediatamente.</span>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="FecharModalExclusao">Cancelar</button>
                <button class="btn-danger" @onclick="ConfirmarExclusaoDefinitiva">Sim, excluir</button>
            </div>

        </div>
    </div>
}

@* ══════════════════════════════════════════
   MODAL — ESCOLHER NOVO MASTER
══════════════════════════════════════════ *@
@if (modalTransferenciaVisivel)
{
    <div class="modal-overlay" @onclick="FecharModalTransferencia">
        <div class="modal-transfer" @onclick:stopPropagation="true">

            @* Cabeçalho *@
            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon modal-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <polyline points="23 11 17 11" />
                            <polyline points="20 8 23 11 20 14" />
                        </svg>
                    </div>
                    <div>
                        <h3>Escolher Novo Master</h3>
                        <p>Selecione o utilizador que receberá o nível AdminSupremo</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="FecharModalTransferencia">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            @* Pesquisa *@
            <div class="mt-search-bar">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text"
                       placeholder="Pesquisar utilizador..."
                       @bind="termoPesquisaTransferencia"
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(termoPesquisaTransferencia))
                {
                    <button class="search-clear" @onclick="@(() => termoPesquisaTransferencia = "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                }
            </div>

            @* Lista de utilizadores *@
            <div class="mt-list">
                @{
                    var candidatos = UtilizadoresFiltradosTransferencia();
                }
                @if (!candidatos.Any())
                {
                    <div class="mt-empty">Nenhum utilizador encontrado.</div>
                }
                else
                {
                    @foreach (var u in candidatos)
                    {
                        bool selecionado = idNovoMasterSelecionado == u.Id;
                        <div class="mt-row @(selecionado ? "mt-row--selected" : "")">
                            <div class="mt-row-left">
                                <div class="u-avatar @(u.Permissao == NivelPermissao.AdminComum ? "u-avatar--admin" : "")">
                                    @u.Nome[0].ToString().ToUpper()
                                </div>
                                <div>
                                    <span class="u-name">@u.Nome</span>
                                    <span class="perm-badge @ObterClassePermissao(u.Permissao)" style="margin-top:3px;">@u.Permissao</span>
                                </div>
                            </div>
                            <div class="mt-row-right">
                                <span class="td-mono">ID #@u.Id.ToString("D4")</span>
                                @if (selecionado)
                                {
                                    // utilizador já selecionado — mostra tick e botão de confirmar
                                    <span class="mt-selected-badge">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                                            <polyline points="20 6 9 17 4 12" />
                                        </svg>
                                        Selecionado
                                    </span>
                                }
                                else
                                {
                                    <button class="btn-mt-escolher" @onclick="@(() => idNovoMasterSelecionado = u.Id)">
                                        Escolher
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @* Rodapé com confirmação final *@
            <div class="mt-footer">
                @if (idNovoMasterSelecionado != 0)
                {
                    var escolhido = listaUsuarios?.FirstOrDefault(u => u.Id == idNovoMasterSelecionado);
                    <div class="mt-footer-info">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="flex-shrink:0;color:var(--amber);">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                            <line x1="12" y1="9" x2="12" y2="13" />
                            <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>
                        <span>Transferir Master para <strong>@escolhido?.Nome</strong>? Esta ação não pode ser desfeita.</span>
                    </div>
                }
                <div class="mt-footer-btns">
                    <button class="btn-cancel" @onclick="FecharModalTransferencia">Cancelar</button>
                    <button class="btn-danger-action btn-danger-action--amber"
                            @onclick="ExecutarTransferencia"
                            disabled="@(idNovoMasterSelecionado == 0 || executandoAcao)">
                        @if (executandoAcao && acaoAtiva == "transferencia")
                        {
                            <span class="btn-spinner-sm"></span>
                            <span>A transferir...</span>
                        }
                        else
                        {
                            <span>Confirmar transferência</span>
                        }
                    </button>
                </div>
            </div>

        </div>
    </div>
}

@* ══════════════════════════════════════════
   CODE-BEHIND
══════════════════════════════════════════ *@
@code {

    // ── Dia 21: Dashboard ─────────────────────────────────────────────────────
    private EstatisticasRelatorio? _dashStats;
    private List<(DateTime Dia, int Total)> _dashGrafico = new();

    private string GerarSvgDashboard()
    {
        int largura = 7 * 52; const int H = 100;
        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg class=\"dash-svg\" viewBox=\"0 0 {largura} 140\" preserveAspectRatio=\"xMinYMid meet\">");
        for (int gl = 0; gl <= 2; gl++) { int yg = 20 + (int)(H / 2.0 * gl); sb.Append($"<line x1=\"0\" y1=\"{yg}\" x2=\"{largura}\" y2=\"{yg}\" stroke=\"#e5e9f2\" stroke-width=\"0.5\"/>"); }
        var dias = new List<(DateTime Dia, int Total)>();
        for (int d = 6; d >= 0; d--) dias.Add((DateTime.Today.AddDays(-d), 0));
        foreach (var (dia, total) in _dashGrafico) { var idx = dias.FindIndex(x => x.Dia.Date == dia.Date); if (idx >= 0) dias[idx] = (dia, total); }
        int maxVal = dias.Max(x => x.Total); if (maxVal == 0) maxVal = 1;
        int gx = 0;
        foreach (var (dia, total) in dias)
        {
            int altPx = (int)(total / (double)maxVal * H); int gy = H - altPx + 20;
            string fill = dia.Date == DateTime.Today ? "#1F3864" : "#2E74B5";
            sb.Append($"<rect x=\"{gx + 10}\" y=\"{gy}\" width=\"32\" height=\"{altPx}\" fill=\"{fill}\" rx=\"4\" opacity=\"0.85\"/>");
            if (total > 0) sb.Append($"<text x=\"{gx + 26}\" y=\"{gy - 4}\" text-anchor=\"middle\" font-size=\"9\" fill=\"{fill}\" font-weight=\"700\">{total}</text>");
            sb.Append($"<text x=\"{gx + 26}\" y=\"133\" text-anchor=\"middle\" font-size=\"8\" fill=\"#aaa\">{(dia.Date == DateTime.Today ? "Hoje" : dia.ToString("dd/MM"))}</text>");
            gx += 52;
        }
        sb.Append("</svg>"); return sb.ToString();
    }

    // ── Email Notificações ────────────────────────────────────────────────────
    private bool _emailNotificacoesAtivo = true;

    private void ToggleEmailNotificacoes()
    {
        _emailNotificacoesAtivo = !_emailNotificacoesAtivo;
        BancoService.DefinirEmailNotificacoes(_emailNotificacoesAtivo);
    }

    // ── Dia 18: PIN de Emergência ─────────────────────────────────────────────
    private bool _mostrarFormPin = false;
    private string _pinAtualAdmin = "";
    private string _novoPinAdmin = "";
    private string _confirmarPinAdmin = "";
    private bool _pinGuardadoOk = false;
    private bool _pinErroAtual = false;

    private void GuardarPin()
    {
        if (!BancoService.VerificarPinEmergencia(_pinAtualAdmin))
        {
            _pinErroAtual = true;
            _pinAtualAdmin = "";
            return;
        }
        if (_novoPinAdmin.Length == 6 && _novoPinAdmin == _confirmarPinAdmin && _novoPinAdmin.All(char.IsDigit))
        {
            BancoService.DefinirPinEmergencia(_novoPinAdmin);
            _pinGuardadoOk = true;
            _pinAtualAdmin = _novoPinAdmin = _confirmarPinAdmin = "";
            _pinErroAtual = false;
            _ = Task.Delay(1500).ContinueWith(_ => InvokeAsync(() =>
            {
                _mostrarFormPin = false;
                _pinGuardadoOk = false;
                StateHasChanged();
            }));
        }
    }

    private void CancelarFormPin()
    {
        _mostrarFormPin = false;
        _pinAtualAdmin = _novoPinAdmin = _confirmarPinAdmin = "";
        _pinGuardadoOk = false;
        _pinErroAtual = false;
    }

    // ── Estado da UI ──────────────────────────────────────
    private string abaAtiva = "usuarios";
    private string termoPesquisa = "";
    private string filtroTipoAcao = "";
    private string? mensagemFeedback;

    private DateTime? filtroDataInicio;
    private DateTime? filtroDataFim;

    // ── Dados ─────────────────────────────────────────────
    private List<Usuario>? listaUsuarios = null;
    private DataTable tabelaLogs = new();

    // ── Modais ────────────────────────────────────────────
    private bool modalVisivel = false;
    private Usuario? usuarioEmEdicao;
    private NivelPermissao novaPermissaoSelecionada;

    private bool modalExclusaoVisivel = false;
    private Usuario? usuarioParaExcluir;

    // ── Paginação ─────────────────────────────────────────
    private const int ITENS_POR_PAGINA = 10;
    private int paginaUsuarios = 1;
    private int paginaLogs = 1;

    // ── Ciclo de vida ─────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        if (!Estado.EstadoLogado || !Estado.EhAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        await Task.Yield();
        _emailNotificacoesAtivo = BancoService.ObterEmailNotificacoes();
        listaUsuarios = BancoService.ObterUsuariosComRostos() ?? new List<Usuario>();
        tabelaLogs = BancoService.ObterLogs() ?? new DataTable();
        var _ini = DateTime.Today.AddDays(-6);
        _dashStats  = BancoService.ObterEstatisticasPeriodo(_ini, DateTime.Now);
        _dashGrafico = BancoService.ObterAcessosPorDia(_ini, DateTime.Now);
        StateHasChanged();
    }

    // ── Navegação de abas ─────────────────────────────────

    private void MudarAba(string aba)
    {
        abaAtiva = aba;
        termoPesquisa = "";
        mensagemFeedback = null;
        paginaUsuarios = 1;
        paginaLogs = 1;
        _ = CarregarDados();
    }

    private void LimparFiltros()
    {
        filtroTipoAcao = "";
        termoPesquisa = "";
        filtroDataInicio = null;
        filtroDataFim = null;
        paginaLogs = 1;
    }

    // ── Filtragem ─────────────────────────────────────────

    private List<Usuario> UtilizadoresFiltrados()
    {
        if (listaUsuarios == null) return new List<Usuario>();

        return listaUsuarios
            .Where(u => string.IsNullOrEmpty(termoPesquisa) ||
                        u.Nome.Contains(termoPesquisa, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private IEnumerable<DataRow> LogsFiltrados()
    {
        if (tabelaLogs == null || tabelaLogs.Rows.Count == 0)
            return new List<DataRow>();

        var rows = tabelaLogs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(termoPesquisa))
        {
            string t = termoPesquisa.ToLower();
            rows = rows.Where(r =>
                r.Field<string>("Usuario").ToLower().Contains(t) ||
                r.Field<string>("Detalhes").ToLower().Contains(t));
        }

        if (!string.IsNullOrWhiteSpace(filtroTipoAcao))
            rows = rows.Where(r =>
                r.Field<string>("Acao").Contains(filtroTipoAcao, StringComparison.OrdinalIgnoreCase));

        if (filtroDataInicio.HasValue)
            rows = rows.Where(r => r.Field<DateTime>("DataHora").Date >= filtroDataInicio.Value.Date);

        if (filtroDataFim.HasValue)
            rows = rows.Where(r => r.Field<DateTime>("DataHora").Date <= filtroDataFim.Value.Date);

        return rows.OrderByDescending(r => r.Field<DateTime>("DataHora"));
    }

    private int ContarTipo(string tipo)
    {
        if (tabelaLogs == null || tabelaLogs.Rows.Count == 0) return 0;

        return tabelaLogs.AsEnumerable()
            .Count(r => r.Field<string>("Acao").Contains(tipo, StringComparison.OrdinalIgnoreCase));
    }

    // ── Helpers de CSS ────────────────────────────────────

    private string ObterClasseBadgeLog(string tipo)
    {
        if (tipo.Contains("Exclusão")) return "type-red";
        if (tipo.Contains("Alteração")) return "type-amber";
        if (tipo.Contains("Cadastro")) return "type-blue";
        if (tipo.Contains("Criação")) return "type-green";
        return "type-gray";
    }

    private string ObterClasseLinha(string tipo)
    {
        if (tipo.Contains("Exclusão")) return "row-danger";
        if (tipo.Contains("Alteração")) return "row-warning";
        return "";
    }

    private string ObterClassePermissao(NivelPermissao p) => p.ToString() switch
    {
        "AdminSupremo" => "perm-master",
        "Admin" => "perm-admin",
        _ => "perm-user"
    };

    // ── Modal — Edição ────────────────────────────────────

    private void AbrirModalEdicao(Usuario u)
    {
        usuarioEmEdicao = u;
        novaPermissaoSelecionada = u.Permissao;
        modalVisivel = true;
    }

    private void FecharModal()
    {
        modalVisivel = false;
        usuarioEmEdicao = null;
    }

    private void SalvarPermissao()
    {
        if (usuarioEmEdicao != null && usuarioEmEdicao.Permissao != novaPermissaoSelecionada)
        {
            BancoService.AtualizarPermissao(usuarioEmEdicao.Id, novaPermissaoSelecionada);
            BancoService.RegistrarLog(
                Estado.UsuarioAtual.Nome ?? "Admin",
                "Alteração de Nível",
                $"Mudou {usuarioEmEdicao.Nome} de {usuarioEmEdicao.Permissao} para {novaPermissaoSelecionada}");

            ExibirFeedback($"Permissão de {usuarioEmEdicao.Nome} atualizada.");
            _ = CarregarDados();
        }

        FecharModal();
    }

    // ── Modal — Exclusão ──────────────────────────────────

    private void SolicitarExclusao(Usuario u)
    {
        if (IsUserSuperAdmin(u)) return;
        usuarioParaExcluir = u;
        modalExclusaoVisivel = true;
    }

    private void FecharModalExclusao()
    {
        modalExclusaoVisivel = false;
        usuarioParaExcluir = null;
    }

    private void ConfirmarExclusaoDefinitiva()
    {
        if (usuarioParaExcluir != null)
        {
            BancoService.RemoverUsuario(usuarioParaExcluir.Id);
            BancoService.RegistrarLog(
                Estado.UsuarioAtual.Nome ?? "Admin",
                "Exclusão",
                $"Removeu {usuarioParaExcluir.Nome} (ID: {usuarioParaExcluir.Id})");

            ExibirFeedback($"Utilizador {usuarioParaExcluir.Nome} removido.");
            _ = CarregarDados();
        }

        FecharModalExclusao();
    }

    // ── Utilitários ───────────────────────────────────────

    private async void ExibirFeedback(string msg)
    {
        mensagemFeedback = msg;
        StateHasChanged();
        await Task.Delay(3500);
        mensagemFeedback = null;
        StateHasChanged();
    }

    private void IrParaCadastro() => Navigation.NavigateTo("/cadastro");
    private void VoltarParaUserLogado() => Navigation.NavigateTo("/UserLogado");

    private bool IsUserSuperAdmin(Usuario u) =>
        u != null &&
        (u.Nome.Trim().ToLower() == "guilherme" ||
         u.Permissao.ToString() == "AdminSupremo");

    // verifica se o utilizador atual é o master
    private bool IsMaster() =>
        Estado.UsuarioAtual?.Permissao == NivelPermissao.AdminSupremo;

    // estado da zona restrita
    private bool confirmarReset = false;
    private bool executandoAcao = false;
    private string acaoAtiva = "";
    private int idNovoMasterSelecionado = 0;

    // estado do modal de transferência
    private bool modalTransferenciaVisivel = false;
    private string termoPesquisaTransferencia = "";

    private void AbrirModalTransferencia()
    {
        idNovoMasterSelecionado = 0;
        termoPesquisaTransferencia = "";
        modalTransferenciaVisivel = true;
    }

    private void FecharModalTransferencia()
    {
        modalTransferenciaVisivel = false;
        idNovoMasterSelecionado = 0;
        termoPesquisaTransferencia = "";
    }

    // utilizadores elegíveis, filtrados pela pesquisa do modal
    private List<Usuario> UtilizadoresFiltradosTransferencia()
    {
        if (listaUsuarios == null) return new List<Usuario>();
        return listaUsuarios
            .Where(u => u.Id != Estado.UsuarioAtual?.Id)
            .Where(u => string.IsNullOrEmpty(termoPesquisaTransferencia) ||
                        u.Nome.Contains(termoPesquisaTransferencia, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void ExecutarReset()
    {
        if (executandoAcao) return;

        // prepara o estado de verificação e redireciona para a página de segurança
        Estado.AcaoPendente = AcaoCritica.ResetarSistema;
        Estado.NomeAlvoVerificacao = Estado.UsuarioAtual?.Nome ?? "";
        Estado.IdNovoMasterPendente = 0;

        confirmarReset = false;
        Navigation.NavigateTo("/verificacao-seguranca");
    }

    private void ExecutarTransferencia()
    {
        if (idNovoMasterSelecionado == 0) return;

        string nomeNovo = listaUsuarios?.FirstOrDefault(u => u.Id == idNovoMasterSelecionado)?.Nome ?? "?";

        // prepara o estado de verificação e redireciona para a página de segurança
        Estado.AcaoPendente = AcaoCritica.TransferirMaster;
        Estado.NomeAlvoVerificacao = nomeNovo;
        Estado.IdNovoMasterPendente = idNovoMasterSelecionado;

        modalTransferenciaVisivel = false;
        idNovoMasterSelecionado = 0;
        termoPesquisaTransferencia = "";

        Navigation.NavigateTo("/verificacao-seguranca");
    }
}

